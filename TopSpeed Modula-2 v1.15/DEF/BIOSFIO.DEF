DEFINITION  MODULE biosfio;


FROM SYSTEM IMPORT Registers;
FROM Lib    IMPORT Intr;

TYPE str_erreur  = ARRAY[0..19] OF ARRAY[0..42] OF CHAR;

CONST c_erreur = str_erreur( "Pas d'erreur",
                             "Commande incorrecte",
                             "Identificateur de secteur incorrect",
                             "Tentative d'écriture sur un disque protégé",
                             "Secteur pas trouvé",
                             "Erreur de réinitialisation",
                             "La disquette a été retirée",
                             "Table des paramŖtres incorrecte",
                             "Dépassement de capacité du DMA",
                             "Dépassement de la limitte d'un segment",
                             "Erreur de secteur",
                             "Données non valides ( mauvais CRC )",
                             "Erreur de données corrigée",
                             "Erreur issue du controleur",
                             "Mauvais positionnement sur une piste",
                             "Time out : pas de réponse du controleur",
                             "Disque pas prłt",
                             "Erreur indéfinie",
                             "Erreur d'écriture",
                             "Erreur de status"
                             );

PROCEDURE erreur(x : SHORTCARD): CARDINAL;

PROCEDURE reset() : SHORTCARD;

PROCEDURE lit_secteur ( piste,tete,secteur,nbre_secteurs,drive : SHORTCARD ;
                        VAR buffer : ARRAY OF BYTE) : SHORTCARD ;

PROCEDURE ecrit_secteur ( piste,tete,secteur,nbre_secteurs,drive : SHORTCARD ;
                          VAR buffer : ARRAY OF BYTE) : SHORTCARD ;

END biosfio.