DEFINITION MODULE os;

(* PROCEDURES de démarrage *)
PROCEDURE COLD_BOOT;                   (* démarrage à froid                  *)
PROCEDURE WARM_BOOT;                   (* démarrage à chaud                  *)

(* PROCEDURES de console et imprimante *)
PROCEDURE ERREUR_CONSOLE( x: SHORTCARD): CARDINAL;
PROCEDURE CONS : BOOLEAN;              (* teste si caractère est prêt        *)
PROCEDURE CONIN : CHAR;                (* lit un caractère sur la console    *)
PROCEDURE CONOUT( c : CHAR);           (* écrit un caractère sur la console  *)
PROCEDURE LIST( c : CHAR);             (* envoi un caractère sur l'imprimante*)

(* PROCEDURES disques *)
PROCEDURE HOME;                        (* tête en position 0                 *)
PROCEDURE ERREUR_DISQUE( x : SHORTCARD): CARDINAL;
PROCEDURE RESET() : SHORTCARD;
PROCEDURE LIT_SECTEUR ( piste,tete,secteur,nbre_secteurs,drive : SHORTCARD ;
                          VAR buffer : ARRAY OF BYTE) : SHORTCARD ;
PROCEDURE ECRIT_SECTEUR ( piste,tete,secteur,nbre_secteurs,drive : SHORTCARD ;
                          VAR buffer : ARRAY OF BYTE) : SHORTCARD ;


END os.