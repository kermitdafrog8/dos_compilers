DEFINITION MODULE LIM; (* LIM expanded memory *)

VAR
    LIMPresent : BOOLEAN;
    PageFr      : CARDINAL;

PROCEDURE GetStatus() : SHORTCARD;
PROCEDURE GetPageFrame(): CARDINAL;
