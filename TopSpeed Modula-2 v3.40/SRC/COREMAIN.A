include "corelib.inc"

module CoreMain

(****************************************************************************)
segment _BSS(BSS, 28H)

public  __argbuf    : org 192           (* command line buffer *)
public  __hugeshift : org 2
public  __osmajor   : org 2
public  __osminor   : org 2             (* DOS version *)
public  __exit_stk  : org 32*CodePtrSize(* at/onexit function stack *)

segment _DATA(DATA, 28H)

public @InitCalled      : dw 0
public @InitGrandTotal  : dw 0
public @InitCurrent     : dw 0
public @InitRecPointer  : dw 0, 0
public @InitPointer     : dw 0, 0
public @StackContextSP  : dw 0
public @StackContextBP  : dw 0
public @InitDone        : db 0
(*%T MThread *)
public @StackContextSS  : dw 0
(*%E *)
public @InitPriority    : db 0

segment _BSS(BSS, 28H)

public @ExitCode :  org 2

segment _BSS(BSS, 28H)

public __exit_list_done : org 1

segment _DATA(DATA, 28H)

(*%T NearPtr *)
public __exit_ptr : dw __exit_stk + (32*CodePtrSize)
public __exit_top : dw __exit_stk + (32*CodePtrSize)
(*%E *)
(*%F NearPtr *)
public __exit_ptr : dd __exit_stk + (32*CodePtrSize)
public __exit_top : dd __exit_stk + (32*CodePtrSize)
(*%E *)

segment _BSS(BSS, 28H)

public __exit_io :   org CodePtrSize
public __exit_file : org CodePtrSize
public __exit_tmp:   org CodePtrSize

public __exit_proc : org FarCodePtrSize

segment _BSS(BSS, 28H)

public __real_in :   org NearCodePtrSize
public __real_out :  org NearCodePtrSize

segment _DATA(DATA, 28H)

extrn __Term2
(*%F NearCall *)
public standard@haltChain : dd __Term2
(*%T _DLLOVL *)
extrn __Term3
public standard@@haltChain2 : dd __Term3
(*%E *)
(*%E *)
(*%T NearCall *)
public standard@haltChain : dw __Term2
(*%E *)

segment _DATA(DATA, 28H)

public  __CmdLine : dd 0
public  __iHandle : dw 0

segment _DATA(DATA, 28H)

public __farstack : dw 0
public __sp_temp :  dw 0
public __ss_temp :  dw 0

(*%F _OS2 *)
(*%F _WINDOWS *)
segment _DATA(DATA, 28H)

public DOSHUGESHIFT = 12
(*%E *)
(*%E *)

segment _DATA(DATA, 28H)

public  _x_initx :     dw 0,0
public  _x_bss_end :   dw 0
public  _x_bss_start : dw 0

segment _BSS(BSS, 28H)

public __sigsetup :   org 2
public __exitbreak :  org 4
public __exitsig :    org CodePtrSize
public __exitgraph :  org CodePtrSize

segment _DATA(DATA, 28H)

public  __psp           : dw 0
public  __env           : dw 0
public  __heap_base     : dw 0
public  __main_args     : dw 0
public  __env_init      : dw 0
public  __arg_init      : dw 0
public  STKHQQ :
public  __stklen        : dw 0
public  __SSisDS        : dw 0
public  __far_ss        : dw 0
public  __x_near_stack_start : dw 0
public  __heap_size     : dw 0
public  __osmode        : dw 0

segment _DATA(DATA, 28H)

public  __x_ax :      dw 0
public  __x_bx :      dw 0
public  __x_di :      dw 0

segment _DATA(DATA, 28H)

public  _x_main :      dw 0,0
public  __stk_base :   dw 0

segment _BSS(BSS, 28H)

public __nmemsetup :    org 1   (* BOOLEAN flag indicating near heap *)
                                (* has been initialised              *)
segment _BSS(BSS, 28H)

public __fmodmemsetup : org 1   (* BOOLEAN flag indicating M2 far heap *)
                                (* has been initialised             *)
segment _BSS(BSS, 28H)

public __fmemsetup :    org 1   (* BOOLEAN flag indicating far heap *)
                                (* has been initialised             *)


segment _DATA(DATA, 28H)
(*%F _ENV *)
(*%T _DLLOVL *)
extrn Loader$GrowHeap
extrn Loader$ShrinkHeap

public __res_mem :      dd Loader$GrowHeap
public __fix_mem :      dd 0
public __shr_mem :      dd Loader$ShrinkHeap
(*%E *)
(*%F _DLLOVL *)
public __res_mem :      org CodePtrSize
public __fix_mem :      org CodePtrSize
public __shr_mem :      org CodePtrSize
(*%E *)
(*%E *)
(*%T _ENV*)
public __res_mem :      org CodePtrSize
public __fix_mem :      org CodePtrSize
public __shr_mem :      org CodePtrSize
(*%E *)

                                (* procedure variable - points to *)
                                (* routine to shrink heap *)

(****************************************************************************)
section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn @RecursiveExit
extrn __exit
extrn __exit_io
extrn __exit_file
extrn __exit_tmp
extrn __exit_proc
extrn __InitReset
extrn @InitPointer
extrn @InitRecPointer
extrn @ExitCode
extrn @StackContextSP
extrn @StackContextBP
extrn @StackContextSS
extrn @InitCurrent
extrn @InitGrandTotal
extrn @InitCalled
extrn @InitPriority
extrn @InitDone
extrn $Stage2

retCode : dw 0

select _TEXT

(*%F _WINDLL *)
public _exit :

(*%F RegParam *)

code = bxframe
    mov  bx, sp
    mov  ax, ss:[bx][code]
(*%E *)
(*%F SameDS *)
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
    mov  [@ExitCode], ax
    cmp  byte [@RecursiveExit], 0
    je   notAgain
(*%F RegParam *)
    push ax
(*%E *)
(*%F NearCall *)
    call far __exit
(*%E *)
(*%T NearCall *)
    call __exit
(*%E *)
notAgain:
    not  byte [@RecursiveExit]
(*%T MThread *)
    mov  ss, [@StackContextSS]
(*%E *)
    mov  sp, [@StackContextSP]
    mov  bp, [@StackContextBP]
    jmp  near $TerminateProcess
(*%E *)
public __InitLoop :

(*%T _WINDOWS *)
(*%F NearCall *)
    inc  bp
    push bp
    mov  bp, sp
(*%E *)
(*%E *)
(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push di
    push si
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
chainLoop:
traverseLoop:
    les  bx, [@InitRecPointer]
    mov  ax, [@InitCurrent]
    cmp  ax, es:[bx][InitRecTotal]
    je   endOfArray
    les  di, [@InitPointer]
    add  word [@InitPointer], InitRecSize
    inc  word [@InitCurrent]
    mov  al, [@InitPriority]
    cmp  al, es:[di][Priority]
    jne  traverseLoop
    inc  word [@InitCalled]
(*%F NearCall *)
    call far es:[di][ProcVar]
    cmp byte [@InitDone],0
    jz   traverseLoop
initLoopRet:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%T _WINDOWS *)
    pop  bp
    dec  bp
(*%E *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    call es:[di][ProcVar]
    cmp byte [@InitDone],0
    jz   traverseLoop
initLoopRet:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    ret  0
(*%E *)

endOfArray:
    mov  ax, [@InitCalled]
    cmp  ax, [@InitGrandTotal]
    je   stageComplete

    les  bx, [@InitRecPointer]
    les  bx, es:[bx][InitRecNext]
    mov  ax, es
    or   ax, bx
    jz   endOfList
    mov  [@InitRecPointer], bx
    mov  [@InitRecPointer][2], es
    sub  ax, ax
    mov  [@InitCurrent], ax
    mov  [@InitPointer], ax
    mov  ax, es:[bx][InitRecSeg]
    mov  [@InitPointer][2], ax
    jmp  traverseLoop

endOfList:
    dec  byte [@InitPriority]
    js   stageComplete
    call __InitReset
    jmp  chainLoop

stageComplete:
    mov  byte [@InitDone],1
(*%T MThread *)
    mov  [@StackContextSS], ss
(*%E *)
    mov  [@StackContextBP], bp
    mov  [@StackContextSP], sp
(*%F NearCall *)
    call far $Stage2
(*%E *)
(*%T NearCall *)
    call $Stage2
(*%E *)
    mov  [@ExitCode], ax

$TerminateProcess:
(*%T _WINDLL *)
    jmp  initLoopRet
(*%E *)

public __Term2 :
(*%F SameDS *)
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
    extrn __exit_ptr
    extrn __exit_top
    extrn standard@haltChain
(*%T _DLLOVL *)
    extrn standard@@haltChain2
    push [standard@@haltChain2][2]
    push [standard@@haltChain2][0]
(*%E *)
(*%F _DLLOVL *)
(*%F NearCall *)
    push cs
(*%E *)
    mov  bx, __Term3
    push bx
(*%E *)
(*%F NearCall *)
    push [standard@haltChain][2]
(*%E *)
    push [standard@haltChain][0]

(* reset halt chain to allow it to be re-used in termination code *)
(*%T _DLLOVL *)
    push [standard@@haltChain2][0]
    pop  [standard@haltChain][0]
    push [standard@@haltChain2][2]
    pop  [standard@haltChain][2]
(*%E *)
(*%F _DLLOVL *)
    mov word [standard@haltChain][0],__Term3
(*%F NearCall *)
    mov [standard@haltChain][2],cs
(*%E *)
(*%E *)

(*%F NearCall *)
    ret far 0                        (* jump to termination procedures *)
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)
public __Term3:
(*%F _WINDOWS *)
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
(*%T MThread *)
    mov  ss, [@StackContextSS]
(*%E *)
    mov  bp, [@StackContextBP]
    mov  sp, [@StackContextSP]
    mov  si, [__exit_ptr]
    mov  di, [__exit_top]
exitLoop:
    cmp  si, di
    je   loopDone
(*%T NearCall *)
    call [si]
    add  si, 2
(*%E *)
(*%F NearCall *)
    call far [si]
    add  si, 4
(*%E *)
(*%F SameDS *)
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
    jmp  exitLoop
loopDone:

    jmp  initLoopRet

public __cleanup :

(*%F SameDS *)
    mov  cx, _DATA
    mov  ds, cx
(*%E *)
    mov  cx, [__exit_io]
    jcxz noCall1
(*%F SameDS *)
    push ds
(*%E *)
(*%F NearCall *)
    call far [__exit_io]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
(*%F SameDS *)
    pop  ds
(*%E *)
noCall1:
    mov  cx, [__exit_file]
    jcxz noCall2
(*%F SameDS *)
    push ds
(*%E *)
(*%F NearCall *)
    call far [__exit_file]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
(*%F SameDS *)
    pop  ds
(*%E *)
noCall2:
    mov  cx, [__exit_tmp]
    jcxz noCall3
(*%F SameDS *)
    push ds
(*%E *)
(*%F NearCall *)
    call far [__exit_tmp]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
(*%F SameDS *)
    pop  ds
(*%E *)
noCall3:
    mov  cx, [__exit_proc]
    jcxz noCall4
(*%F SameDS *)
    push ds
(*%E *)
    call far [__exit_proc]
(*%F SameDS *)
    pop  ds
(*%E *)
noCall4:
    ret  0

(******************************************************************************)
section
segment _DATA(DATA, 28H)
segment _TEXT(CODE,28H)

select _TEXT

extrn __env_init
extrn _malloc
extrn __env
extrn __env_var
extrn __env_copy
extrn __FatalErrorPos
extrn __FatalError


public __setenv :

n       = -2
p       = -4
c       = -6
eptr    = -10
current = -14
dgroup  = -16
locals  =  16

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
    mov  [bp][dgroup], ds
    cmp  byte [__env_init], 0
    jne  near setDone
    not  byte [__env_init]
memSet:
    sub  dx, dx
    mov  [bp][n], dx
    mov  ax, [__env]
    mov  [bp][eptr][2], ax
    mov  word [bp][eptr], 0
Loop1:
    cmp  dx, 63
    jge  Loop1Done
    sub  cx, cx
    lds  si, [bp][eptr]
Loop2:
    cmp  cx, 1024
    jge  Loop2Done
    lodsb
    or  al, al
    jz  Loop2Done
    inc  cx
    jmp  Loop2
Loop2Done:
    jcxz Loop1Done
    inc  cx
    mov  ax, cx
    mov  [bp][p], cx
    mov  [bp][n], dx
    mov  ds, [bp][dgroup]
(*%F RegParam *)
    push ax
(*%E *)
(*%F NearCall *)
    call far _malloc
(*%E *)
(*%T NearCall *)
    call _malloc
(*%E *)
(*%F RegParam *)
    add  sp, 2
(*%E *)
    mov  [bp][current], ax
(*%F NearPtr *)
    mov  [bp][current][2], dx
    or  dx, dx
(*%E *)
(*%T NearPtr *)
(*%F _WINDOWS *)
    mov  word [bp][current][2], _DATA
(*%E *)
(*%T _WINDOWS *)
    mov  word [bp][current][2], ss
(*%E *)
    or  ax, ax
(*%E *)
    jz  InternalError
    mov  di, [bp][current]
    mov  es, [bp][current][2]
    mov  si, [bp][eptr]
    mov  ax, [bp][eptr][2]
    mov  cx, [bp][p]
    call __env_copy
    mov  bx, [bp][n]
(*%F NearPtr *)
    mov  cl, 2
(*%E *)
(*%T NearPtr *)
    mov  cl, 1
(*%E *)
    shl  bx, cl
    mov  ax, [bp][current]
    mov  [bx][__env_var], ax
(*%F NearPtr *)
    mov  ax, [bp][current][2]
    mov  [bx][__env_var][2], ax
(*%E *)
    inc  word [bp][n]
    mov  dx, [bp][n]
    mov  cx, [bp][p]
    add  [bp][eptr], cx
    jmp  Loop1
Loop1Done:
    mov  ds, [bp][dgroup]
    mov  bx, [bp][n]
(*%F NearPtr *)
    mov  cl, 2
(*%E *)
(*%T NearPtr *)
    mov  cl, 1
(*%E *)
    shl  bx, cl
    sub  ax, ax
    mov  [bx][__env_var], ax
    mov  [bx][__env_var][2], ax
setDone:
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

InternalError:
    call far __FatalErrorPos
    mov  cx, 60H
    push cx
    push dx
    push ax
    call far __FatalError

(******************************************************************************)
section
extrn __env_var
extrn __core_lock
extrn __core_unlock
extrn $StdRet

segment _TEXT(CODE,00028H)


nicmp :

(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%F NearPtr *)
RetSize = 2
(*%E *)


(*%F NearPtr *)
num    = sframe
(*%E *)

(*%F NearPtr *)
    push bp
    mov  bp, sp
(*%E *)
(*%T NearPtr *)
    push dx
(*%E *)
    push di
    push si
(*%F NearPtr *)
    push ds
    mov  ds, bx
    mov  si, ax
    mov  di, cx
    mov  es, dx
    mov  cx, [bp][num]
(*%E *)
(*%T NearPtr *)
    mov  si, ax
    mov  di, bx
    push ds
    pop  es
(*%E *)
    sub  ax, ax
    jcxz nicmpDone
nicmpLoop:
    lodsb
    cmp  al, 'z'        (* convert to upper if lower *)
    ja   notlowa
    cmp  al, 'a'
    jb   notlowa
    sub  al, 20H
notlowa:
    mov  bl, es:[di]
    inc  di             (* convert to upper if lower *)
    cmp  bl, 'z'
    ja   notlowb
    cmp  bl, 'a'
    jb   notlowb
    sub  bl, 20H
notlowb:
    cmp  al, bl
    jl   nicmpLessThan
    jg   nicmpGreaterThan
    or   al, al
    loopne nicmpLoop
nicmpSame:
    sub  ax, ax         (* return 0 *)
    jmp  nicmpDone
nicmpLessThan:
    mov  ax, -1         (* return -1 *)
    jmp  nicmpDone
nicmpGreaterThan:
    mov  ax, 1          (* return 1 *)
nicmpDone:
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  si
    pop  di
(*%T NearPtr *)
    pop  dx
(*%E *)
(*%F NearPtr *)
    pop  bp
(*%E *)
    ret  RetSize

public _getenv :

(*%F RegParam *)
str = frame
(*%E *)
(*%T RegParam *)
(*%T NearPtr *)
str = - 2
(*%E *)
(*%F NearPtr *)
str = - 4
(*%E *)
(*%E *)

(*%T NearPtr *)
    push  bp
    mov   bp,sp
    sub   sp, 2
    push  di
    push  si
(*%T RegParam *)
    push  dx
    push  cx
    push  bx
    mov   [bp][str],ax
(*%E *)
(*%F RegParam *)
    mov  ax, [bp][str]
(*%E *)
    push  ds
    pop   es
    mov   di, ax
    mov   cx, 0FFFFH
    sub   al, al
repne ;   scasb             (* get length of string *)
    not   cx
    dec   cx
    mov   di,cx
    xor   dx,dx
$0:
    mov   bx,dx
    add   bx,dx
    mov   si,[bx][__env_var]
    test  si,si
    je    $2
    mov   cx,di
    mov   bx,si
    mov   ax,[bp][str]
    call  nicmp
    test  ax,ax
    je    $3
$1:
    inc   dx
    cmp   dx,3FH
    jl    $0
$2:
    xor   ax,ax
    jmp   $4
$3:
    mov   bx,di
    add   bx,si
    cmp   byte [bx],3DH
    jne   $1
    inc   bx
    mov   ax,bx
$4:
(*%T RegParam *)
    pop  bx
    pop  cx
    pop  dx
(*%E *)
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret far 0
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)
(*%E *)

(*%F NearPtr *)
    push  bp
    mov   bp,sp
    sub   sp,0AH
    push  ds
    push  di
    push  si
(*%T MThread *)
    mov  di, seg __core_lock
    mov  es, di
    call far es:[__core_lock]
(*%E *)
(*%T RegParam *)
    push  cx
    mov   [bp][str],ax
    mov   [bp][str][2],bx
(*%E *)
(*%F RegParam *)
    mov  ax, [bp][str]
    mov  bx, [bp][str][2]
(*%E *)
    mov   di,ax
    mov   es,bx
    mov   cx,-1
    sub   al,al
    repne ;scasb
    not   cx
    mov   ax,cx
    dec   ax
    mov   di,ax
    xor   si,si
    mov   ax,seg __env_var
    mov   [bp][-6],ax
$0:
    mov   bx,si
    shl   bx,1
    shl   bx,1
    mov   ds,[bp][-6]
    lds   cx,[bx][__env_var]
    mov   [bp][-0AH],cx
    mov   ax,ds
    or    ax,cx
    je    $2
    push  di
    mov   dx,ds
    mov   ax,[bp][str]
    mov   bx,[bp][str][2]
    call  nicmp
    test  ax,ax
    je    $3
$1:
    inc   si
    cmp   si,3FH
    jl    $0
$2:
    xor   ax,ax
    xor   dx,dx
    jmp   $4
$3:
    mov   bx,[bp][-0AH]
    cmp   byte [bx][di],3DH
    jne   $1
    lea   ax,[bx][di][1]
    mov   dx,ds
$4:
(*%T RegParam *)
    pop   cx
(*%E *)
(*%T MThread *)
    mov  di, seg __core_unlock
    mov  es, di
    call far es:[__core_unlock]
(*%E *)
    pop   si
    pop   di
    pop   ds
    mov   sp,bp
    pop   bp
(*%F NearCall *)
    ret far 0
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)
(*%E *)

(****************************************************************************)
(*%T _OS2 *)
section
segment _DATA(DATA, 28H)
segment _TEXT(CODE,28H)

extrn __exit_ptr
extrn __exit_top
extrn __exit_io
extrn __exit_file
extrn __exit_tmp
extrn __exit_proc
extrn __exit_list_done
extrn __x_near_stack_start
extrn __farstack
extrn standard@haltChain
extrn DOSEXITLIST
extrn __do_exit_lists

exit_handler:
    mov  bx, _DATA
    mov  ds, bx
    cmp  byte [__exit_list_done], 0
    jnz  noCall4
    cmp  word [__farstack], 0
    jnz  notNear
    mov  sp, [__x_near_stack_start]
    mov  ss, bx
notNear:
(*%F NearCall *)
    push [standard@haltChain][2]
(*%E *)
    push [standard@haltChain][0]

(* reset halt chain to allow it to be re-used in termination code *)
    mov word [standard@haltChain][0],here
(*%F NearCall *)
    mov [standard@haltChain][2],cs
(*%E *)

(*%F NearCall *)
    ret far 0                        (* jump to termination procedures *)
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)
here:
    mov  bx, _DATA
    mov  ds, bx
    mov  si, [__exit_ptr]
    mov  di, [__exit_top]
exitLoop:
    cmp  si, di
    je   loopDone
(*%T NearCall *)
    call [si]
    add  si, 2
(*%E *)
(*%F NearCall *)
    call far [si]
    add  si, 4
(*%E *)
(*%F SameDS *)
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
    jmp  exitLoop
loopDone:
noCall4:
    mov  ax, EXLST_EXIT
    push ax
    sub  ax, ax
    push ax
    push ax
    call far DOSEXITLIST

public __set_exit_handler :
    mov  ax, EXLST_ADD
    push ax
    push cs
    mov  ax, exit_handler
    push ax
    call far DOSEXITLIST
    ret far 0
(*%E *)

section
(****************************************************************************)
(*%T _WINDLL *)
segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

extrn __exit_io
extrn __exit_file
extrn __exit_tmp
extrn __exit_proc
extrn __exit_ptr
extrn __exit_top
extrn standard@haltChain

public _exit :

(*%F NearCall *)
    push [standard@haltChain][2]
(*%E *)
    push [standard@haltChain][0]

(* reset halt chain to allow it to be re-used in termination code *)
    mov word [standard@haltChain][0],here
(*%F NearCall *)
    mov [standard@haltChain][2],cs
(*%E *)

(*%F NearCall *)
    ret far 0                        (* jump to termination procedures *)
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)
here:
    mov  bx, _DATA
    mov  ds, bx
    mov  si, [__exit_ptr]
    mov  di, [__exit_top]
exitLoop:
    cmp  si, di
    je   loopDone
(*%T NearCall *)
    call [si]
    add  si, 2
(*%E *)
(*%F NearCall *)
    call far [si]
    add  si, 4
(*%E *)
(*%F SameDS *)
    mov  ds, bx
(*%E *)
    jmp  exitLoop
loopDone:
    mov  cx, [__exit_io]
    jcxz noCall1
(*%F NearCall *)
    call far [__exit_io]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noCall1:
    mov  cx, [__exit_file]
    jcxz noCall2
(*%F NearCall *)
    call far [__exit_file]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noCall2:
    mov  cx, [__exit_tmp]
    jcxz noCall3
(*%F NearCall *)
    call far [__exit_tmp]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noCall3:

(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*%E _WINDLL*)

(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA,28H)

public @InitChain : dw 0, 0

select _TEXT

public __InitLink :
  (* Initializes @InitChain from record passed in ax:bx *)

(*%F SameDS *)
    push ds
    mov  cx, _DATA
    mov  ds, cx                        (* ds = _DATA *)
(*%E *)
    mov  es, ax                        (* es = seg of record *)
    mov  ax, [@InitChain]
    mov  es:[bx], ax                   (* @InitChain -> record passed in *)
    mov  ax, [@InitChain][2]
    mov  es:[bx][2], ax
    mov  [@InitChain], bx
    mov  [@InitChain][2], es
(*%F SameDS *)
    pop  ds
(*%E *)
    ret  far 0

(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA,28H)
segment _INIT(INIT_CODE,28H)

select _DATA

extrn @InitCalled
extrn @InitPriority
extrn @InitCurrent
extrn @InitPointer
extrn @InitRecPointer
extrn @InitGrandTotal
extrn @InitChain
extrn __osmode

select _TEXT

public __InitReset :

    les  bx, [@InitChain]
    sub  cx, cx
    mov  word [@InitCurrent], cx
    mov  word [@InitPointer], cx
    mov  ax, es:[bx][InitRecSeg]
    mov  [@InitPointer][2], ax
    mov  [@InitRecPointer], bx
    mov  [@InitRecPointer][2], es
    ret  0

public __InitSetup :

Current = -4
locals  =  4

    push bp
    mov  bp, sp
    sub  sp, locals
    call __InitReset
chainLoop:
    mov  ax, es
    or   ax, bx
    jz   chainDone
    mov  [bp][Current], bx
    mov  [bp][Current][2], es
    mov  es, es:[bx][InitRecSeg]
    cmp  byte [__osmode], 1
    jnz  realMode
    mov  ax, es
    (* lsl cx, ax *)
    db   0FH, 3, 0C8H
    jcxz gotCount
    mov  ax, cx
    mov  cl, InitRecSize
    div  cl
    sub  ah, ah
    mov  cx, ax
    jmp  gotCount
realMode:
    mov  cx, -1
    mov  di, -InitRecSize
sizeLoop:
    add  di, InitRecSize
    cmp  word es:[di][Magic], MAGIC_NUM
    loope sizeLoop
    neg  cx
    sub  cx, 2
gotCount:
    add  [@InitGrandTotal], cx
    les  bx, [bp][Current]
    mov  es:[bx][InitRecTotal], cx
    les  bx, es:[bx][InitRecNext]
    jmp  chainLoop
chainDone:
    mov  word [@InitCalled], 0
    mov  byte [@InitPriority], PRMAX
    mov  sp, bp
    pop  bp
    ret  0

(***************************************************************************)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn _x_main
extrn _main

select _DATA

extrn __argv
extrn __argc

select _TEXT

public __main_args2 :
(*%F RegParam *)
(*%F NearPtr *)
  push ds                        (*  char *argv[] *)
(*%E *)
  mov  ax, __argv
  push ax
  push [__argc]                  (*  int argc *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
  mov  ax, [__argc]              (* int argc *)
  mov  bx, __argv                (* char *argv[] *)
  mov  cx, ds
(*%E *)
(*%T NearPtr *)
  mov  ax, [__argc]
  mov  bx, __argv
(*%E *)
(*%E *)

(*%F NearCall *)
  call far [_x_main]             (* call main *)
(*%E *)
(*%T NearCall *)
  call _main
(*%E *)

(*%F RegParam *)
(*%F NearPtr *)
  add sp, 6
(*%E *)
(*%T NearPtr *)
  add sp, 4
(*%E *)
(*%E *)

(*%F NearCall *)
  ret  far 0
(*%E *)
(*%T NearCall *)
  ret  0
(*%E *)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn _x_main
extrn _main

select _DATA

extrn __env_var
extrn __argv
extrn __argc

select _TEXT

public __main_args3 :
(*%F RegParam *)
(*%F NearPtr *)              (* pass arguments to main *)
  push ds
(*%E *)
  mov  ax, __env_var
  push ax                        (*  char *envp[] *)
(*%F NearPtr *)
  push ds                        (*  char *argv[] *)
(*%E *)
  mov  ax, __argv
  push ax
  push [__argc]                  (*  int argc *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
  mov  ax, [__argc]              (* int argc *)
  mov  bx, __argv                (* char *argv[] *)
  mov  cx, ds
  push ds
  mov  dx, __env_var
  push dx                        (*  char *envp[] *)
(*%E *)
(*%T NearPtr *)
  mov  ax, [__argc]
  mov  bx, __argv
  mov  cx, __env_var
(*%E *)
(*%E *)

(*%F NearCall *)
  call far [_x_main]             (* call main *)
(*%E *)
(*%T NearCall *)
  call _main
(*%E *)

(*%F RegParam *)
(*%F NearPtr *)
  add sp, 10
(*%E *)
(*%T NearPtr *)
  add sp, 6
(*%E *)
(*%E *)

(*%F NearCall *)
  ret  far 0
(*%E *)
(*%T NearCall *)
  ret  0
(*%E *)

section
(****************************************************************************)
(*%T _WINDLL *)
segment _TEXT(CODE,28H)

extrn LIBMAIN
extrn __heap_size
extrn __CmdLine
extrn __iHandle
extrn __call_main

public __libmain_args :

   push [__iHandle]
