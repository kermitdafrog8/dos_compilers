section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn DOSGETPID

select _TEXT


public _getpid :

(* struct _PIDINFO *)

pid         = 0
tid         = 2
pidParent   = 6

PidInfoSize = 6

pidbuf  = -PidInfoSize
locals  = PidInfoSize

    push bp
    mov  bp, sp
    sub  sp, locals
    push ss
    lea  ax, [bp][pidbuf]
    push ax
    call far DOSGETPID
    mov  ax, [bp][pidbuf][pid]
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*%E *) (* OS2 *)

section
(*%F _OS2 *)
(*%F _WINDOWS *)
  (***********************************************************************)
  (* $SWInt - Generate a SoftWare Interrupt                              *)
  (*                                                                     *)
  (* DOS Memory Models                                                   *)
  (*                                                                     *)
  (*   Internal Procedure - Near Call                                    *)
  (*     Parameters:                                                     *)
  (*       All Registers set up                                          *)
  (*       Interrupt number on stack                                     *)
  (*     Return:                                                         *)
  (*       All Registers set up                                          *)
  (*                                                                     *)
  (***********************************************************************)
segment _TEXT(CODE,48H)

IntNo                   = frame + 2
Flags                   = 2

public $SWInt :
    pushf
    push bp
    mov  bp, sp
    push ax
    mov  ax, [bp][IntNo]
    cli
    mov  cs:[$$InterruptNo], al
    mov  cs:[$$InterruptNo2], al
    db   0EAH                         (*I far jmp *)
    dw   $$Next,_TEXT                 (* purge pre-fetch *)
$$Next:
    cmp  al, 25H
    je   $$Int2526
    cmp  al, 26H
    je   $$Int2526
    pop  ax
    pop  bp
    db   0CDH                          (*I int *)
$$InterruptNo:
    db   0
$$IntDone:
    push bp
    mov  bp, sp
    push ax
    lahf
    mov  [bp][Flags], ah
    pop  ax
    pop  bp
    popf
(*%T _fcall *)
    ret  far 2
(*%E *)
(*%F _fcall *)
    ret  2
(*%E *)
$$Int2526:
    pop  ax
    pop  bp
    db   0CDH                          (*I int *)
$$InterruptNo2:
    db   0
    inc  sp
    inc  sp
    jmp  $$IntDone

(*%E _WINDOWS *)
(*%E _OS2 *)

section
(*%T _WINDOWS *)
  (***********************************************************************)
  (* $SWInt - Generate a SoftWare Interrupt                              *)
  (*                                                                     *)
  (* Windows Memory Models                                               *)
  (*                                                                     *)
  (*   Internal Procedure - Near Call                                    *)
  (*     Parameters:                                                     *)
  (*       All Registers set up                                          *)
  (*       Interrupt number on stack                                     *)
  (*     Return:                                                         *)
  (*       All Registers set up                                          *)
  (*                                                                     *)
  (***********************************************************************)
segment _TEXT(CODE,48H)

extrn ALLOCCSTODSALIAS
extrn FREESELECTOR

IntNo                   = frame + 2
Flags                   = 2

public $SWInt :
    pushf
    push bp
    mov  bp, sp
    push ax
    push ds
    push cs
    call far ALLOCCSTODSALIAS
    mov  ds, ax
    mov  ax, [bp][IntNo]
    cli
    mov  [$$InterruptNo],  al
    mov  [$$InterruptNo2], al
(*  call far $ClearPipe *)
    mov  ax, ds
    pop  ds
    push ax
    call far FREESELECTOR
    mov  ax, [bp][IntNo]
    cmp  al, 25H
    je   $$Dos2526
    cmp  al, 26H
    je   $$Dos2526
    pop  ax
    pop  bp
    db   0CDH                          (*I int *)
$$InterruptNo:
    db   0
$$IntDone:
    push bp
    mov  bp, sp
    push ax
    lahf
    mov  [bp][Flags], ah
    pop  ax
    pop  bp
    popf
(*%T _fcall *)
    ret  far 2
(*%E *)
(*%F _fcall *)
    ret  2
(*%E *)
$$Dos2526:
    pop  ax
    pop  bp
    db   0CDH                          (*I int *)
$$InterruptNo2:
    db   0
    inc  sp
    inc  sp
    jmp  $$IntDone

(*%E _WINDOWS *)

end


