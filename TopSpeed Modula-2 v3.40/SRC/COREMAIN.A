segment EMU_TEXT  (EMU_CODE,28H)

public __FloatInitStack :

(*%T RegParam *)
 push cx     (* initialise fp registers except for stack top *)
 mov cx,7
push_zero:
 fldz st(0)
 loop push_zero
 pop cx
(*%E *)
 ret  far 0

(*%E _WINDOWS *)

section

segment _TEXT(CODE,28H)
segment PROC_TEXT(CODE,28H)
segment _DATA(DATA, 28H)
segment EMU_STATE(DATA,68H)

extrn @Save8087
extrn emuBuffer
extrn __initsig
extrn __real_in
extrn __real_out
extrn __rreal_in
extrn __rreal_out
extrn __farstack
extrn __stk_base

select _TEXT

public __fp_1 :


(*%F _WINDOWS *)
    mov  ax, PROC_TEXT
    mov  es, ax
    mov  byte es:[@Save8087], 1
    mov  ax, _DATA
    mov  es, ax
    cmp  word es:[__farstack], 0
    je   nearStack
    add  word es:[__stk_base], 490
nearStack:
(*%F _DLL *)
    mov  word es:[__real_in], __rreal_in     (* initialise 'C' fp output *)
    mov  word es:[__real_out], __rreal_out
(*%E *)
    call far __initsig
    ret  far 0

dw emuBuffer
(*%E *)

(*%T _WINDOWS *)
    mov  word [__real_in], __rreal_in     (* initialise 'C' fp output *)
    mov  word [__real_out], __rreal_out
    call far __initsig
    ret  far 0

