(*%T NearCall *)
initargc : dw MAGIC_NUM
           db PR4
           dw do_initargc
(*%E *)

select _BSS
public __argv : org 32*DataPtrSize

select _DATA
public __argc : dw initargc


select  _TEXT

    call __setargv
(*%F NearCall *)
    ret  far 0
