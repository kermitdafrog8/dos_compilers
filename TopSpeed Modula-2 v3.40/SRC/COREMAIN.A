extrn __rreal_out
extrn __stk_base
extrn __farstack

select _TEXT

public __fp_1 :

    mov  ax, _DATA
    mov  es, ax
    cmp  word [__farstack], 0
    je   nearStack
    add  word [__stk_base], 490
nearStack:
(*%F _DLL *)
    mov  word es:[__real_in], __rreal_in     (* initialise 'C' fp output *)
    mov  word es:[__real_out], __rreal_out
(*%E *)
    call far __initsig
    ret  far 0

dw emuBuffer
