segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn DOSGETVERSION
extrn DOSGETMACHINEMODE

select _DATA

extrn __osmajor
extrn __osminor
extrn __osmode

select _TEXT

public __osversion :

(*
void __osversion(void)

sets OS version
*)

version = -2
locals  =  2

    push bp
    mov  bp, sp
    sub  sp, locals
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    push ss
    lea  ax, [bp][version]
    push ax
    call far DOSGETVERSION
    sub  ax, ax
    mov  al, [bp][version]
    mov  [__osminor], ax
    mov  al, [bp][version][1]
    mov  [__osmajor], ax
    push ds
    mov  ax, __osmode
    push ax
    call far DOSGETMACHINEMODE
(*%F SameDS *)
    pop  ds
(*%E *)
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)


select _DATA

extrn __x_ax
extrn __x_bx

extrn __argv
extrn __argbuf
extrn __argc
extrn __arg_init

select _TEXT

public __setargv :

    push bp
    push di
    push si
    push ds
    mov  cx, _DATA
    mov  ds, cx
    cmp  byte [__arg_init], 0
    jne  near initDone
    not  byte [__arg_init]
    mov  di, __argbuf
(*%F NearPtr *)
    push ds
    mov  si, [__x_bx]
    mov  ds, [__x_ax]
    mov  ax, _DATA
    mov  es, ax
    mov  di, __argbuf
    mov  bx, __argv
    sub  bp, bp
    mov  cx, 1
    mov  dl, ' '
    mov  dh, 0
mainLoop:
    mov  es:[bx], di
    mov  es:[bx][2], es
    inc  bp
copyLoop:
startStringRet:
    lodsb
    or   al, al
    je   copyDone
    cmp  al, dl
    je   getNextCommand
    cmp  al, '"'
    je   startString
    stosb
    jmp  copyLoop
getNextCommand:
    cmp  dh, 1
    jz   endString
endStringRet:
    sub  al, al
    stosb
    add  bx, 4
skipLoop:
    mov  al, [si]
    or   al, al
    je   copyDone
    cmp  al, ' '
    jne  mainLoop
    inc  si
    loop skipLoop
copyDone:
    dec  cx
    jcxz getNextCommand
    stosb
    pop  ds
(*%E *)
(*%T NearPtr *)
    push ds
    mov  si, [__x_bx]
    mov  ds, [__x_ax]
    mov  ax, _DATA
    mov  es, ax
    mov  di, __argbuf
    mov  bx, __argv
    sub  bp, bp
    mov  cx, 1
    mov  dl, ' '
    mov  dh, 0
mainLoop:
    mov  es:[bx], di
    inc  bp
copyLoop:
startStringRet:
    lodsb
    or   al, al
    je   copyDone
    cmp  al, dl
    je   getNextCommand
    cmp  al, '"'
    je   startString
    stosb
    jmp  copyLoop
getNextCommand:
    cmp  dh, 1
    jz   endString
endStringRet:
    sub  al, al
    stosb
    add  bx, 2
skipLoop:
    mov  al, [si]
    or   al, al
    je   copyDone
    cmp  al, ' '
    jne  mainLoop
    inc  si
    loop skipLoop
copyDone:
    dec  cx
    jcxz getNextCommand
    stosb
    pop  ds
(*%E *)
    mov  [__argc], bp
initDone:
    pop  ds
    pop  si
    pop  di
    pop  bp
    ret  0

startString:
    mov  dl, '"'
    mov  dh, 1
    jmp  startStringRet

endString:
    mov  dl, ' '
    mov  dh, 0
    inc  si
    jmp  endStringRet


(***************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn VIOWRTCHARSTR

select _DATA

message : db 'Floating Point Not Loaded'
MESLEN = 25

select _TEXT


public __real_pdef :
public __real_sdef :

(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    push ds
    mov  ax, message
    push ax
    mov  ax, MESLEN
    push ax
    sub  ax, ax
    push ax
    push ax
    push ax
    call far VIOWRTCHARSTR
(*%F SameDS *)
    pop  ds
(*%E *)
    ret  0

section

segment _TEXT(CODE,28H)
segment _INIT(INIT_CODE,28H)
segment _CONST(DATA,28H)
segment _DATA(DATA,28H)
segment BSS_START(BSS,28H)
segment _BSS(BSS,28H)
segment BSS_END(BSS,28H)
segment NEAR_STACK(BSS,28H)
segment NEAR_HEAP(BSS,28H)

group DGROUP(_CONST,_DATA,BSS_START,_BSS,BSS_END,NEAR_STACK,NEAR_HEAP)


extrn __hugeshift
extrn __env_var
extrn __env_size
extrn __env
extrn __psp
extrn __osmajor
extrn __osmode
extrn __osversion
extrn @ExitCode
extrn __argv
extrn __argc
extrn __argbuf
extrn __farstack
extrn __nheaptop
extrn __sp_temp
extrn __ss_temp
extrn _x_bss_end
extrn _x_main
extrn __x_ax
extrn __x_bx
extrn __x_di
extrn __main_args
extrn __exit
extrn __cleanup
extrn _main
extrn __SSisDS
extrn __stk_base
extrn _x_initx
extrn __stklen
extrn __FloatInit
(*%F _DLL *)
extrn __siginit
(*%E *)
extrn __x_near_stack_start
extrn DOSGETHUGESHIFT
extrn DOSFREESEG
extrn DOSREALLOCSEG
extrn DOSGETMACHINEMODE
extrn __set_exit_handler
extrn __InitSetup
extrn __InitLoop

select _TEXT

public __startup :
  mov  dx, _DATA
  mov  ds, dx
  mov  [__stklen], si
  mov  [__SSisDS], cx
  mov  [__x_ax], ax
  mov  [__x_bx], bx
  mov  [__x_di], di
  mov  [__env], ax
  mov  [__sp_temp], sp
  mov  [__ss_temp], ss
(*%T _XTD *)
  push ax
  push bx
  mov  ah, 51H
  int  21H
  mov  [__psp],bx
  call far __osversion
  pop  bx
  pop  ax
(*%E *)
  push ds
  mov  ax, __osmode
  push ax
  call far DOSGETMACHINEMODE
(*%T MThread *)
  mov  byte ss:[CurrentThread], 1      (* Thread number *)
(*%E *)
  mov word ss:[InMathLib], 0
(*%T NearPtr *)
  cmp  byte [__SSisDS], 0
  jnz  sidSet
  mov  byte [__SSisDS], 1
sidSet:
(*%E *)
  cmp  byte [__SSisDS], 1
  je   nearStack
  cmp  byte [__SSisDS], 2
  je   pmStack
  not  word [__farstack]       (* far stack required, not much to do *)
  jmp  stackSet
nearStack:
  mov  bx, [__x_near_stack_start]
  mov  [__stk_base], bx
  add  bx, [__stklen]
  and  bx, ~1
  sub  bx, 2
  mov  ax, _DATA               (* Near stack required, move it to DGROUP *)
  mov  ss, ax
  mov  sp, bx
  jmp  stackSet
pmStack:
  mov  ax, sp
  sub  ax, [__stklen]
  mov  [__stk_base], ax
stackSet:
  mov  ax, __hugeshift
  push ds
  push ax
  call far DOSGETHUGESHIFT
  mov  cx, [__hugeshift]
  mov  ax, 1
  shl  ax, cx
  mov  [__hugeshift], ax
  mov  ax, STACK_GUARD
  push ax
  sub  bp, bp
  push bp
  mov  bp, sp
  call far __FloatInit
  cmp  word [__osmode], 0
  je   notPMode
  call far __set_exit_handler
notPMode:
  call __InitSetup
(*%F NearCall *)
  call far __InitLoop        (* lib module initialisation is called here *)
(*%E *)
(*%T NearCall *)
  call __InitLoop
(*%E *)
  call __cleanup
  mov  ax, [@ExitCode]
(*%F RegParam *)
  push ax
(*%E *)
(*%F NearCall *)
  call far __exit
(*%E *)
(*%T NearCall *)
  call __exit
(*%E *)
(* This call will not return *)
(*****************************)

public $Stage2 :
(*%F _DLL *)
  call __siginit
(*%E *)
  add  word [__stk_base], 100H
  jmp far [_x_initx]
public __call_main :
(*%F NearCall *)
  call far [_x_main]
  ret  far 0
(*%E *)
(*%T NearCall *)
  call [_x_main]
  ret  0
(*%E *)

(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn  DOSEXIT

select _DATA

extrn __sp_temp
extrn __ss_temp
extrn __SSisDS
extrn __exit_list_done

select _TEXT

public __exit :

(*
void __exit(int code)

terminates process.
*)
(*%F RegParam *)
code   = frame

    push bp
    mov  bp, sp
    mov  ax, [bp][code]
(*%E *)
    cmp  byte [__SSisDS], 1
    jne  farStack
    mov  ss, [__ss_temp]
    mov  sp, [__sp_temp]
farStack:
    mov  byte [__exit_list_done], 1
    mov  bx, EXIT_PROCESS
    push bx
    push ax
    call far  DOSEXIT                (* call exit function *)

db 'TopSpeed RTL (C) JPI 1989'

section

segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)
segment EMU_STATE(DATA,68H)

extrn emuBuffer
