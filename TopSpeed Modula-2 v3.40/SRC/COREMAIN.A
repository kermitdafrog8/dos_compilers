(***************************************************************************)
section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __stklen
extrn __nheaptop
extrn __SSisDS
extrn __far_ss

select _TEXT

(* ------------------------------------------------------------------------
   PROCEDURE - _getheapbase.

   PRECONDITIONS - __SSisDS, far_ss and __stklen initialised.

   POSTCONDITIONS - None.

   IN PARAMETERS -  None.

   OUT PARAMETERS - Returns far pointer to far heap base.

   CALLING CONVENTION - Standard.

   NOTES -  Does not cause far heap to be initialsised.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)

public __getheapbase :

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%F NearPtr *)
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    sub  ax, ax
    cmp  byte [__SSisDS], 0
    jne  nearStack
    add  ax, [__stklen]
    add  ax, 0FH
    shr  ax, 1
    shr  ax, 1
    shr  ax, 1
    shr  ax, 1
nearStack:
    mov  dx, [__far_ss]
    add  dx, ax
    sub  ax, ax
(*%F SameDS *)
    pop  ds
(*%E *)
(*%E *)

(*%T NearPtr *)
    mov  dx, [__far_ss]
    sub  ax, ax
(*%E *)

(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(****************************************************************************)
(*%F _WINDLL *)
section

segment _INIT(INIT_CODE,28H)
segment _TEXT(CODE,28H)
segment _DATA(DATA,28H)
segment _BSS(BSS, 28H)

extrn __setargv

select _TEXT

do_initargc : (* defined later on ! *)

select _INIT
(*%F NearCall *)
initargc : dw MAGIC_NUM
           db PR4
           dd do_initargc
(*%E *)
(*%T NearCall *)
initargc : dw MAGIC_NUM
           db PR4
           dw do_initargc
(*%E *)

select _BSS
public __argv : org 32*DataPtrSize

select _DATA

public __argc : dw initargc

select  _TEXT

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    call __setargv
(*%F NearCall *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section

segment _INIT(INIT_CODE,28H)
segment _TEXT(CODE,28H)
segment _DATA(DATA,28H)
segment _BSS(BSS, 28H)

extrn __setargv
extrn __setenv

select _TEXT

do_initargce : (* defined later on ! *)

select _INIT
(*%F NearCall *)
initargce : dw MAGIC_NUM
            db PR4
            dd do_initargce
(*%E *)
(*%T NearCall *)
initargce : dw MAGIC_NUM
            db PR4
            dw do_initargce
(*%E *)

select _DATA

public __env_var : dw initargce
                   org ENVNUM*DataPtrSize-2

select  _TEXT

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%F NearCall *)
    call far __setenv
(*%E *)
(*%T NearCall *)
    call __setenv
(*%E *)
    call __setargv
(*%F NearCall *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)
(****************************************************************************)

segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __exit
extrn __osmajor
extrn __osminor

select _TEXT


(* void __osversion(void) - checks DOS version and terminates if v1.x. *)

public __osversion :
    push ds
    mov  ah, 30H
    int  21H
    or   al, al
    je   versionOne
    mov  [__osmajor], al
    mov  [__osminor], ah
    jmp  versionDone
versionOne:
    mov  ax, cs
    mov  ds, ax
    mov  dx, message
    mov  ah, 9
    int  21H
    pop  ds
(*%F NearCall *)
    call far __exit
(*%E *)
(*%T NearCall *)
    call __exit
(*%E *)
versionDone:
    pop  ds
    ret  0

message : db 'Error MSDOS V1$'

(**************************************************************************)
(*%F _WINDLL *)
section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _DATA

extrn __osmajor
extrn __argv
extrn __argbuf
extrn __argc
extrn __psp
extrn __arg_init

select _TEXT

public __setargv :

  push di
  push si
  push ds
  cmp  byte [__arg_init], 0
  jne  near initDone
  not  byte [__arg_init]
  mov  di, __argbuf
  cmp  word [__osmajor], 2             (* process command line *)
  je   noExecName
  mov  es, [__psp]
  mov  es, es:[2CH]
  sub  di, di
  sub  ax, ax
  mov  cx, -1
execLoop:                              (* get address of command *)
  scasw
  je   execFound
  dec  di
  loop execLoop
(*%F NearPtr *)
execFound:
  add  di, 2
  mov  [__argv], di
  mov  [__argv][2], es
  jmp  argv1
noExecName:                            (* version 2 - argv[0]=NULL *)
  mov  word [__argv], 0
  mov  word [__argv][2], 0
argv1:
  mov  bx, 4                           (* move arguments to buffer  *)
  mov  es, [__psp]
  mov  di, 81H
  mov  si, __argbuf
  mov  cl, es:[di][-1]
  sub  ch, ch
argLoop:
  mov  al, ' '
repe ; scasb
  je   endofLine
  dec  di
  inc  cx
  mov  [__argv][bx], si
  mov  [__argv][bx][2], ds
  xchg di, si
  push es
  push ds
  pop  es
  pop  ds
  add  bx, 4
  mov  dl, ' '
  mov  dh, 0
moveLoop:
  lodsb
  cmp  al, dl
  jne  notSpace
  cmp  dh, 1
  jz   endString
endStringRet:
  sub  al, al
  stosb
  xchg di, si
  push es
  push ds
  pop  es
  pop  ds
  loop argLoop
  jmp  endofLine
notSpace:
  cmp  al, '"'
  je   startString
  stosb
startStringRet:
  loop moveLoop
  sub  al, al
  stosb
endofLine:
  shr  bx, 1
  shr  bx, 1
(*%E *)
(*%T NearPtr *)
execFound:
  mov  ax, es
  mov  ds, ax                       (* ds:si = name *)
(*%T _WINDOWS *)
  mov  ax, ss
(*%E *)
(*%F _WINDOWS *)
  mov  ax, _DATA
(*%E *)
  mov  es, ax
  add  di, 2
  mov  si, di
  mov  di, __argbuf                 (* es:di = buffer *)
  mov  es:[__argv], di
nLoop:
  lodsb
  stosb
  or   al, al
  jz   argv1
  jmp  nLoop
noExecName:                            (* version 2 - argv[0]=NULL *)
  mov  word [__argv], 0
argv1:
  mov  bx, 2                           (* move arguments to buffer  *)
(*%T _WINDOWS *)
  mov  ax, ss
(*%E *)
(*%F _WINDOWS *)
  mov  ax, _DATA
(*%E *)
  mov  ds, ax
  mov  es, [__psp]
  mov  si, di
  mov  di, 81H
  mov  cl, es:[di][-1]
  sub  ch, ch
argLoop:
  mov  al, ' '
repe ; scasb
  je   endofLine
  dec  di
  inc  cx
  mov  [__argv][bx], si
  xchg di, si
  push es
  push ds
  pop  es
  pop  ds
  add  bx, 2
  mov  dl, ' '
  mov  dh, 0
moveLoop:
  lodsb
  cmp  al, dl
  jne  notSpace
  cmp  dh, 1
  jz   endString
endStringRet:
  sub  al, al
  stosb
  xchg di, si
  push es
  push ds
  pop  es
  pop  ds
  loop argLoop
  jmp  endofLine
notSpace:
  cmp  al, '"'
  je   startString
  stosb
startStringRet:
  loop moveLoop
  sub  al, al
  stosb
endofLine:
  shr  bx, 1
(*%E *)
(*%T _WINDOWS *)
  mov  ax, ss
(*%E *)
(*%F _WINDOWS *)
  mov  ax, _DATA
(*%E *)
  mov  ds, ax
  mov  [__argc], bx
initDone:
  pop  ds
  pop  si
  pop  di
  ret  0

startString:
  mov  dh, 1
  mov  dl, '"'
  jmp  startStringRet

endString:
  mov  dh, 0
  mov  dl, ' '
  jmp  endStringRet
(*%E *)
(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _DATA

extrn __sigsetup
extrn __exitbreak
extrn __exitsig
extrn __exitgraph

select _TEXT

public __exit :

(*
void __exit(int code)

terminates process.
*)
code   = frame

    push bp
    mov  bp, sp
(*%T RegParam *)
    mov  di, ax
(*%E *)
(*%F SameDS *)
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
(*%F _WINDOWS *)
    mov  cx, [__exitbreak]
    jcxz noBreak
    call far [__exitbreak]
noBreak:
    mov  cx, [__exitsig]
    jcxz noSig
(*%F NearCall *)
    call far [__exitsig]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noSig:
    mov  cx, [__exitgraph]
    jcxz noGraph
(*%F NearCall *)
    call far [__exitgraph]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noGraph:
(*%E *)
extrn __FloatFinish
    call far __FloatFinish
(*%F RegParam *)
    mov  al, [bp][code]
(*%E *)
(*%T RegParam *)
    mov  ax, di
(*%E *)
(*%T _DLLOVL *)
    extrn Loader$Terminate
    call far Loader$Terminate
(*%E *)
    mov  ah, 4CH
    int  21H

db 'TopSpeed RTL (C) Clarion Software Corporation 1989-1992'

(****************************************************************************)
section
segment _DATA(DATA, 28H)
segment _TEXT(CODE,28H)

extrn __exit_proc
extrn __exitbreak
extrn __exitsig
extrn __exitgraph
extrn __FloatFinish

public __term_process :


(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    mov  cx, [__exit_proc]
    jcxz noCall4
(*%F SameDS *)
    push ds
(*%E *)
    call far [__exit_proc]
(*%F SameDS *)
    pop  ds
(*%E *)
noCall4:
    mov  cx, [__exitbreak]
    jcxz noBreak
    call far [__exitbreak]
noBreak:
    mov  cx, [__exitsig][2]
    jcxz noSig
(*%F NearCall *)
    call far [__exitsig]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noSig:
    mov  cx, [__exitgraph]
    jcxz noGraph
(*%F NearCall *)
    call far [__exitgraph]
(*%E *)
(*%T NearCall *)
    call cx
(*%E *)
noGraph:
    call far __FloatFinish
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(****************************************************************************)
section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _DATA

message : db 'Floating Point Not Loaded$'

select _TEXT


public __real_pdef :
public __real_sdef :

(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  dx, message
    mov  ah, 9
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
(*%F SameDS *)
    pop  ds
(*%E *)
    ret  0

(*%F _WINDOWS *)
