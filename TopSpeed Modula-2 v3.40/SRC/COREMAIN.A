extrn _x_bss_end
extrn _x_bss_start
extrn __bss_end
extrn __bss_start
extrn _x_main
extrn __main_args
extrn __FloatInit
extrn __SigInit
extrn __SSisDS
extrn __far_ss
extrn __stk_base
extrn __initx
extrn __x_near_stack_start
extrn __set_machine_id
extrn __InitSetup
extrn __InitLoop
extrn @ExitCode

select _TEXT                     (* Process initialisation starts here *)
                                 (* DON'T TOUCH *)
public __startup :
  mov  dx, ds                    (* save PSP *)
  cld                            (* cld is assumed everywhere *)
  mov  ax, BSS_START
  mov  es, ax
  mov  ax, _DATA
  mov  ds, ax
  mov  [__stklen], si
  mov  [__far_ss], ss
(*%F MThread *)
(*%F NearPtr *)
  mov  [__SSisDS], cl
(*%E *)
(*%E *)
(*%T NearPtr *)
  mov  byte [__SSisDS], 1        (* SS always == DS in this model *)
(*%E *)
(*%T MThread *)
  mov  byte [__SSisDS], 0        (* SS always != DS in this model *)
(*%E *)
(*%F _DLL *)
  mov  di, [_x_bss_start]        (* set near heap and _BSS bounds *)
  mov  cx, [_x_bss_end]
(*%E *)
(*%T _DLL *)
  mov  di, __bss_start           (* set near heap and _BSS bounds *)
  mov  cx, __bss_end
(*%E *)
  mov  si, cx                    (* clear _BSS segment *)
  sub  cx, di
  sub  ax, ax
  shr  cx, 1
  rep; stosw
  adc  cx, 0
  rep; stosb

  mov [__psp],dx                 (* save psp segment *)
  mov es, dx
  mov dx, es:[2CH]
  mov [__env], dx                (* save enviromment segment *)
(*%F NearPtr *)
  mov byte ss:[CurrentThread], 1
(*%E *)
  mov word ss:[InMathLib], 0

  cmp byte [__SSisDS], 1
  je  nearStack
  not word [__farstack]                (* far stack required, not much to do *)
  jmp stackSet
nearStack:
  mov bx, [__x_near_stack_start]
  mov [__stk_base], bx
  add bx, [__stklen]
  and bx, ~1
  sub bx, 2
  mov ax, _DATA               (* Near stack required, move it to DGROUP *)
  mov ss, ax
  mov sp, bx

stackSet:
  mov  ax, STACK_GUARD
  push ax
  sub  bp, bp
  push bp
  mov  bp, sp
  call far __FloatInit       (* initialise floating point if present *)
  call __osversion           (* get MSDOS version first *)
  call far __set_machine_id
  mov  word [__hugeshift], 1000H

  call __InitSetup

(* Program actually starts after library initialization is performed durring *)
(* the following call                                                        *)
(*%F NearCall *)
  call far __InitLoop        (* library module initialisation is called here *)
(*%E *)
(*%T NearCall *)
  call __InitLoop
(*%E *)

  call __cleanup
  mov  ax, [@ExitCode]
(*%F RegParam *)
  push ax
(*%E *)
(*%F NearCall *)
  call far __exit
(*%E *)
(*%T NearCall *)
  call __exit
(*%E *)
(* This call will not return *)
(*****************************)

public $Stage2 :

(*%F NearCall *)
  call far __SigInit
(*%E *)
(*%T NearCall *)
  call __SigInit             (* initialise interrupt vectors *)
(*%E *)
  add  word [__stk_base], 100H

(*%F _DLLOVL *)
  cmp  byte [__fmemsetup], 0
  jnz  dontFree              (* Far heap present memory init complete *)

  sub  dx, dx
  cmp  byte [__SSisDS], 1
  je   nearStackSet          (* free surplus memory if near heap and stack *)
  mov  dx, [__stklen]
  add  dx, 0FH
  jnc  sizeOK
  mov  dx, 1000H
  jmp  nearStackSet
sizeOK:
  mov  cl, 4
  shr  dx, cl
nearStackSet:
  mov  ax, [__psp]
  mov  es, ax
  mov  bx, [__far_ss]
  add  bx, dx
  mov  es:[2], bx
  sub  bx, ax
  mov  ah, 4AH
  int  21H

dontFree:
(*%E *)
(*%F _ENV *)
(*%T _DLLOVL *)
  mov  byte [__fmemsetup], 1 (* Far Heap Managed by Loader *)
(*%E *)
(*%E *)
  jmp  far [_x_initx]


section
segment _TEXT(CODE, 28H)

extrn _main
extrn _x_main

public __call_main :
(*%F NearCall *)
(*%T _DLLOVL *)
  push bp
  mov  bp,sp
(*%E *)
  call far [_x_main]             (* call main *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
  ret  far 0
(*%E *)
(*%T NearCall *)
  call [_x_main]
  ret  0
(*%E *)

(*%E *) (* NOT Windows *)

(*%T _WINDOWS *)
section

segment _TEXT(CODE,28H)
segment _INIT(INIT_CODE,28H)
segment BEGDATA(DATA,28H)
public __bdata_dummy : org 10
segment EMU_STATE(DATA,28H)
segment _CONST(DATA,28H)
segment _DATA(DATA,28H)
segment BSS_START(BSS,28H)
segment _BSS(BSS,28H)
segment BSS_END(BSS,28H)

group DGROUP(BEGDATA,EMU_STATE,_CONST,_DATA,BSS_START,_BSS,BSS_END)

extrn __psp
extrn __env
extrn __hugeshift
extrn __env_var
extrn __env_size
extrn __osmajor
extrn __argv
extrn __argc
extrn __argbuf
