extrn __SigInit
extrn __SSisDS
extrn __stk_base
extrn _x_initx
extrn __set_machine_id
extrn __InitLoop
extrn __InitSetup
extrn __ireg
extrn @ExitCode

select _DATA

dm :  dw 0

select _TEXT                     (* Process initialisation starts here *)
                                 (* DON'T TOUCH *)
public __startup :
  cld                            (* cld is assumed everywhere *)
(*%F _WINDLL *)
  mov  [__stk_base], cx          (* cx set by call to INITTASK *)
(*%E *)
  mov  cx, ds
  mov  es, cx
  mov  cx, [_x_bss_end]
(*%T _WINDLL *)
  mov  [__stk_base], cx
(*%E *)
  mov  di, [_x_bss_start]        (* set near heap and _BSS bounds *)
  mov  si, cx                    (* clear _BSS segment *)
  sub  cx, di
  sub  ax, ax
  rep; stosb                           (* cx = 0 *)

(*%F _WINDLL *)
  mov dx, [__ireg][PSPSeg]
  mov [__psp],dx                 (* save psp segment *)
  mov es, dx
  mov dx, es:[2CH]
  mov [__env], dx                (* save enviromment segment *)
(*%E *)
  mov  ax, STACK_GUARD                 (* set up stack *)
  push ax
  push cx
  mov  bp, sp

  call far __FloatInit       (* initialise floating point if present *)
  mov  word [__hugeshift], 1000H

  call __InitSetup
(*%F NearCall *)
  call far __InitLoop        (* lib module initialisation is called here *)
(*%E *)
(*%T NearCall *)
  call __InitLoop
(*%E *)

  call __cleanup
  mov  ax, [@ExitCode]
(*%T _WINDLL *)
  add  sp, 4
  ret  far 0
(*%E *)
(*%F RegParam *)
  push ax
(*%E *)
(*%F _WINDLL *)
(*%F NearCall *)
  call far __exit
(*%E *)
(*%T NearCall *)
  call __exit
(*%E *)
(*%E *)
(*%T _WINDLL *)
  ret  far 0
(*%E *)

(* This call will not return *)
(*****************************)

public $Stage2 :
(*%F NearCall *)
    inc  bp
    push bp
    mov  bp, sp
(*%E *)

    add  word [__stk_base], 100H
    jmp  far [_x_initx]

public __call_main :
(*%F NearCall *)
    call far [_x_main]                 (* call main *)
    pop  bp
    dec  bp
    ret  far 0
(*%E *)
(*%T NearCall *)
    call [_x_main]
    ret  0
(*%E *)

