section
(****************************************************************************)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)
segment _BSS(BSS, 28H)

select _BSS

InitLim = 32
buffer : org (DataPtrSize * InitLim) + 2

select _TEXT

extrn $initm

DummyProc:

(*%F near_init_code *)
    ret  far 0
(*%E *)
(*%T near_init_code *)
    ret  0
(*%E *)

public _InitModules :

(*%F _DLLOVL *)

    call Init
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

    call Init
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)
    call Init
(*%F NearCall *)
    ret  far 4
(*%E *)
(*%T NearCall *)
    ret  4
(*%E *)
    call Init
(*%F NearCall *)
    ret  far 6
(*%E *)
(*%T NearCall *)
    ret  6
(*%E *)
    call Init
(*%F NearCall *)
    ret  far 8
(*%E *)
(*%T NearCall *)
    ret  8
(*%E *)
    call Init
(*%F NearCall *)
    ret  far 0AH
(*%E *)
(*%T NearCall *)
    ret  0AH
(*%E *)
arg1     = frame+2
(*%E *)

(*%T _DLLOVL *)
arg1     = frame
(*%E *)

base     = -2
StackPos = -4
locals   =  4

Init:
    push bp
    mov  bp, sp
    sub  sp, locals
(*%T RegParam *)
    push ax
    push bx
    push cx
    push dx
(*%E *)
    push di
    push si
    push ds
(*%F SameDS *)
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  di, buffer
    push ds
    mov  ax, ds
    mov  es, ax
    mov  ax, DummyProc
    stosw
(*%F near_init_code *)
    mov  ax, cs
    stosw
(*%E *)
    lea  si, [bp][arg1]
    mov  cx, ss
    mov  ds, cx
    mov  cx, InitLim
storeLoop:
    lodsw
(*%T near_init_data *)
    or   ax, ax
(*%E *)
(*%F near_init_data *)
    mov  bx, ax
    or   bx, ds:[si]
(*%E *)
    jz   terminator
    stosw
(*%F NearPtr *)
(*%F near_init_data *)
    movsw
(*%E *)
(*%T near_init_data *)
    add  si, 2
(*%E *)
(*%E *)
    loop  storeLoop
terminator:
    mov  ax, -1
    stosw
    pop  ds
    extrn _x_main
    mov  word [_x_main], buffer
(*%F near_init_data *)
    mov  [_x_main][2], es
(*%E *)
    push bp
(*%T _DLLOVL *)
    mov  bp,sp
    call far $initm
(*%E *)
(*%F _DLLOVL *)
 (*%F near_init_code *)
    push cs
 (*%E *)
    call $initm
(*%E *)
    pop  bp

noArgs:
    pop  ds
    pop  si
    pop  di
(*%T RegParam *)
    pop  dx
    pop  cx
    pop  bx
    pop  ax
(*%E *)
    mov  sp, bp
    pop  bp
(*%F _DLLOVL *)
    ret  0
(*%E *)
(*%T _DLLOVL *)
    ret  far 0
(*%E *)

(***************************************************************************)
section;
segment PROC_TEXT(CODE,28H)

extrn @MachineId

public __set_machine_id :

  mov ax, 0F000H
  mov es, ax
  mov al, es:[0FFFEH]
  mov cs:[@MachineId], al
  ret far 0

