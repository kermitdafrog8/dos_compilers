section
(***************************************************************************)
segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

extrn __ioerr

(*%F _XTD *)
public __close :
(*%E *)
public __dos_close :

(* int _close(int handle)
     closes file and returns 0 if succeessful. Low level DOS function. *)

(*%F RegParam *)
handle   = frame

    push bp
    mov  bp, sp
    push bx
    mov  ah, 3EH
    mov  bx, [bp][handle]
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  closeOK
(*%F NearCall *)
    call far __ioerr                            (* set errno *)
(*%E *)
(*%T NearCall *)
    call __ioerr                            (* set errno *)
(*%E *)
    mov  ax, -1                               (* return -1 *)
    jmp  closeDone
closeOK:
    mov  ax, 0                                (* return 0 *)
closeDone:
    pop  bx
    pop  bp
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E RegParam *)

(*%T RegParam *)
(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push bx
    mov  bx, ax
    mov  ah, 3EH
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  closeOK
(*%F NearCall *)
    call far __ioerr                            (* set errno *)
(*%E *)
(*%T NearCall *)
    call __ioerr                            (* set errno *)
(*%E *)
    mov  ax, -1                             (* return -1 *)
    jmp  closeDone
closeOK:
    sub  ax, ax                             (* return 0 *)
closeDone:
    pop  bx
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E RegParam *)

(*%E _XTDDOS *)

end
