section
(****************************************************************************)
segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

(* External data *)

extrn __ioerr

public __open :

(* int _open(char *path, int access)
     opens file and returns handle. *)

(*%F RegParam *)
path   = frame
(*%F NearPtr *)
access = 4+frame
(*%E *)
(*%T NearPtr *)
access = 2+frame
(*%E *)

    push bp
    mov  bp, sp
    push dx
(*%F NearPtr *)
    push ds
(*%E *)
    mov  ah, 3DH
    mov  al, [bp][access]
(*%F NearPtr *)
    lds  dx, [bp][path]
(*%E *)
(*%T NearPtr *)
    mov  dx, [bp][path]
(*%E *)
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  openOK
(*%F NearCall *)
    call far __ioerr                             (* set errno *)
(*%E *)
(*%T NearCall *)
    call __ioerr                             (* set errno *)
(*%E *)
    mov  ax, -1                              (* return -1 *)
openOK:
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  dx
    pop  bp                                  (* handle already in ax *)
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E RegParam *)

(*%T RegParam *)
(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push dx
(*%F NearPtr *)
    push ds
(*%E *)
(*%F NearPtr *)
    mov  ds, bx
(*%E *)
    mov  dx, ax
(*%F NearPtr *)
    mov  al, cl
(*%E *)
(*%T NearPtr *)
    mov  al, bl
(*%E *)
    mov  ah, 3DH
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  openOK
(*%F NearCall *)
    call far __ioerr                             (* set errno *)
(*%E *)
(*%T NearCall *)
    call __ioerr                             (* set errno *)
(*%E *)
    mov  ax, -1                              (* return -1 *)
openOK:
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  dx
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E RegParam *)


section
(*************************************************************************)
segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

(* External data *)

extrn __ioerr

public __dos_read :

(*%F RegParam *)
RetSize = 0
(*%E *)
(*%T RegParam *)
(*%T NearPtr *)
RetSize = 2
(*%E *)
(*%F NearPtr *)
RetSize = 4
(*%E *)
(*%E *)

(*%F RegParam *)
handle  = frame
buffer  = 2+frame
num     = 6+frame
numread = 8+frame
(*%E *)
(*%T RegParam *)
numread = frame
(*%E *)
    push bp
    mov  bp, sp
    push ds
(*%T RegParam *)
    mov  ds, cx
    mov  cx, dx
    mov  dx, bx
    mov  bx, ax
(*%E *)
(*%F RegParam *)
    mov  bx, [bp][handle]
    mov  cx, [bp][num]
    lds  dx, [bp][buffer]
(*%E *)
    mov  ah, 3FH
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  readOK
(*%F NearCall *)
    call far __ioerr                            (* set errno *)
(*%E *)
(*%T NearCall *)
    call __ioerr                            (* set errno *)
(*%E *)
    jmp  Exit
readOK:
(*%F NearPtr *)
    lds  bx, [bp][numread]
(*%E *)
(*%T NearPtr *)
    mov  bx, [bp][numread]
    mov  cx, _DATA
    mov  ds, cx
(*%E *)
    mov  [bx], ax
    sub  ax, ax
Exit:
    pop  ds
    pop  bp                                 (* number already in ax *)
(*%F NearCall *)
    ret  far RetSize
(*%E *)
(*%T NearCall *)
    ret RetSize
(*%E *)


