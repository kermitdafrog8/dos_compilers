section
(* ------------------------------------------------------------------------
   PROCEDURE - highvideo.

   PRECONDITIONS - None.

   POSTCONDITIONS - High intensity attribute bit set.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __attrib

select _TEXT

public  _highvideo :                  (* set high intensity bit *)


(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%F SameDS *)
    push ax
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    or   byte [__attrib], 8
(*%F SameDS *)
    pop  ds
    pop  ax
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - lowvideo.

   PRECONDITIONS - None.

   POSTCONDITIONS - High intensity attribute bit cleared.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __attrib

select _TEXT

public  _lowvideo :                   (* clear high intensity bit *)


(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%F SameDS *)
    push ax
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    and  byte [__attrib], 247
(*%F SameDS *)
    pop  ds
    pop  ax
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - normvideo.

   PRECONDITIONS - None.

   POSTCONDITIONS - High intensity attribute bit set to original state.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __attrib
extrn __startattrib

select _TEXT

public  _normvideo :                    (* restore original attribute *)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%F SameDS *)
    push ax
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  al, [__startattrib]
    mov  [__attrib], al
(*%F SameDS *)
    pop  ds
    pop  ax
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - textcolor.

   PRECONDITIONS - None.

   POSTCONDITIONS - Text foreground color attribute bit set.

   IN PARAMETERS -  New color (int).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __attrib
extrn __startattrib

select _TEXT

public _textcolor :

colour = frame

    push bp
    mov  bp, sp
(*%F SameDS *)
    push bx
    push ds
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
(*%F RegParam *)
    mov  al, [bp][colour]
(*%E *)
    and  al, 08FH
    and  byte [__attrib], 070H
    or   [__attrib], al
(*%F SameDS *)
    pop  ds
    pop  bx
(*%E *)
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - textbackground.

   PRECONDITIONS - None.

   POSTCONDITIONS - Text background color attribute bit set.

   IN PARAMETERS -  New color (int).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __attrib
extrn __startattrib

select _TEXT

public  _textbackground :

colour = frame                           (* set background colour *)

    push bp
    mov  bp, sp
    push cx
(*%F SameDS *)
    push bx
    push ds
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
(*%F RegParam *)
    mov  ax, [bp][colour]
(*%E *)
    and  al, 7
    mov  cl, 4
    shl  ax, cl
    and  byte [__attrib], 0FH
    or   [__attrib], al
(*%F SameDS *)
    pop  ds
    pop  bx
(*%E *)
    pop  cx
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
