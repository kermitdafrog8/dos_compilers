(*%F RegParam *)
    push ax
(*%E *)
(*%F SameDS *)
    push bx
    push ds
    mov  bx, _DATA
    mov  ds, bx
(*%E *)
(*%F RegParam *)
    mov  ax, [bp][attribute]
(*%E *)
    mov  [__attrib], al
(*%F SameDS *)
    pop  ds
    pop  bx
(*%E *)
(*%F RegParam *)
    pop  ax
(*%E *)
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
