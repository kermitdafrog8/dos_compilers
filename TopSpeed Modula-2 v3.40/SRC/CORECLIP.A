include "corelib.inc"

module Borw

(* Common Procedures *)
(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - _incxy.

   PRECONDITIONS - None.

   POSTCONDITIONS - Cursor position advanced.

   IN PARAMETERS -  row (CHAR), column (CHAR) in DH:DL.

   OUT PARAMETERS - returns new values DH:DL.

   CALLING CONVENTION - Near Call.

   NOTES -  Internal.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __setxy
extrn __scroll
extrn __right
extrn __top
extrn __bottom
extrn __left
extrn __wscroll

select _TEXT

public  __incxy :                   (* internal to conio *)

(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    inc  dl
    cmp  dl, [__right]
    jbe  xOK
    cmp  dh, [__bottom]
    jae  scrollUp
    mov  dl, [__left]
    inc  dh
xOK:
    call __setxy
(*%F SameDS *)
    pop  ds
(*%E *)
    ret   0
scrollUp:
    cmp  word [__wscroll], 0
    je   xOK
    push dx
    mov  ax, 601H
    mov  ch, [__top]
    mov  cl, [__left]
    mov  dh, [__bottom]
    mov  dl, [__right]
    call __scroll
    pop  dx
    mov  dl, [__left]
    jmp  xOK

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - _decxy.

   PRECONDITIONS - None.

   POSTCONDITIONS - Cursor position decremented.

   IN PARAMETERS -  row (CHAR), column (CHAR) in DH:DL.

   OUT PARAMETERS - returns new values DH:DL.

   CALLING CONVENTION - Near Call.

   NOTES -  Internal.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __setxy
extrn __scroll

select _DATA

extrn __right
extrn __top
extrn __bottom
extrn __left

select _TEXT

public  __decxy :                   (* internal to conio *)

(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    dec  dl
    cmp  dl, [__left]
    jae  xOK
    cmp  dh, [__top]
    jbe  screenBegin
    mov  dl, [__right]
    dec  dh
xOK:
    call __setxy
(*%F SameDS *)
    pop  ds
(*%E *)
    ret   0
screenBegin:
    mov  dh, [__top]
    mov  dl, [__left]
    jmp  xOK

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - clreol.

   PRECONDITIONS - None.

   POSTCONDITIONS - Screen cleared from cursor to end of line.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __getxy
extrn __attrib
extrn __right

select _TEXT

public  _clreol :                   (* clear screen from cursor to eol *)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push ax
    push bx
    push cx
    push dx
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    call __getxy
    mov  ax, 6FFH
    mov  cx, dx
    mov  dl, [__right]              (* calculate end of line *)
    call __scroll                   (* use scroll to clear screen *)
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  dx
    pop  cx
    pop  bx
    pop  ax
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - clrscr.

   PRECONDITIONS - None.

   POSTCONDITIONS - Screen cleared and cursor home.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __setxy
extrn __attrib
extrn __top
extrn __left
extrn __bottom
extrn __right

select _TEXT

public  _clrscr :                  (* clear screen and home cursor *)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push ax
    push bx
    push cx
    push dx
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  ax, 06FFH
    mov  ch, [__top]
    mov  cl, [__left]
    mov  dl, [__right]
    mov  dh, [__bottom]
    call __scroll
    mov  dh, [__top]
    mov  dl, [__left]
    call __setxy
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  dx
    pop  cx
    pop  bx
    pop  ax
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
