(*%E *)
    push ax
    push bx
    push cx
    push dx
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    call __getxy
    mov  ch, dh
    mov  cl, [__left]
    mov  dh, [__bottom]
    mov  dl, [__right]
    mov  ax, 701H
    call __scroll
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  dx
    pop  cx
    pop  bx
    pop  ax
(*%T _DLLOVL *)
