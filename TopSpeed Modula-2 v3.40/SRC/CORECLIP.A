   PROCEDURE - delline.

   PRECONDITIONS - None.

   POSTCONDITIONS - Current line deleted and screen scrolled up.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __scroll
extrn __getxy
extrn __top
extrn __left
extrn __bottom
extrn __right

select _TEXT

public  _delline :               (* delete current line *)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push ax
    push bx
    push cx
    push dx
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    call __getxy
    mov  ch, dh
    mov  cl, [__left]
    mov  dh, [__bottom]
    mov  dl, [__right]
    mov  ax, 601H
    call __scroll
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  dx
    pop  cx
    pop  bx
    pop  ax
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(* __delline ENDP *)

(****************************************************************************)
section
