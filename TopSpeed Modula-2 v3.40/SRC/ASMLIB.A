section
(* ------------------------------------------------------------------------
   PROCEDURE - WinStr.CharPos.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  source (ARRAY OF CHAR), ch (CHAR).

   OUT PARAMETERS - returns offset of ch in source CARDINAL),
                    MAX(CARDINAL) if not found.

   CALLING CONVENTION - Standard + Far Pointers.

   NOTES -  None.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)

public WinStr$CharPos :

(*%T RegParam *)

RetSize = 0

    push di
    mov  es, cx
    mov  di, bx
    mov  cx, ax
    mov  ax, dx
    mov  dx, cx
    push ax
    sub  al, al
repne ; scasb
    jne  lCalc
    inc  cx
lCalc:
    sub  dx, cx
    xchg dx, cx
    mov  di, bx
    pop  ax
repne; scasb
    jnz   notFound
    dec  di
    sub  di, bx
    mov  ax, di
chrDone:
    pop  di
(*%T _fcall *)
    ret far RetSize
(*%E *)
(*%F _fcall *)
    ret  RetSize
(*%E *)
notFound:
    mov  ax, -1
    jmp  chrDone
(*%E *)

(*%F RegParam *)
slen = 6+frame
s    = 2+frame
chk  = frame
RetSize = 8

    push bp
    mov  bp, sp
    push di
    les  di, [bp][s]
    mov  cx, [bp][slen]
    mov  dx, [bp][slen]
    sub  al, al
repne ; scasb
    jne lCalc
    inc  cx
lCalc:
    sub  dx, cx
    xchg dx, cx
    mov  di, [bp][s]
    mov  al, [bp][chk]
repne; scasb
    jnz   notFound
    dec  di
    sub  di, [bp][s]
    mov  ax, di
chrDone:
    pop  di
    pop  bp
(*%T _fcall *)
    ret far RetSize
(*%E *)
(*%F _fcall *)
    ret  RetSize
(*%E *)
notFound:
    mov  ax, -1
    jmp  chrDone
(*%E *)

