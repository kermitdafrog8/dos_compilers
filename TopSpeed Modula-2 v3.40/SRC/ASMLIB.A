section
(* ------------------------------------------------------------------------
   PROCEDURE - Str.Caps.

   PRECONDITIONS - None.

   POSTCONDITIONS - String characters set to upper case.

   IN PARAMETERS -  string (VAR ARRAY OF CHAR).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment STR_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment STRDLL_TEXT(CODE,28H)
(*%E *)
(*%F RegParam *)

(*%F NearPtr *)
Slen = 4+frame
Sseg = 2+frame
Sofs = frame

RetSize = 6
(*%E *)
(*%T NearPtr *)
Slen = 2+frame
Sofs = frame

RetSize = 4
(*%E *)
(*%E *)
(*%T RegParam *)
RetSize = 0
(*%E *)
public Str$Caps :

(*%F RegParam *)
  push bp
  mov  bp,sp
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
(*%T NearPtr *)
  push cx
(*%E *)
(*%E *)
  push ds
  push si
(*%F RegParam *)
(*%F NearPtr *)
  lds  si, [bp][Sofs]
(*%E *)
(*%T NearPtr *)
  mov  si, [bp][Sofs]
(*%E *)
  mov cx,[bp][Slen]
(*%E *)
(*%T RegParam *)
(*%F NearPtr *)
  mov  ds, cx
(*%E *)
  mov  cx, ax
  mov  si, bx
(*%E *)
$loop:
  lodsb
  cmp al,97 (* 'a' *)
  jb $notSmall
  cmp al,122 (* 'z' *)
  ja $notSmall
  sub al,32
  mov [si][-1],al
  loop $loop
  jmp  $$Done
$notSmall:
  or al,al
  loopnz $loop
$$Done:
  pop si
  pop ds
(*%T RegParam *)
(*%T NearPtr *)
  pop  cx
(*%E *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%E *)
(*%F RegParam *)
  pop bp
(*%E *)
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

