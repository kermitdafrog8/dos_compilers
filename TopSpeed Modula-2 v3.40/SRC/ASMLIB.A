(*%E *)
(*%T NearPtr *)
  mov [bp][Slen], ax
  mov [bp][Sofs], bx
  mov [bp][Plen], cx
  mov [bp][Pofs], dx
(*%E *)
(*%E *)
  push ds
  push si
  push di
(*%F NearPtr *)
  les di,[bp][Sofs]
(*%E *)
(*%T NearPtr *)
  mov di,[bp][Sofs]
  push ds
  pop  es
(*%E *)
  mov cx,[bp][Slen]
  mov bx,cx
  sub al,al
  repne
  scasb
  jne LengthCalc1
  inc cx
LengthCalc1:
  sub bx,cx
(*%F NearPtr *)
  les di,[bp][Pofs]
(*%E *)
(*%T NearPtr *)
  mov di,[bp][Pofs]
  push ds
  pop  es
(*%E *)
  mov cx,[bp][Plen]
  mov dx,cx
  sub al,al
  repne
  scasb
  jne LengthCalc2
  inc cx
LengthCalc2:
  sub dx,cx
  sub bx,dx
  jb NotFound
(*%F NearPtr *)
  mov ds,[bp][Sseg]
(*%E *)
  sub ax,ax
SearchLoop:
  mov si,[bp][Sofs]
  add si,ax
  mov di,[bp][Pofs]
  mov cx,dx
  repe
  cmpsb
  je Found
  inc ax
  cmp ax,bx
  jbe SearchLoop
NotFound:
  mov ax,0FFFFH
Found:
Exit:
  pop di
  pop si
  pop ds
(*%T RegParam *)
  mov  sp, bp
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

