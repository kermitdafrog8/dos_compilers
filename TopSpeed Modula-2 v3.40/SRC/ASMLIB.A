(* PROCEDURE Move(Source,Dest:ADDRESS;Count:CARDINAL); *)
(* Source:4 | Dest:4 | Count:2 *)

(*%F NearPtr *)
public Lib$Move :
(*%E *)
public Lib$FarMove :
  Count  = frame
(*%T RegParam *)
  Return = 2
(*%E *)
(*%F RegParam *)
  Dest   = frame + 2
  Source = frame + 6
  Return = 10
(*%E *)

  push bp
  mov  bp, sp
  push ds
(*%F RegParam *)
  push ax
  push bx
  push cx
  push dx
(*%E *)
  push si
  push di
(*%T RegParam *)
  mov  si, ax
  mov  ds, bx
  mov  di, cx
  mov  es, dx
(*%E *)
(*%F RegParam *)
  lds  si, [bp][Source]
  les  di, [bp][Dest]
(*%E *)
(*%F ProtMode*)
  mov  ax, ds                          (* Normalize Source Pointer *)
  mov  dx, 16
  mul  dx
  add  ax, si
  adc  dx, 0
  mov  bx, ax                          (* Save Source Low in  bx *)
  mov  cx, dx                          (* Save Source High in cx *)
  mov  ax, es                          (* Normalize Destination Pointer *)
  mov  dx, 16
  mul  dx
  add  ax, di
  adc  dx, 0
  cmp  dx, cx                          (* Choose Move Direction *)
  ja   @MoveUp
  jb   @MoveDown
  cmp  ax, bx                          (* IF same segment, check offsets *)
  jb   @MoveDown
  je   @MoveExit
(*%E*)
(*%T ProtMode*)
  cmp si,di
  ja   @MoveDown
(*%E*)
@MoveUp:
  mov  cx, [bp][Count]
  jcxz @MoveExit
  std
  mov  bx, 1
  add  si, cx
  dec  si
  add  di, cx
  dec  di
  jmp  @MoveStart
@MoveDown:
  mov  cx, [bp][Count]
  jcxz @MoveExit
  xor  bx, bx
@MoveStart:
  test di, 1
  jz   @MoveEven
  movsb
  dec  cx
@MoveEven:
  sub  si, bx
  sub  di, bx
  shr  cx, 1
  rep; movsw
  jnc  @MoveExit
  add  si, bx
  add  di, bx
  movsb
@MoveExit:
  cld
  pop  di
  pop  si
(*%F RegParam *)
  pop  dx
  pop  cx
  pop  bx
  pop  ax
(*%E *)
  pop  ds
  pop  bp
(*%T NearCall *)
  ret  Return
(*%E *)
(*%F NearCall *)
  ret  far Return
(*%E *)

