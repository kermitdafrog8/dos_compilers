  mov  ax, [bp][Shift]
  cmp  ax, [bp][Slen]
  jae  NotFound
  add  [bp][Sofs], ax
(*%F NearPtr *)
  les di,[bp][Sofs]
(*%E *)
(*%T NearPtr *)
  mov di,[bp][Sofs]
  push ds
  pop  es
(*%E *)
  mov cx,[bp][Slen]
  mov bx,cx
  sub al,al
  repne
  scasb
  jne LengthCalc1
  inc cx
LengthCalc1:
  sub bx,cx
(*%F NearPtr *)
  les di,[bp][Pofs]
(*%E *)
(*%T NearPtr *)
  mov di,[bp][Pofs]
  push ds
  pop  es
(*%E *)
  mov cx,[bp][Plen]
  mov dx,cx
  sub al,al
  repne
  scasb
  jne LengthCalc2
  inc cx
LengthCalc2:
  sub dx,cx
  sub bx,dx
  jb NotFound
(*%F NearPtr *)
  mov ds,[bp][Sseg]
(*%E *)
  sub ax,ax
SearchLoop:
  mov si,[bp][Sofs]
  add si,ax
  mov di,[bp][Pofs]
  mov cx,dx
  repe
  cmpsb
  je Found
  inc ax
  cmp ax,bx
  jbe SearchLoop
NotFound:
  mov ax,0FFFFH
  jmp  Exit
Found:
  add  ax, [bp][Shift]
Exit:
  pop di
  pop si
  pop ds
(*%T RegParam *)
  mov  sp, bp
(*%E *)
