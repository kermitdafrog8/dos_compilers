(* ------------------------------------------------------------------------
   PROCEDURE - Str.CharPos.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  source (ARRAY OF CHAR), ch (CHAR).

   OUT PARAMETERS - returns offset of ch in source CARDINAL),
                    MAX(CARDINAL) if not found.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment STR_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment STRDLL_TEXT(CODE,28H)
(*%E *)
public Str$CharPos :

(*%T RegParam *)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%T NearPtr *)
    push dx
(*%E *)
    push di
(*%F NearPtr *)
    mov  es, cx
    mov  di, bx
    mov  cx, ax
    mov  ax, dx
    mov  dx, cx
(*%E *)
(*%T NearPtr *)
    mov  di, bx
    mov  dx, ax
    mov  ax, cx
    mov  cx, dx
    push ds
    pop  es
(*%E *)
    push ax
    sub  al, al
repne ; scasb
    jne  lCalc
    inc  cx
lCalc:
    sub  dx, cx
    xchg dx, cx
    mov  di, bx
    pop  ax
repne; scasb
    jnz   notFound
    dec  di
    sub  di, bx
    mov  ax, di
chrDone:
    pop  di
(*%T NearPtr *)
    pop  dx
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far   0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
notFound:
    mov  ax, -1
    jmp  chrDone
(*%E *)

(*%F RegParam *)
(*%T NearPtr *)
slen = 4+frame
s    = 2+frame
chk  = frame
RetSize = 6
(*%E *)
(*%F NearPtr *)
slen = 6+frame
s    = 2+frame
chk  = frame
RetSize = 8
(*%E *)

    push bp
