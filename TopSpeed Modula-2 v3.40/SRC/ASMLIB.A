(*%E *)

extrn @NormPtr

public Lib$AddFarAddr :

(*%F RegParam *)
a_H   = 4+frame
a_L   = 2+frame
c_val = frame

  push bp; mov bp,sp
  mov ax,[bp][a_L]
  mov dx,[bp][a_H]
  add ax,[bp][c_val]
  jnc $NoOverflow
  add dx,1000H
$NoOverflow:
  call near @NormPtr
  pop bp;
(*%F NearCall *)
  ret far 6
(*%E *)
(*%T NearCall *)
  ret 6
(*%E *)
(*%E *)

(*%T RegParam *)

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  mov dx,bx
  add ax,cx
  jnc $NoOverflow
