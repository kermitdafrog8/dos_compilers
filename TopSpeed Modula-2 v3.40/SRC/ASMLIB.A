  mov dx,[bp][S2len]
(*%E *)
(*%T RegParam *)
  mov  si, bx
  mov  ds, cx
  les  di,[bp][S2ofs]
  mov  bx, ax
(*%E *)
  mov cx,bx
  cmp cx,dx
  jb CompareLoop
  mov cx,dx
CompareLoop:
  lodsb
  scasb
  jne NotEqual
  or al,al
  loopne CompareLoop
  je Equal
  cmp bx,dx
  je Equal
  ja CheckSi
  cmp byte es:[di],0
  je Equal
Less:
  mov ax,-1
  jmp Return
CheckSi:
  cmp byte [si],0
  je Equal
Greater:
  mov ax,1
  jmp Return
NotEqual:
  cmp al,es:[di][-1]
  jb Less
  jmp Greater
Equal:
  sub ax,ax
Return:
  pop di
  pop si
  pop ds
  pop bp
(*%T _fcall *)
    ret far RetSize
(*%E *)
(*%F _fcall *)
    ret  RetSize
