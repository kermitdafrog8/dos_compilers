(*%E *)
  push di
  push si
(*%F NearPtr *)
  mov  si, cx
  mov  es, bx
  mov  di, ax
  mov  ax, dx
(*%E *)
(*%T NearPtr *)
  mov  si, bx
  mov  di, ax
  mov  ax, cx
  mov  cx, bx
  push ds
  pop  es
(*%E *)
  jcxz ExitScan
  repe
  scasb
  je ExitScan
  inc cx
ExitScan:
  mov ax, si
  sub ax, cx
  pop  si
  pop  di
(*%T _DLLOVL *)
