  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

(***************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - MATHLIB.StoreEnvironment.

   PRECONDITIONS - None.

   POSTCONDITIONS - 087 state stored in buffer record.

   IN PARAMETERS -  buffer (VAR Environment).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment MATHLIB_TEXT(CODE,28H)
(*%E *)

public  MATHLIB$StoreEnvironment :


_res = frame

(*%T RegParam *)
  retSize = 0
(*%E *)

(*%F RegParam *)
(*%F NearPtr *)
  retSize = 4
(*%E *)
(*%T NearPtr *)
  retSize = 2
(*%E *)
(*%E *)

(*%T RegParam *)
(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
(*%F NearPtr *)
  mov  dx, ds
  mov  ds, bx
(*%E *)
  mov  bx, ax
  fstenv  [bx]
  fwait
(*%F NearPtr *)
  mov  ds, dx
(*%E *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%E *)

(*%F RegParam *)
  push bp
  mov  bp, sp
(*%F NearPtr *)
  mov  dx, ds
  lds  bx, [bp][_res]
(*%E *)
(*%T NearPtr *)
  mov  bx, [bp][_res]
(*%E *)
  fstenv  [bx]
  fwait
(*%F NearPtr *)
  mov  ds, dx
(*%E *)
  pop  bp
(*%E *)

(*%F NearCall *)
  ret far retSize
(*%E *)
(*%T NearCall *)
  ret retSize
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.LongJmp.

   PRECONDITIONS - Label initialised by call to SetJmp.

   POSTCONDITIONS - Program execution continues after call to SetJmp.

   IN PARAMETERS -  label (VAR LongLabel).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn _longjmp2
extrn __setjmp2

public Lib$LongJmp :

task_state = 2+frame
val        = frame

  push bp
  mov  bp, sp

(*%F RegParam *)
  mov  ax, [bp][val]
  mov  cx, [bp][task_state]
(*%F NearPtr *)
  mov  dx, [bp][task_state][2]
  mov  [bp][frame][0], cx
  mov  [bp][frame][2], dx
  mov  [bp][frame][4], ax
(*%E *)
(*%T NearPtr *)
  mov  [bp][frame][0], cx
  mov  [bp][frame][2], ax
(*%E *)
(*%E *)

  jmp  far _longjmp2

(* ------------------------------------------------------------------------
   PROCEDURE - Lib.SetJmp.

   PRECONDITIONS - None.

   POSTCONDITIONS - label initialized for subsequent non-local goto.

   IN PARAMETERS -  label (VAR LongLabel).

   OUT PARAMETERS - code (CARDINAL).

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)

public Lib$SetJmp :

  push bp
  mov  bp, sp
  jmp  far __setjmp2


(*****************************************************************************)


(*%F _OS2 *)  (* MSDOS Specific Procedures *)
(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.InternalDelay.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  microseconds delay (CARDINAL).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Suspend execution of process. Internal library function called
            by Lib.Delay.

   VERSION - MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn _delay

msecs = frame
public Lib$InternalDelay :

(*%F RegParam *)
  push bp
  mov  bp, sp
  push [bp][msecs]
(*%F NearCall *)
  call far _delay
(*%E *)
(*%T NearCall *)
  call _delay
(*%E *)
  add  sp, 2
  pop  bp
(*%F NearCall *)
  ret  far 2
(*%E *)
(*%T NearCall *)
  ret  2
(*%E *)
(*%E *)

(*%T RegParam *)
(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
(*%F NearCall *)
  call far _delay
(*%E *)
(*%T NearCall *)
  call _delay
(*%E *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret  far 0
(*%E *)
(*%T NearCall *)
  ret  0
(*%E *)
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.InternalEnableBreakCheck.

   PRECONDITIONS - None.

   POSTCONDITIONS - Ctl C/Break checking enabled.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Internal procedure, calls procedure in CoreSig.

   VERSION - MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn @SetBreakInterrupt
public Lib$InternalEnableBreakCheck :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  call far @SetBreakInterrupt
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.InternalDisableBreakCheck.

   PRECONDITIONS - None.

   POSTCONDITIONS - Ctl C/Break checking disabled.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Internal procedure, calls procedure in CoreSig.

   VERSION - MSDOS.

   ------------------------------------------------------------------------ *)
(*%F SameDS *)
segment SIG_TEXT(CODE,28H)
(*%E *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)

extrn @ResetBreakInterrupt
public Lib$InternalDisableBreakCheck :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push ax
  push ds
  call far @ResetBreakInterrupt
  sub ax,ax
  mov ds,ax
  pushf
  cli
  mov word ds:[23H*4], DummyBreak
  mov word ds:[23H*4][2],cs
  popf
  pop ds
  pop ax
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

DummyBreak :
  iret

section
(*****************************************************************************)
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.DosExec.

   PRECONDITIONS - Memory space allocated.

   POSTCONDITIONS - Process executed.

   IN PARAMETERS -  Name (ARRAY OF CHAR), param block (FarADDRESS).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Far Call, Reg params off.

   NOTES -  Called by Lib.Execute.

   VERSION - MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

SaveSS : dw 0
SaveSP : dw 0

public Lib$DosExec :
(*%F NearPtr *)
NameLen=14; NameSeg=12; NameOfs=10; ParamSeg=8; ParamOfs=6
RetSize = 10
(*%E *)
(*%T NearPtr *)
NameLen=12; NameOfs=10; ParamSeg=8; ParamOfs=6
RetSize = 8
(*%E *)


  push bp; mov bp,sp
  push ds; push es; push si; push di

  pushf
  mov ax,4B00H
(*%F NearPtr *)
  mov ds,[bp][NameSeg]
(*%E *)
  mov dx,[bp][NameOfs]
  mov es,[bp][ParamSeg]
  mov bx,[bp][ParamOfs]
  push bp
  push ss:[2EH]            (* where DOS doth tread *)
  push ss:[30H]
  push cs:[SaveSS]                (* to restore code seg *)
  push cs:[SaveSP]
  mov cs:[SaveSS],ss
  mov cs:[SaveSP],sp
  int 21H
  mov ss,cs:[SaveSS]
  mov sp,cs:[SaveSP]
  pop cs:[SaveSP]
  pop cs:[SaveSS]
  pop ss:[30H]
  pop ss:[2EH]
  pop bp
  jc ExitExec
  sub ax,ax
ExitExec:
  popf
  pop di; pop si; pop es; pop ds
  pop bp; ret far RetSize

(*****************************************************************************)
(*%F _WINDOWS *)
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.CpuId.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  Record (VAR CpuRec).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Determines types processor and co-processor.

   VERSION - MSDOS (Not windows).

   ------------------------------------------------------------------------ *)
section
segment _DATA(DATA,28H)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

ndp_cw:   dw	0
ndp_stat: dw      0	
temp87:   dw 0
CpuXlat:  db 1,2,0,0,0,0,0,7,3,4,5,6,0,0,0,7,8


public Lib$CpuId:
(*%F RegParam *)
cpurec = frame
ndp_save = -100
locals = 100
(*%F NearPtr *)
RetSize = 4
(*%E *)
(*%T NearPtr *)
RetSize = 2
(*%E *)
(*%E *)

(*%T RegParam *)
cpurec   = -4
ndp_save = -104
locals = 104
RetSize = 0
(*%E *)

        push bp
        mov bp,sp
        sub sp, locals
(*%T RegParam *)
        mov  [bp][cpurec], ax
(*%F NearPtr *)
        mov  [bp][cpurec][2], bx
(*%E *)
(*%T NearPtr *)
        push bx
(*%E *)
        push cx
        push dx
(*%E *)
        push ds
        push es
        push si
        push di
        push cs
        pop ds
foption 0
        fsave [bp][ndp_save]
        fwait
	xor	dx,dx
        sub     si,si
        mov es,si
	mov	cx,0FFFFH
	sti
	db 0F3H                     (* rep *)
	db 026H                     (* es: *)
	lodsb
	jcxz	a1
	or	dh,08H			(* if CPU is Intel *)
a1:
	push	sp
	pop	ax
	cmp	ax,sp
	jne	a2
	or	dh,04H			(* if cpu is 8028x *)
a2:
	mov	cl,21H
	mov	al,0FFH
	shl	al,cl
	jz	a3
	or	dh,02H			(* if cpu is 8018x or 8028x *)
a3:
	mov	ch,0
	cli
        db 0EBH,00H                      (* jmp     $+2 : empty queue *)
	mov	byte [a4],0
	db	0B1H			(* MOV	CL,... *)
a4:	db	1			(* ...1 *)
	sti
	jcxz	a5
	or	dh,01H			(* if PIQ length=6 (80x86) *)
a5:
	mov	byte [a4],1             (* reset for next time *)
        cmp dh,7
        jne Not386
        pushf
        pop ax
        or ah,0F0H
        push ax
        popf
        pushf
        pop ax
        and ah,0F0H
        jz Not386
        or dh,10H
Not386:
foption 2	
        mov word ds:[temp87], -1
	finit
        call wait
	fstsw	ds:[temp87]
        call wait
	mov	al,0
        cmp byte ds:[temp87],al
	jne	a6
	fstcw	ds:[ndp_cw]
        call wait
	and	byte [ndp_cw],7FH
	fldcw	ds:[ndp_cw]
        call wait
	db 09BH,0DBH,0E1H               (* fdisi *)
        call wait
	fstcw	ds:[ndp_cw]            (* Test for 87/287 *)
        call wait
                                       (* Test for 387 *)
        fld1 st(0)
        fldz st(0)
        fdivp st(1),st(0)
        fld st(0),st(0)
        fchs st(0)
        fcompp st(0),st(1)
        fstsw [ndp_stat]
        call wait
        mov ax,[ndp_stat]
        pushf
        sahf
        je is_87_287
        popf
        mov al,3                       (* 387 *)
        jmp a6
is_87_287:
        popf
	cmp	word ds:[ndp_cw],3FFH  (* was test byte 80H *)
	mov	al,1                   (* 87 *)
	jz	a6
	mov	al,2                   (* 287 *)
a6:
foption 0
        frstor [bp][ndp_save]
        call wait
        mov bl,dh
        sub bh,bh
        cmp bl,15
        jbe a7
        mov bl,16
a7:
        mov ah,al
        mov al,cs:[CpuXlat][bx]
(*%F NearPtr *)
        les di,[bp][cpurec]
(*%E *)
(*%T NearPtr *)
        mov di,[bp][cpurec]
        mov bx, ss
        mov es, bx
(*%E *)
        stosw
        pop di
        pop si
        pop es
        pop ds
(*%T RegParam *)
        pop  dx
        pop  cx
(*%T NearPtr *)
        pop  bx
(*%E *)
(*%E *)
        mov sp,bp
        pop bp
(*%F NearCall *)
	ret far RetSize
(*%E *)	
(*%T NearCall *)
	ret RetSize
(*%E *)	

wait:   mov cx,400H
wloop:  loop wloop
        ret 0

(*%E *)

(*%E *)  (* End Of DOS (not extender) *)

(*%T _XTDDOS *)  (* DOS and extender routines, but not OS2 *)
(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.UserBreak.

   PRECONDITIONS - None.

   POSTCONDITIONS - Process terminated.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Calls procedure in CoreSig.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn @UserBreak

public Lib$UserBreak :


(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    call far @UserBreak
(*%T _DLLOVL *)
    pop  bp
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Sound.

   PRECONDITIONS - None.

   POSTCONDITIONS - Noise.

   IN PARAMETERS -  Frequency (CARDINAL).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

FreqHz = frame

(*%F RegParam *)
RetSize =2
(*%E *)
(*%T RegParam *)
RetSize =0
(*%E *)
public Lib$Sound :



(*%F RegParam *)
  push bp
  mov bp,sp
  mov bx,[bp][FreqHz]
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push bx
  push dx
  mov bx, ax
(*%E *)
  mov ax,34DDH  (* 1.193181 MHz *)
  mov dx,0012H
  cmp dx,bx
  jnb SOU9
  div bx
  mov bx,ax
  in al,PPIport+1
  test al,03H
  jnz SOU1
  or al,03H
  out PPIport+1,al
                (* 10              11       011     0   *)
  mov al,0B6H  (* Select timer 2, LSB,MSB, mode 3, bin *)
  out Timer+3,al
SOU1:
  mov al,bl
  out Timer+2,al
  mov al,bh
  out Timer+2,al
SOU9:
(*%T RegParam *)
  pop  dx
  pop  bx
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%E *)
(*%F RegParam *)
  pop bp
(*%E *)
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.NoSound.

   PRECONDITIONS - None.

   POSTCONDITIONS - Silence.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

public Lib$NoSound :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push ax
  in al,PPIport+1
  and al,0FCH
  out PPIport+1,al
  pop  ax
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

section
(*****************************************************************************)
(* ------------------------------------------------------------------------
   PROCEDURE - @LoadRegisters.

   PRECONDITIONS - Called by Intr, Dos.

   POSTCONDITIONS - Registers loaded prior to software interrupt.

   IN PARAMETERS -  DS:SI points to register record.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Near Call.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment SIG_TEXT(CODE,28H)
(*%E *)

axr=0;  bxr=2;  cxr=4;  dxr=6;  bpr=8;
sir=10; dir=12; dsr=14; esr=16; flags=18

_XTDWIN       = _XTD | _WINDOWS

public @LoadRegisters :
(* loads register in register pack pointed to by DS:SI *)
(*%T _WINDOWS*)
  (* validate segment registers *)
    push sp
    pop  ax
    cmp  ax, sp
    jne  $$RealMode
    db   00FH, 001H, 0E0H              (*I smsw ax *)
    test al, 1
    jz   $$RealMode
(*%E *)
(*%T _XTDWIN *)
  (* check for invalid selectors *)
    mov  dx, [si][dsr]
    db   00FH, 000H, 0E2H              (*I verr dx *)
    jz   $$DSOk
    sub  dx, dx
$$DSOk:
    push dx
    mov  dx, [si][esr]
    db   00FH, 000H, 0E2H              (*I verr dx *)
    jz   $$ESOk
    sub  dx, dx
$$ESOk:
    mov  es, dx
(*%E _XTDWIN*)
(*%T _WINDOWS *)
    jmp  $$RegsValidated
$$RealMode:
(*%E _WINDOWS*)
(*%F _XTD*)
    mov  es, [si][esr]
    push [si][dsr]
(*%E _XTD*)
$$RegsValidated:
    mov  ax, [si][axr]
    mov  bx, [si][bxr]
    mov  cx, [si][cxr]
    mov  dx, [si][dxr]
    mov  di, [si][dir]
    mov  bp, [si][bpr]
    mov  si, [si][sir]
    pop  ds
    ret  near 0

(* ------------------------------------------------------------------------
   PROCEDURE - @SaveRegisters.

   PRECONDITIONS - Called by Intr, Dos.

   POSTCONDITIONS - Registers loaded prior after software interrupt.

   IN PARAMETERS -  far pointer on stack points to register record.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Near Call.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)

public @SaveRegisters :
(* saves register in register pack pointed to by pointer on stack *)
  push ds
  push si
  mov  si, sp
  lds  si, ss:[si][6]
  pushf
  pop  [si][flags]
  pop  [si][sir]
  pop  [si][dsr]
  mov  [si][axr],ax
  mov  [si][bxr],bx
  mov  [si][cxr],cx
  mov  [si][dxr],dx
  mov  [si][dir],di
  mov  [si][bpr],bp
  mov  [si][esr],es
  ret  near 4

section
(*****************************************************************************)
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Dos.

   PRECONDITIONS - Regsiters record initialized.

   POSTCONDITIONS - Interrupt 21H issued.

   IN PARAMETERS -  register record (VAR Registers).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment SIG_TEXT(CODE,28H)
(*%E *)

extrn @LoadRegisters
extrn @SaveRegisters
extrn @InProgramFlag
extrn @StopProgramFlag
extrn __FatalErrorPos
extrn __FatalError

(*%F RegParam *)
p_seg = 2+frame
p_off = frame

(*%F NearPtr *)
RetSize = 4
(*%E *)
(*%T NearPtr *)
RetSize = 2
(*%E *)
(*%E *)
(*%T RegParam *)
p_seg  = -2
p_off  = -4
locals =  4

RetSize = 0
(*%E *)
public Lib$Dos :

  push bp
  mov  bp, sp
(*%T RegParam *)
  sub  sp, locals
(*%T NearPtr *)
  push bx
(*%E *)
  push cx
  push dx
  mov  [bp][p_off], ax
(*%F NearPtr *)
  mov  [bp][p_seg], bx
(*%E *)
(*%E *)
  push ds
  push si
  push di
  pushf
(*%F _XTD *)
(*%F _WINDOWS *)
(*%F _DLL *)
  cmp byte cs:[@InProgramFlag], 1
(*%E *)
(*%T _DLL *)
  mov  dx, seg @InProgramFlag
  mov  es, dx
  cmp byte es:[@InProgramFlag], 1
(*%E *)
  je ok
  cld
  call far __FatalErrorPos
  mov  cx, 13H
  push cx
  push dx
  push ax
  call far __FatalError
ok:
(*%F _DLL *)
  cmp byte cs:[@StopProgramFlag], 1
  je Stop                     (* wait for timer to stop us *)
  mov byte cs:[@InProgramFlag], 0
(*%E *)
(*%T _DLL *)
  cmp byte es:[@StopProgramFlag], 1
  je Stop                     (* wait for timer to stop us *)
  mov byte es:[@InProgramFlag], 0
(*%E *)
(*%E _WINDOWS*)
(*%E _XTD*)
(*%F NearPtr *)
  lds  si,[bp][p_off]
(*%E *)
(*%T NearPtr *)
  mov  si,[bp][p_off]
  push ds
  pop  es
(*%E *)
  push ds                     (* save register pointer *)
  push si
  call @LoadRegisters
  int  21H
  call @SaveRegisters
(*%F _XTD *)
(*%F _WINDOWS *)
 (*%F _DLL *)
  mov byte cs:[@InProgramFlag], 1
 (*%E *)
 (*%T _DLL *)
  mov  dx, seg @InProgramFlag
  mov  es, dx
  mov byte es:[@InProgramFlag], 1
 (*%E *)
(*%E _WINDOWS *)
(*%E _XTD *)
  popf
  pop di
  pop si
  pop ds
(*%T RegParam *)
  pop  dx
  pop  cx
(*%T NearPtr *)
  pop  bx
(*%E *)
  add  sp, locals
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
Stop:
  sti
  jmp Stop

section
(*****************************************************************************)
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Intr.

   PRECONDITIONS - Regsiters record initialized.

   POSTCONDITIONS - Specified Interrupt issued.

   IN PARAMETERS -  register record (VAR Registers), interupt no (CARDINAL).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS and Windows and extender.

   ------------------------------------------------------------------------ *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment SIG_TEXT(CODE,28H)
(*%E *)

extrn @LoadRegisters
extrn $SWInt
extrn @SaveRegisters

(*%F _jpicall *)
  p_num                 = frame
  p_off                 = 2+frame

  RetSize               = 2 + DataPtrSize
(*%E *)

(*%T _jpicall *)
  RetSize               = 0
(*%E *)

public Lib$Intr :
    push bp
(*%F _jpicall *)
    mov  bp, sp
(*%E *)
(*%T _jpicall *)
 (*%F _fptr *)
    push cx
 (*%E *)
    push dx
(*%E *)
    push ds
    push si
    push di
    pushf

(*%T _jpicall *)
 (*%T _fptr *)
    mov  ds, bx
 (*%E *)
    mov  si, ax
(*%E *)
(*%F _jpicall *)
 (*%T _fptr *)
    lds  si, [bp][p_off]
 (*%E *)
 (*%F _fptr *)
    mov  si, [bp][p_off]
 (*%E *)
(*%E *)
    push ds                            (* save register pointer *)
    push si
(*%T _jpicall *)
 (*%T _fptr *)
    push cx                            (* Push Interrupt Number *)
 (*%E *)
 (*%F _fptr *)
    push bx                            (* Push Interrupt Number *)
 (*%E *)
(*%E *)
(*%F _jpicall *)
    push [bp][p_num]                   (* Push Interrupt Number *)
(*%E *)
    call @LoadRegisters
(*%T _fcall *)
    call far $SWInt
(*%E *)
(*%F _fcall *)
    call $SWInt
(*%E *)
    call @SaveRegisters
    popf
    pop  di
    pop  si
    pop  ds
(*%T _jpicall *)
    pop  dx
(*%F _fptr *)
    pop  cx
(*%E *)
(*%E *)
    pop bp
(*%T _fcall *)
    ret  far RetSize
(*%E *)
(*%F _fcall *)
    ret  RetSize
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.SetInProgramFlag.

   PRECONDITIONS - None.

   POSTCONDITIONS - @InProgramFlag set.

   IN PARAMETERS -  None.

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  Allows entry to MSDOS.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment SIG_TEXT(CODE,28H)
(*%E *)

extrn @InProgramFlag

(*%F RegParam *)
on = frame

RetSize = 2
(*%E *)
(*%T RegParam *)
RetSize = 0
(*%E *)
public Lib$SetInProgramFlag :

(*%F RegParam *)
  push bp
  mov bp,sp
  mov al, [bp][on]
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
(*%E *)
(*%F _DLL *)
  mov cs:[@InProgramFlag], al
(*%E *)
(*%T _DLL *)
  push bx
  mov  bx, seg @InProgramFlag
  mov  es, bx
  mov  es:[@InProgramFlag], al
  pop  bx
(*%E *)
(*%F RegParam *)
  pop bp
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%E *)
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

(* ------------------------------------------------------------------------
   PROCEDURE - Lib.GetInProgramFlag.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  None.

   OUT PARAMETERS - State of @InProgramFlag (BOOLEAN).

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS and extender.

   ------------------------------------------------------------------------ *)

public Lib$GetInProgramFlag :


(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  sub ah,ah
(*%F _DLL *)
  mov al,cs:[@InProgramFlag]
(*%E *)
(*%T _DLL *)
  push bx
  mov  bx, seg @InProgramFlag
  mov  es, bx
  mov  al, es:[@InProgramFlag]
  pop  bx
(*%E *)
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)



(*%E *)  (* End Of DOS/extender) *)

(*%T _OS2 *)  (* OS/2 Specific Procedures *)
(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.SelectorLimit.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  Segment (CARDINAL).

   OUT PARAMETERS - Limit (CARDINAL).

   CALLING CONVENTION - Standard.

   NOTES -  Returns size of segment.

   VERSION - OS2.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn __osmode
(*%F RegParam *)
public Lib$SelectorLimit : Sel=frame
  push bp; mov bp,sp;
  push ds
  mov ax,seg __osmode
  mov ds,ax
  cmp byte [__osmode],0
  jz slmax
  mov dx,[bp][Sel]
  db 0FH;db 03H;db 0C2H       (*I lsl ax,dx *)
  jz slok
  sub ax,ax
slok:
  pop ds
  pop bp;
(*%F NearCall *)
  ret far 2
(*%E *)
(*%T NearCall *)
  ret 2
(*%E *)
slmax:
  mov ax,0FFFFH
  jmp slok
(*%E *)

(*%T RegParam *)
public Lib$SelectorLimit :
  push bx
  push dx
  push ds
  mov bx,seg __osmode
  mov ds,bx
  cmp byte [__osmode],0
  jz slmax
  mov dx,ax
  db 0FH;db 03H;db 0C2H       (*I lsl ax,dx *)
  jz slok
  sub ax,ax
slok:
  pop ds
  pop dx
  pop bx
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)
slmax:
  mov ax,0FFFFH
  jmp slok
(*%E *)

(* ------------------------------------------------------------------------
   PROCEDURE - Lib.AddressOK.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  address (ADDRESS).

   OUT PARAMETERS - State (BOOLEAN).

   CALLING CONVENTION - Standard.

   NOTES -  Returns validity of segment.

   VERSION - OS2.

   ------------------------------------------------------------------------ *)

(*%F RegParam *)
public Lib$AddressOK: Ofs=6; Sel=8
  push bp; mov bp,sp;
  push ds
  mov dx,[bp][Sel]
  mov ax,seg __osmode
  mov ds,ax
  cmp byte [__osmode],0
  jz aook
  db 0FH;db 03H;db 0C2H       (*I lsl ax,dx *)
  jnz aofail
  cmp ax,[bp][Ofs]
  jb aofail
aook:
  mov ax,1
  jmp aoexit
aofail:
  sub ax,ax
aoexit:
  pop ds
  pop bp;
(*%F NearCall *)
  ret far 4
(*%E *)
(*%T NearCall *)
  ret 4
(*%E *)
(*%E *)

(*%T RegParam *)
public Lib$AddressOK :
  push cx
  push dx
  push ds
  mov dx, bx
  mov cx, ax
  mov ax,seg __osmode
  mov ds,ax
  cmp byte [__osmode],0
  jz aook
  db 0FH;db 03H;db 0C2H       (*I lsl ax,dx *)
  jnz aofail
  cmp ax, cx
  jb aofail
aook:
  mov ax,1
  jmp aoexit
aofail:
  sub ax,ax
aoexit:
  pop ds
  pop dx
  pop cx
(*%F NearCall *)
  ret far 4
(*%E *)
(*%T NearCall *)
  ret 4
(*%E *)
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.ProtectedMode.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  address (ADDRESS).

   OUT PARAMETERS - Proctected mode  (BOOLEAN).

   CALLING CONVENTION - Standard.

   NOTES -  Returns True if process running under protected mode.

   VERSION - OS2.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn __osmode

public Lib$ProtectedMode :
  push ds
  mov ax,seg __osmode
  mov ds,ax
  mov al,[__osmode]
  mov ah,0
  pop ds
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

(*%E *)

