section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.ScanR.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  destination (ADDRESS), byte count (CARDINAL),
                    byte value (BYTE).

   OUT PARAMETERS - position of value, count if not found (CARDINAL).

   CALLING CONVENTION - Standard.

   NOTES -  Scans for byte from low address.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

(*%F RegParam *)
(*%F NearPtr *)
d_seg = 6+frame
d_ofs = 4+frame
len   = 2+frame
val   = frame

RetSize = 8
(*%E *)

(*%T NearPtr *)
d_ofs = 4+frame
len   = 2+frame
val   = frame

RetSize = 6
(*%E *)
public Lib$ScanR :

  push bp
  mov bp,sp
  push di
  mov cx,[bp][len]
  jcxz ExitScan
(*%F NearPtr *)
  les di,[bp][d_ofs]
(*%E *)
(*%T NearPtr *)
  mov di,[bp][d_ofs]
  push ds
  pop  es
(*%E *)
  mov ax,[bp][val]
  repne
  scasb
  jne ExitScan
  inc cx
ExitScan:
  mov ax,[bp][len]
  sub ax,cx
  pop di
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

(*%T RegParam *)

RetSize = 0
public Lib$ScanR :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push di
  push si
(*%F NearPtr *)
  mov  si, cx
  mov  es, bx
  mov  di, ax
  mov  ax, dx
(*%E *)
(*%T NearPtr *)
  mov  si, bx
  mov  di, ax
  mov  ax, cx
  mov  cx, bx
  push ds
  pop  es
(*%E *)
  jcxz ExitScan
  repne
  scasb
  jne ExitScan
  inc cx
ExitScan:
  mov ax, si
  sub ax, cx
  pop  si
  pop  di
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

