include "corelib.inc"

module AsmLib

(* Common Procedures *)
(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Terminate.

   PRECONDITIONS - None.

   POSTCONDITIONS - Procedure appended to terminate chain.

   IN PARAMETERS -  P (PROC), next link (VAR PROC).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

extrn standard@haltChain
extrn __core_lock
extrn __core_unlock

(*%F RegParam *)
(*%F NearCall *)
(*%F NearPtr *)
a_ptrH = 6+frame
a_ptrL = 4+frame
c_ptrH = 2+frame
c_ptrL = frame

RetSize = 8
(*%E *)
(*%T NearPtr *)
a_ptrH = 4+frame
a_ptrL = 2+frame
c_ptrL = frame

RetSize = 6
(*%E *)
(*%E *)
(*%T NearCall *)
(*%T NearPtr *)
a_ptrL = 2+frame
c_ptrL = frame

RetSize = 4
(*%E *)
(*%F NearPtr *)
a_ptrL = 4+frame
c_ptrH = 2+frame
c_ptrL = frame

RetSize = 6
(*%E *)
(*%E *)
public Lib$Terminate :



  push bp
  mov bp,sp
  push ds
(*%F SameDS *)
  mov  ax, seg standard@haltChain
  mov  ds, ax
(*%E *)
(*%T MThread *)
(*%F _DLL *)
  call far  [__core_lock]
(*%E *)
(*%T _DLL *)
  mov  ax, seg __core_lock
  mov  es, ax
  call far  es:[__core_lock]
(*%E *)
(*%E *)
  mov     ax,[bp][a_ptrL]
  xchg    ax,[standard@haltChain]
(*%F NearCall *)
  mov     dx, [bp][a_ptrH]
  xchg    dx,[standard@haltChain][2]
(*%E *)
(*%F NearPtr *)
  lds     bx,[bp][c_ptrL]
(*%E *)
(*%T NearPtr *)
  mov     bx,[bp][c_ptrL]
(*%E *)
  mov     [bx],ax
(*%F NearCall *)
  mov     [bx][2],dx
(*%E *)
(*%T MThread *)
  mov  bx, seg __core_unlock
  mov  es, bx
  call far  es:[__core_unlock]
(*%E *)
  pop ds
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

(*%T RegParam *)
public Lib$Terminate :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push si
(*%F NearPtr *)
  push ds
(*%E *)
(*%F SameDS *)
  mov  si, seg standard@haltChain
  mov  ds, si
(*%E *)
(*%T MThread *)
(*%F _DLL *)
  call far  [__core_lock]
(*%E *)
(*%T _DLL *)
  mov  si, seg __core_lock
  mov  es, si
  call far  es:[__core_lock]
(*%E *)
(*%E *)
(*%F NearCall *)
  xchg    ax,[standard@haltChain]
  xchg    bx,[standard@haltChain][2]
(*%F NearPtr *)
  mov     ds, dx
(*%E *)
  mov     si, cx
  mov     [si],ax
  mov     [si][2],bx
(*%E *)

(*%T NearCall *)
  xchg    ax,[standard@haltChain]
(*%F NearPtr *)
  mov     ds, cx
(*%E *)
  mov     [bx],ax
(*%E *)

(*%T MThread *)
  mov  bx, seg __core_unlock
  mov  es, bx
  call far  es:[__core_unlock]
(*%E *)
(*%F NearPtr *)
  pop ds
(*%E *)
  pop si
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.HashString.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  string (ARRAY OF CHAR), hash range (CARDINAL).

   OUT PARAMETERS - Returns hash value (CARDINAL).

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)



(*%F RegParam *)
(*%F NearPtr *)
ssize   = 6+frame
segm    = 4+frame
offs    = 2+frame
modulus = frame

RetSize = 8
(*%E *)
(*%T NearPtr *)
ssize   = 4+frame
offs    = 2+frame
modulus = frame

RetSize = 6
(*%E *)
(*%E *)

(*%T RegParam *)
modulus = -2
locals  =  2

RetSize = 0
(*%E *)

public Lib$HashString :


  push  bp
  mov   bp,sp
(*%T RegParam *)
  sub  sp, locals
(*%T NearPtr *)
  push dx
(*%E *)
(*%E *)
(*%F NearPtr *)
  push  ds
(*%E *)
  push  si
  push  di
(*%F RegParam *)
  mov   cx,[bp][ssize]
  jcxz  $Exit
(*%F NearPtr *)
  mov   ds,[bp][segm]
(*%E *)
  mov   si,[bp][offs]
  mov   di,[bp][ssize]
(*%E *)
(*%T RegParam *)
  or    ax, ax
  jz    $Exit
(*%F NearPtr *)
  mov   ds, cx
  mov   si, bx
  mov   [bp][modulus], dx
(*%E *)
(*%T NearPtr *)
  mov   si, bx
  mov   [bp][modulus], cx
(*%E *)
  mov   cx, ax
  mov   di, ax
(*%E *)
  sub   bx,bx
  sub   dx,dx
  sub   ax,ax
$loop:
  lodsb
  or    al, al
  jz    $EndLoop
  xor   dl, al
  rol   dx, 1
  rol   dx, 1
  rol   dx, 1
  add   dx, di
  sub   dx, cx
  loop  $loop
$EndLoop:
  mov  ax, dx
  sub  dx, dx
  div  word [bp][modulus]
$Exit:
  mov  ax, dx
  pop di
  pop si
(*%F NearPtr *)
  pop ds
(*%E *)
(*%T RegParam *)
(*%T NearPtr *)
  pop  dx
(*%E *)
  mov  sp, bp
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

(*****************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Fill.

   PRECONDITIONS - None.

   POSTCONDITIONS - block of bytes set tp specified value.

   IN PARAMETERS -  destination (ADDRESS), byte count (CARDINAL),
                    byte value (BYTE).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

(*%F RegParam *)
(*%F NearPtr *)
d_seg = 6+frame
d_ofs = 4+frame
len   = 2+frame
val   = frame

RetSize = 8
(*%E *)
(*%T NearPtr *)
d_ofs = 4+frame
len   = 2+frame
val   = frame

RetSize = 6
(*%E *)
public Lib$Fill :

  push bp
  mov  bp, sp
  push di
  mov  cx, [bp][len]
(*%F NearPtr *)
  les  di, [bp][d_ofs]
(*%E *)
(*%T NearPtr *)
  mov  di, [bp][d_ofs]
  push ds
  pop es
(*%E *)
  mov  ax, [bp][val]
  mov  ah, al
  shr  cx, 1
rep ; stosw
  jnc $Exit
  stosb
$Exit:
  pop di
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

(*%T RegParam *)

RetSize = 0
public Lib$Fill :

(*%T _DLLOVL *)
  push bp
  mov  bp, sp
(*%E *)
  push di
(*%F NearPtr *)
  mov  di, ax
  mov  es, bx
  mov  ax, dx
(*%E *)
(*%T NearPtr *)
  mov  di, ax
  mov  ax, cx
  mov  cx, bx
  push ds
  pop  es
(*%E *)
  mov  ah, al
  shr  cx, 1
rep ; stosw
  jnc $Exit
  stosb
$Exit:
  pop di
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

