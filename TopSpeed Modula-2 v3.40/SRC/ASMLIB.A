(*%F NearPtr *)
    les  di, [bp][s]
(*%E *)
(*%T NearPtr *)
    mov  di, [bp][s]
    push ds
    pop  es
(*%E *)
    mov  cx, [bp][slen]
    mov  dx, [bp][slen]
    sub  al, al
repne ; scasb
    jne lCalc
    inc  cx
lCalc:
    sub  dx, cx
    xchg dx, cx
    mov  di, [bp][s]
    mov  al, [bp][chk]
repne; scasb
    jnz   notFound
    dec  di
    sub  di, [bp][s]
    mov  ax, di
chrDone:
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far  RetSize
(*%E *)
(*%T NearCall *)
