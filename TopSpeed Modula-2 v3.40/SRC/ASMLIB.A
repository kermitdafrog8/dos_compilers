$NoOverflow:
  call @NormPtr
(*%T _DLLOVL *)
  pop  bp
(*%E *)
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)
(*%E *)


