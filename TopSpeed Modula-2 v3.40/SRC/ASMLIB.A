(* PROCEDURE Move(Source,Dest:ADDRESS;Count:CARDINAL); *)
(* Source:2 | Dest:2 | Count:2 *)

(*%T NearPtr *)
public Lib$Move :
(*%E *)
public Lib$NearMove :
(*%T RegParam *)
  Return = 0
(*%E *)
(*%F RegParam *)
  Count  = frame
  Dest   = frame + 2
  Source = frame + 4
  Return = 6
(*%E *)

(*%T RegParam *)
  jcxz @MoveExit
(*%E *)
(*%F RegParam *)
  push bp
  mov  bp, sp
  push ax
  push bx
  push cx
(*%E *)
  push si
  push di
(*%T RegParam *)
  mov  si, ax
  mov  di, bx
(*%E *)
(*%F RegParam *)
  mov  si, [bp][Source]
  mov  di, [bp][Dest]
  mov  cx, [bp][Count]
  jcxz @MoveDone
(*%E *)
  mov  ax, ds
  mov  es, ax
  xor  bx, bx
  cmp  di, si
  jb   @MoveDown
  je   @MoveDone
  std
  inc  bx
  add  si, cx
  dec  si
  add  di, cx
  dec  di
  test di, 1
  jz   @MoveEven
  movsb
  dec  cx
  jmp  @MoveEven
@MoveDown:
  test di, 1
  jz   @MoveEven
  movsb
  dec  cx
@MoveEven:
  sub  si, bx
  sub  di, bx
  shr  cx, 1
  rep; movsw
  jnc  @MoveDone
  add  si, bx
  add  di, bx
  movsb
@MoveDone:
  cld
  pop  di
  pop  si
(*%F RegParam *)
  pop  cx
  pop  bx
  pop  ax
  pop  bp
(*%E *)
@MoveExit:
(*%T NearCall *)
  ret  Return
(*%E *)
(*%F NearCall *)
  ret  far Return
(*%E *)
