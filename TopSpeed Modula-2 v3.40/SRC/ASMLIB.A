section
(* ------------------------------------------------------------------------
   PROCEDURE - Str.Compare.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  string1, string2 (VAR ARRAY OF CHAR).

   OUT PARAMETERS - returns difference of strings (INTEGER).

   CALLING CONVENTION - Standard.

   NOTES -  None.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment STR_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment STRDLL_TEXT(CODE,28H)
(*%E *)
(*%F RegParam *)
(*%F NearPtr *)
S1len = 10+frame
S1seg =  8+frame
S1ofs =  6+frame
S2len =  4+frame
S2seg =  2+frame
S2ofs =  frame

RetSize = 12
(*%E *)
(*%T NearPtr *)
S1len =  6+frame
S1ofs =  4+frame
S2len =  2+frame
S2ofs =  frame

RetSize = 8
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
S2seg = 2+frame
S2ofs = frame

RetSize =4
(*%E *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%E *)
public Str$Compare :



  push bp
  mov bp,sp
  push ds
  push si
  push di

(*%F RegParam *)
(*%F NearPtr *)
  lds si,[bp][S1ofs]
  les di,[bp][S2ofs]
(*%E *)
(*%T NearPtr *)
  mov si,[bp][S1ofs]
  mov di,[bp][S2ofs]
  push ds
  pop  es
(*%E *)
  mov bx,[bp][S1len]
  mov dx,[bp][S2len]
(*%E *)
(*%T RegParam *)
(*%F NearPtr *)
  mov  si, bx
  mov  ds, cx
  les  di,[bp][S2ofs]
  mov  bx, ax
(*%E *)
(*%T NearPtr *)
  mov si, bx
  mov di, dx
  mov bx, ax
  mov dx, cx
  push ds
  pop  es
(*%E *)
(*%E *)
  mov cx,bx
  cmp cx,dx
  jb CompareLoop
  mov cx,dx
CompareLoop:
  lodsb
  scasb
  jne NotEqual
  or al,al
  loopne CompareLoop
  je Equal
  cmp bx,dx
  je Equal
  ja CheckSi
  cmp byte es:[di],0
  je Equal
Less:
  mov ax,-1
  jmp Return
CheckSi:
  cmp byte [si],0
  je Equal
Greater:
  mov ax,1
  jmp Return
NotEqual:
  cmp al,es:[di][-1]
  jb Less
  jmp Greater
Equal:
  sub ax,ax
Return:
  pop di
  pop si
  pop ds
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

