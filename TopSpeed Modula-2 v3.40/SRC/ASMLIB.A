section
(* ------------------------------------------------------------------------
   PROCEDURE - WinStr.Slice.

   PRECONDITIONS - None.

   POSTCONDITIONS - dest contains section of source, starting at position with
                    a maximum size of length.

   IN PARAMETERS -  dest (VAR ARRAY OF CHAR), source (ARRAY OF CHAR),
                    position, length (CARDINAL).

   OUT PARAMETERS - None.

   CALLING CONVENTION - Standard + far pointers.

   NOTES -  None.

   ------------------------------------------------------------------------ *)
segment _TEXT(CODE,28H)
(*%F RegParam *)
NSlen = 14+frame
NSseg = 12+frame
NSofs = 10+frame
Slen  =  8+frame
Sseg  =  6+frame
Sofs  =  4+frame
P     =  2+frame
L     =  frame

RetSize = 16
(*%E *)

(*%T RegParam *)
NSlen = -2
NSseg = -4
NSofs = -6
Slen  = -8
Sseg  =  6+frame
Sofs  =  4+frame
P     =  2+frame
L     =  frame

RetSize = 8
locals = 8
(*%E *)
public WinStr$Slice :

  push bp
  mov bp, sp
(*%T RegParam *)
  sub  sp, locals
  mov  [bp][NSlen], ax
  mov  [bp][NSofs], bx
  mov  [bp][NSseg], cx
  mov  [bp][Slen], dx
(*%E *)
  push ds
  push si
  push di
  les di,[bp][Sofs]
  mov cx,[bp][Slen]
  sub al,al
  repne
  scasb
  jne LengthCalc
  inc cx
LengthCalc:
  mov ax, [bp][Slen]
  sub ax,cx

  mov bx, [bp][P]
  sub ax,bx
  ja NotBeyondEnd
  sub ax,ax
NotBeyondEnd:
  cmp ax, [bp][L]
  jb OffEnd
  mov ax, [bp][L]
OffEnd:
  lds si, [bp][Sofs]
  add si,[bp][P]
  mov cx,[bp][NSlen]
  cmp ax,cx
  ja SourceBigger
  mov cx,ax
SourceBigger:
  les di,[bp][NSofs]
  rep
  movsb
  jae Exit
  sub al,al
  stosb
Exit:
  pop di
  pop si
  pop ds
(*%T RegParam *)
  mov  sp, bp
(*%E *)
  pop bp
(*%T _fcall *)
    ret far RetSize
(*%E *)
(*%F _fcall *)
    ret  RetSize
(*%E *)

