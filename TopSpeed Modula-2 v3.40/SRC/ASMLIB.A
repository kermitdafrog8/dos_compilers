section
(* ------------------------------------------------------------------------
   PROCEDURE - $NormPtr.

   PRECONDITIONS - None.

   POSTCONDITIONS - Far pointer normalised.

   IN PARAMETERS -  pointer (FarADDRESS) dx:ax.

   OUT PARAMETERS - pointer return (FarADDRESS).

   CALLING CONVENTION - NearCall.

   NOTES -  None.

   VERSION - MSDOS real mode.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

public @NormPtr :
  mov cx,ax
  and ax,000FH
  shr cx,1
  shr cx,1
  shr cx,1
  shr cx,1
  add dx,cx
  ret 0

(**************************************************************************)
section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.AddFarAddr.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  pointer (FarADDRESS).

