section
(* ------------------------------------------------------------------------
   PROCEDURE - Lib.Compare.

   PRECONDITIONS - None.

   POSTCONDITIONS - None.

   IN PARAMETERS -  source, destination (ADDRESS), byte count (CARDINAL).

   OUT PARAMETERS - position of first differing byte,
                    count if blocks equal (CARDINAL).

   CALLING CONVENTION - Standard.

   NOTES -  Scans for byte from high address.

   VERSION - _OS2 and MSDOS.

   ------------------------------------------------------------------------ *)
(*%F _DLL *)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment Lib_TEXT(CODE,28H)
(*%E *)
(*%E *)
(*%T _DLL *)
segment LibDLL_TEXT(CODE,28H)
(*%E *)

public Lib$Compare :

(*%F RegParam *)
num   = frame
(*%T NearPtr *)
s2    = 2+frame
s1    = 4+frame

RetSize = 6
(*%E *)
(*%F NearPtr *)
s2    = 2+frame
s1    = 6+frame

RetSize = 10
(*%E *)


    push bp
    mov  bp, sp
    push di
    push si
(*%F NearPtr *)
    push ds
    lds  si, [bp][s1]
    les  di, [bp][s2]
(*%E *)
(*%T NearPtr *)
    mov  si, [bp][s1]
    mov  di, [bp][s2]
    push ds
    pop  es
(*%E *)
    mov  cx, [bp][num]
    mov  ax, cx
    jcxz exitScan
repe ; cmpsb
    je   exitScan
    inc  cx
exitScan:
    sub  ax, cx
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far  RetSize
(*%E *)
(*%T NearCall *)
    ret  RetSize
(*%E *)
(*%E *)


(*%T RegParam *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%F NearPtr *)
RetSize = 2
(*%E *)

(*%F NearPtr *)
num    = frame
(*%E *)


(*%F NearPtr *)
    push bp
    mov  bp, sp
(*%E *)
    push di
    push si
(*%F NearPtr *)
    push ds
    mov  ds, bx
    mov  si, ax
    mov  di, cx
    mov  es, dx
    mov  cx, [bp][num]
(*%E *)
(*%T NearPtr *)
    mov  si, ax
    mov  di, bx
    push ds
    pop  es
(*%E *)
    mov  ax, cx
    jcxz exitScan
repe ; cmpsb
    je   exitScan
    inc  cx
exitScan:
    sub  ax, cx
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  si
    pop  di

(*%F NearPtr *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far  RetSize
(*%E *)
(*%T NearCall *)
    ret  RetSize
(*%E *)

(*%E *)

