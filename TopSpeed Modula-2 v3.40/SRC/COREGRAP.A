    jmp  notNeeded


public __EGAPlot :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    cmp  byte [__EGAtranslate], 0
    jz   notNeeded
    push ax
    push bx
    mov  ax, cx
    call __EGAxlat
    mov  cx, ax
    pop  bx
    pop  ax
notNeeded:
    push cx
    mov  cx, ax
    and  cx, 7
    mov  ch, 80H
    shr  ch, cl
    mov  cl, ch              (* cl = mask *)
(*%T _XTD *)
    db   0C1H,0F8H,003H                (*I shr  ax, 3 *)
(*%E *)
(*%F _XTD *)
    shr  ax, 1
    shr  ax, 1
    shr  ax, 1
(*%E *)
    mov  si, ax
    mov  ax, [__width]
    mul  bx
    add  si, ax              (* offset *)
    mov  ax, [__active_page]
    mul  word [__page_size]
(*%T _XTD *)
    db   0C1H,0E0H,004H                (*I shl  ax, 4 *)
    add  si, ax
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    add  ax, 0A000H
(*%E *)
    mov  es, ax              (* segment *)
    pop  bx                  (* cx = mask, bx = col *)
    mov  dx, 03CEH
    mov  ax, 205H
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 8
    mov  ah, cl
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    xchg bl, es:[si]
    mov  ah, 0FFH
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, 5
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)

(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
