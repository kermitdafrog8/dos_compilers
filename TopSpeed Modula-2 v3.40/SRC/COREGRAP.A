section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __hclip
extrn __pixeladdrEGA2
extrn __EGAxlat

select _DATA

extrn __EGAtranslate

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


x1     = -2
y1     = -4
x2     = -6
EGAcolor = -8
locals   =  8

public __EGAHLine :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __hclip
    jc   near noDraw
    mov  [bp][x1], ax
    mov  [bp][y1], bx
    mov  [bp][x2], cx

    mov  ax, dx
    cmp  byte [__EGAtranslate], 0
    jz   notNeeded
    call __EGAxlat
notNeeded:
    mov  [bp][EGAcolor], ax
    mov  dx, 3CEH
    mov  ax, 5H
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ah, [bp][EGAcolor]
    sub  al, al
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, 0FF01H
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 3
    mov  ah, 0
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, [bp][y1]
    mov  bx, [bp][x1]
    call __pixeladdrEGA2
    mov  di, bx
    mov  dh, ah
    not  dh
    shl  dh, cl
    not  dh
    mov  cx, [bp][x2]
    and  cl, 7
    xor  cl, 7
    mov  dl, 0FFH
    shl  dl, cl
    mov  ax, [bp][x2]
    mov  bx, [bp][x1]
    mov  cl, 3
    shr  ax, cl
    shr  bx, cl
    mov  cx, ax
    sub  cx, bx
    mov  bx, dx
    mov  dx, 3CEH
    mov  al, 8
    push es
    pop  ds
    mov  si, di
    or   bh, bh
    js   byteAligned
    or   cx, cx
    jnz  multiByte
    and  bl, bh
    jmp  singleByte
multiByte:
    mov  ah, bh
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    movsb
    dec  cx
byteAligned:
    mov  ah, 0FFH
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
rep ; movsb
singleByte:
    mov  ah, bl
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    movsb
    sub  ax, ax
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    inc  ax
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 3
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, 0FF08H
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
noDraw:
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn  __pixeladdrEGA2
extrn  __hclip

select _DATA

EGA2x1      : dw 0
EGA2y1      : dw 0
EGA2x2      : dw 0
EGA2color   : dw 0
propPix     : db 0, 0FFH

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __EGA2HLine :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __hclip
    jc   noDraw
    mov  [EGA2x1], ax
    mov  [EGA2y1], bx
    mov  [EGA2x2], cx
    mov  [EGA2color], dx
    mov  ax, [EGA2y1]
    mov  bx, [EGA2x1]
    call __pixeladdrEGA2
    mov  di, bx
    mov  dh, ah
    not  dh
    mov  dl, 0FFH
    shl  dh, cl
    not  dh
    mov  cx, [EGA2x2]
    and  cl, 7
    xor  cl, 7
    shl  dl, cl
    mov  ax, [EGA2x2]
    mov  bx, [EGA2x1]
    mov  cl, 3
    shr  ax, cl
    shr  bx, cl
    mov  cx, ax
    sub  cx, bx
    mov  bx, propPix
    mov  al, [EGA2color]
    xlat
    or   dh, dh
    js   fullByte
    or   cx, cx
    jnz  multiByte
    and  dl, dh
    jmp  lastByte
multiByte:
    mov  ah, al
    and  ah, dh
    not  dh
    and  es:[di], dh
    or   es:[di], ah
    inc  di
    dec  cx
fullByte:
rep ; stosb
lastByte:
    and  al, dl
    not  dl
    and  es:[di], dl
    or   es:[di], al
noDraw:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(**************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __hclip

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

mask  =  frame

public __VGAHLine :

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __hclip
    jc   noDraw
    mov  di, cx
    sub  di, ax
    inc  di
    push dx
    mov  dx, 320
    xchg bx, ax
    mul  dx
    add  ax, bx
    mov  cx, di
(*%T _XTD *)
    extrn __A000h
    mov  bx, __A000h
(*%E *)
(*%F _XTD *)
    mov  bx, 0A000H
(*%E *)
    mov  es, bx
    mov  di, ax
    pop  ax
rep ; stosb
noDraw:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __lclip

select _DATA

extrn __fgcolor

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


lstyle = frame

x1     = -2
y1     = -4
x2     = -6
y2     = -8
inc1   = -10
inc2   = -12
mask   = -14
draw   = -16
locals =  16

verticalLine:
    mov  ax, [bp][y1]
    mov  bx, [bp][y2]
    mov  cx, bx
    sub  cx, ax
    jge  Ps
    neg  cx
    mov  ax, bx
Ps:
    inc  cx
    mov  di, [bp][x1]
    mov  dx, 320
    mul  dx
    add  di, ax
    dec  si
    mov  al, [__fgcolor]
    mov  bx, [bp][lstyle]
    cmp  bx, -1
    jne  vertMask
vertLoop:
    stosb
    add  di, si
    loop vertLoop
    jmp  lineExit
vertMask:
    mov  dx, [bp][mask]
vertMLoop:
    test dx, bx
    jz   noStore
    stosb
cont:
    add  di, si
    rol  dx, 1
    loop vertMLoop
    jmp  lineExit
noStore:
    inc  di
    jmp  cont

VGAhoriz:
    mov  ax, [bp][y1]
    mov  bx, [bp][x1]
    mov  dx, 320
    mul  dx
    add  ax, bx
    mov  di, ax
    inc  cx
    mov  al, [__fgcolor]
    mov  bx, [bp][lstyle]
    mov  dx, [bp][mask]
hLoop:
    test bx, dx
    jz   noStore5
    mov  es:[di], al
noStore5:
    inc  di
    rol  dx, 1
    loop hLoop
    jmp  lineExit

lowLine:
    test dx, [bp][lstyle]
    jz   noStore2
    stosb
cont2:
    rol  dx, 1
    or   si, si
    jns  lPos
    add  si, [bp][inc1]
    loop lowLine
    jmp  lineExit
noStore2:
    inc  di
    jmp  cont2
lPos:
    add  si, [bp][inc2]
    add  di, bx
    loop lowLine
    jmp  lineExit

highLine:
    test dx, [bp][lstyle]
    jz  noStore3
    stosb
cont3:
    rol  dx, 1
    add  di, bx
    or   si, si
    jns  hPos
    add  si, [bp][inc1]
    dec  di
    loop highLine
    jmp  lineExit
noStore3:
    inc  di
    jmp  cont3
hPos:
    add  si, [bp][inc2]
    loop highLine

lineExit:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __VGALine :    (* ax = x1, bx = y1, cx = x2, dx = y2 *)

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   lineExit
    mov  [bp][x1], ax
    mov  [bp][y1], bx
    mov  [bp][x2], cx
    mov  [bp][y2], dx
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  es, ax

    mov  si, 320
    sub  cx, [bp][x1]
    jz   verticalLine
    push cx
    mov  cx, [bp][x1]
    and  cl, 15
    mov  bx, 1
    shl  bx, cl
    mov  [bp][mask], bx
    pop  cx
    mov  bx, [bp][y2]
    sub  bx, [bp][y1]
    jz   VGAhoriz
    jns  slopePos
    neg  bx
    neg  si
slopePos:
    push si
    mov  word [bp][draw], lowLine
    cmp  bx, cx
    jle  useLowSlope
    mov  word [bp][draw], highLine
    xchg  bx, cx
useLowSlope:
    shl  bx, 1
    mov  [bp][inc1], bx
    sub  bx, cx
    mov  si, bx
    sub  bx, cx
    mov  [bp][inc2], bx
    mov  ax, [bp][y1]
    mov  di, [bp][x1]
    mov  dx, 320
    mul  dx
    add  di, ax
    inc  cx
    pop  bx
    mov  al, [__fgcolor]
    mov  dx, [bp][mask]
    jmp  [bp][draw]

(**************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __VGAleftscan :

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push di
    mov  di, ax
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  es, ax
    mov  al, bl
scanLoop:
    dec  di
    dec  dx
    cmp  al, es:[di]
    je   scanDone
    cmp  dx, cx
    jge  scanLoop
scanDone:
    mov  ax, dx
    inc  ax
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)

section

(*%F NearCall *)
