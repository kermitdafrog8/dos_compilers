    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  dx, cx
    mov  cx, ax
    and  cl, 7
    xor  cl, 7
    shl  dl, cl
    mov  cl, dl
(*%T _XTD *)
    db   0C1H,0F8H,003H                (*I shr  ax, 3 *)
(*%E *)
(*%F _XTD *)
    shr  ax, 1
    shr  ax, 1
    shr  ax, 1
(*%E *)
    mov  si, ax
    mov  ax, [__width]
    mul  bx
    add  si, ax              (* offset *)
    mov  ax, [__active_page]
    mul  word [__page_size]
(*%T _XTD *)
    db   0C1H,0E0H,004H                (*I shl  ax, 4 *)
    add  si, ax
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    add  ax, 0A000H
(*%E *)
    mov  es, ax              (* segment *)
    or   es:[si], cl
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdrEGA
extrn __resetEGA
extrn __EGAPlaneShift
extrn __EGAStartPlane

select _DATA

extrn __width
actionTable : db 10H, 8H, 0H, 0H, 18H

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

x1     = frame
y1     = 2+frame
buffer = 4+frame
action = 8+frame

BytesPerRow   = -2
len           = -4
rows          = -6
rowcount      = -8
startmask     = -10
endmaskL      = -12
endmaskR      = -14
RMWBits       = -16
NotFlag       = -18
EGAPlaneShift = -20
EGAStartPlane = -22
locals        =  22

_GPRESET    =  2
ByteShift   =  3

public __EGAPut :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  ax, [__EGAPlaneShift]
    mov  [bp][EGAPlaneShift], ax
    mov  ax, [__EGAStartPlane]
    mov  [bp][EGAStartPlane], ax
    mov  ax, [__width]
    mov  [bp][BytesPerRow], ax
    mov  al, [bp][action]
    cmp  al, _GPRESET
    jnz  selectMode
    mov  byte [bp][RMWBits], 0
    mov  byte [bp][NotFlag], 1
    jmp  modeSelected
selectMode:
    mov  bx, actionTable
    xlat
    mov  [bp][RMWBits], ax
    mov  byte [bp][NotFlag], 0
modeSelected:
    mov  ax, [bp][y1]            (* setup addressing *)
    mov  bx, [bp][x1]
    call __pixeladdrEGA
    inc  cl
    and  cl, 7
    mov  di, bx
    lds  si, [bp][buffer]
                                (* get header *)
    lodsw
    mov  [bp][rows], ax
    lodsb
    sub  ah, ah
    mov  [bp][len], ax
    lodsb
    mov  ch, al
                                (* setup controller *)
    mov  dx, 3CEH
    mov  al, 3
    out  byte dx, al
    inc  dx
    mov  al, [bp][RMWBits]
    out  byte dx, al

    dec  dx
    mov  al, 5H
    out  byte dx, al
    inc  dx
    mov  al, 8
    out  byte dx, al

    dec  dx
    mov  al, 7H
    out  byte dx, al
    inc  dx
    mov  al, 0
    out  byte dx, al

    dec  dx
    mov  dl, 0C4H
    mov  al, 2H
    mov  ah, 1
    push cx
    mov  cl, [bp][EGAStartPlane]
    shl  ah, cl
    pop  cx
    cmp  cx, 0FF00H
    jne  op15
                                (* byte aligned blocks *)
    mov  cx, [bp][len]
op10:
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    push ax
    push di
    mov  bx, [bp][rows]
    mov  ah, [bp][NotFlag]
op11:
    push di
    push cx
op12:
    lodsb
    or   si, si
    jnz  inSeg1
    push ds
    extrn @next_seg
    call @next_seg
    pop ds
inSeg1:
    or   ah, ah
    jz   EGApStore
    not  al
EGApStore:
    and  es:[di], al
    inc  di
    loop op12
    pop  cx
    pop  di
    add  di, [bp][BytesPerRow]
    dec  bx
    jnz  op11

    pop  di
    pop  ax
    push cx
    mov  cl, [bp][EGAPlaneShift]
    shr  ah, cl
    pop  cx
    jnz  op10
    jmp  near EGAPutExit

op15:                                 (* non aligned blocks *)
    push ax
    mov  bx, 0FFH
    mov  al, ch
    cbw
    cmp  word [bp][len], 1
    jne  op16
    mov  bl, ch
    mov  ah, ch
    sub  al, al
op16:
    shl  ax, cl
    shl  bx, cl
    mov  bl, al
    mov  al, 8
    mov  [bp][endmaskL], ax
    mov  ah, bl
    mov  [bp][endmaskR], ax
    mov  ah, bh
    mov  [bp][startmask], ax
    mov  bx, [bp][len]
    pop  ax

op17:
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    push ax
    push di
    mov  dl, 0CEH
    mov  ax, [bp][rows]
    mov  [bp][rowcount], ax

op18:
    push di
    push ds
    push si
    push bx
    mov  ax, [bp][startmask]
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    lodsb
    or   si, si
    jnz  inSeg2
    push ds
    call @next_seg
    pop ds
inSeg2:
    mov  ah, al
    lodsb
    xchg ah, al
    cmp  byte [bp][NotFlag], 0
    je   noNot1
    not  ax
noNot1:
    dec  si
    test cl, cl
    jnz  op19
    dec  bx
    jnz  op20
    jmp  op22

op19:
    rol  ax, cl
    and  es:[di], ah
    inc  di
    dec  bx
op20:
    push ax
    mov  ax, 0FF08H
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    pop  ax
    dec  bx
    jng  op22

op21:
    and  es:[di], al
    inc  di
    lodsb
    or   si, si
    jnz  inSeg3
    push ds
    call @next_seg
    pop ds
inSeg3:
    mov  ah, al
    lodsb
    xchg ah, al
    cmp  byte [bp][NotFlag], 0
    je   noNot2
    not  ax
noNot2:
    dec  si
    rol  ax, cl
    dec  bx
    jnz  op21

op22:
    mov  bx, ax
    mov  ax, [bp][endmaskL]
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    and  es:[di], bl
    mov  ax, [bp][endmaskR]
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    and  es:[di][1], bh
    pop  bx
    pop  si
    pop  ds
    add  si, bx
    jnc  inSeg4
    mov  di, ds         (*@@@ Ask Nigel *)
    add  di, 1000H
    mov  ds, di
inSeg4:
    pop  di
    add  di, [bp][BytesPerRow]
    dec  word [bp][rowcount]
    jnz  op18
    pop  di
    pop  ax
    mov  dl, 0C4H
    push cx
    mov  cl, [bp][EGAPlaneShift]
    shr  ah, cl
    pop  cx
    jnz  op17

EGAPutExit:
(*%F NearCall *)
    call far __resetEGA
(*%E *)
(*%T NearCall *)
    call __resetEGA
(*%E *)
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)



(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __EGAleftscan :

left   = frame
border  = frame

    push bp
    mov  bp, sp
    push di
    push si
    push ds
    std
    mov  si, ax               (* ptr *)
    mov  ds, bx
    mov  di, dx               (* lim value *)
    mov  bp, [bp][left]       (* left *)
    mov  bx, cx               (* bl border *)
    mov  cx, 7                (* calculate mask *)
    and  cx, bp
    mov  ch, 80H
    shr  ch, cl
    mov  cl, ch               (* cl = mask *)

    mov  dx, 03CEH            (* set read mode *)
    mov  al, 5
    out  byte dx, al
    mov  al, 8
    inc  dx
    out  byte dx, al
    dec  dx
    mov  al, 2
    out  byte dx, al
    inc  dx
    mov  al, bl
    out  byte dx, al
    dec  dx
    mov  ax, 0FF08H
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    lodsb
scanLoop:
    dec  bp
    cmp  cl, 80H
    je   needNewByte
    shl  cl, 1
getPixel:
    test al, cl
    jnz  scanDone
    cmp  bp, di
    jge  scanLoop
scanDone:
    inc  bp
    mov  ax, bp
    cld
    pop  ds
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

needNewByte:
    mov  cl, 1H
newByteLoop:
    lodsb
    or   al, al
    jnz  getPixel
    sub  bp, 8
    cmp  bp, di
    jge  newByteLoop
    mov  bp, di
    dec  bp
    jmp  scanDone

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __EGArightscan :

right   = frame
border  = frame

    push bp
    mov  bp, sp
    push di
    push si
    push ds
    mov  si, ax               (* ptr *)
    mov  ds, bx
    mov  es, bx
    mov  di, dx               (* lim value *)
    mov  bp, [bp][right]      (* right *)
    mov  bx, cx               (* bl border *)
    mov  cx, 7                (* calculate mask *)
    and  cx, bp
    mov  ch, 80H
    shr  ch, cl
    mov  cl, ch               (* cl = mask *)
                              (* read mode set in left scan *)
    lodsb
EGARsLoop:
    inc  bp
    cmp  cl, 1H
    je   EGAnNewByte
    shr  cl, 1
EGARgPixel:
    test al, cl
    jnz  EGARsDone
    cmp  bp, di
    jle  EGARsLoop
EGARsDone:
    dec  bp
    mov  dx, 3CEH
    mov  al, 5
    out  byte dx, al
    inc  dx
    mov  al, 0
    out  byte dx, al
    mov  ax, bp
    pop  ds
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

EGAnNewByte:
    mov  ax, bp
    mov  cx, di
    sub  cx, bp
    inc  cx
    mov  bp, cx
    and  bp, 7
    shr  cx, 1
    shr  cx, 1
    shr  cx, 1
    jcxz noneLeft
    sub  al, al
    xchg si, di
repe ; scasb
    xchg si, di
    je   byteF
    inc  cx
    shl  cx, 1
    shl  cx, 1
    shl  cx, 1
byteF:
    mov  ax, di
    sub  ax, cx
    sub  ax, bp
    mov  bp, ax
    inc  bp
    cmp  bp, di
    ja   EGARsDone
EGAFastDone:
    dec  si
EGAFastDone2:
    lodsb
    mov  cl, 80H
    jmp  EGARgPixel

noneLeft:
    mov  bp, ax
    jmp  EGAFastDone2


(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdr320x200
extrn __pixeladdr640x200

select _DATA

extrn __width

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


(*
void CGAGet(unsigned char *buffer, short x1, y1, x2, y2);
*)

buffer        = frame
x1            = 4+frame
y1            = 6+frame
x2            = 8+frame
y2            = 10+frame
len           = -2
incr          = -4
locals        =  4

public __CGA320Get :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  ax, [bp][x2]      (* get block size *)
    sub  ax, [bp][x1]
    mov  cx, 0FF03H
    and  cl, al
    xor  cl, 3
    shl  cl, 1
    shl  ch, cl
    mov  cl, ch
    push cx
    mov  cl, 2
    shr  ax, cl
    inc  ax
    push ax
    mov  ax, [bp][y2]
    sub  ax, [bp][y1]
    inc  ax
    push ax

    mov  ax, [bp][y1]            (* compute video address *)
    mov  bx, [bp][x1]
    call __pixeladdr320x200
    xor  cl, 6
    jmp  common


(*
void CGAGet(unsigned char *buffer, short x1, y1, x2, y2);
*)

public __CGA640Get :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  ax, [bp][x2]      (* get block size *)
    sub  ax, [bp][x1]
    mov  cx, 0FF07H
    and  cl, al
    xor  cl, 7
    shl  ch, cl
    mov  cl, ch
    push cx
    mov  cl, 3
    shr  ax, cl
    inc  ax
    push ax
    mov  ax, [bp][y2]
    sub  ax, [bp][y1]
    inc  ax
    push ax

    mov  ax, [bp][y1]            (* compute video address *)
    mov  bx, [bp][x1]
    call __pixeladdr640x200
    xor  cl, 7
common:
    push es
    pop  ds
    mov  si, bx
    mov  bx, 2000H
    test si, 2000H
    jz   interleave1
    mov  bx, 80-2000H
interleave1:
    mov  [bp][incr], bx
    les  di, [bp][buffer]
    pop  ax                   (* pixel rows *)
    stosw
    mov  dx, ax               (* dx = row count *)
    pop  ax                   (* bytes per pixel row *)
    stosb
    mov  [bp][len], ax
    pop  ax
    stosb                     (* mask for last byte *)
    mov  ch, al

getLoop1:
    mov  bx, [bp][len]
    push si
getLoop2:
    lodsw
    dec  si
    rol  ax, cl
    stosb
    dec  bx
    jnz  getLoop2

    and  es:[di][-1], ch
    pop  si
    add  si, [bp][incr]
    mov  ax, 2000H
    xor  ax, 80-2000H
    xor  [bp][incr], ax
    dec  dx
    jnz  getLoop1


    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdr320x200
extrn __pixeladdr640x200

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

x1     = frame
y1     = 2+frame
buffer = 4+frame
action = 8+frame
len        = -2
incr       = -4
rows       = -6
bitOp      = -8
pixAddress = -10
lastMask   = -12
clShift    = -13
locals     =  13

incRow:
    add  di, [bp][incr]
    mov  ax, 2000H
    xor  ax, 80-2000H
    xor  [bp][incr], ax
    dec  word [bp][rows]
    ret  0

__setBlock:

    cmp  cx, 0FF00H
    jnz  L640op15
    mov  cx, [bp][len]
L640op10:
    push cx
    push di
rep ; movsb
    pop  di
    pop  cx
    call incRow
    jnz  L640op10
    jmp  near L640setExit

L640op15:
    not  ch
    mov  dx, 0FF00H
    ror  dx, cl
    mov  bx, [bp][len]
    dec  bx
L640op16:
    push di
    or   bx, bx
    jz   L640op18
    push bx
L640op17:
    and  es:[di], dx
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  L640op17
    pop  bx
L640op18:
    mov  al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    pop  di
    call incRow
    jnz  L640op16
    jmp  near L640setExit

__XORBlock:
    mov  bx, [bp][len]
L640op20:
    push di
    push bx
L640op21:
    lodsb
    sub  ah, ah
    ror  ax, cl
    xor  es:[di], ax
    inc  di
    dec  bx
    jnz  L640op21
    pop  bx
    pop  di
    call incRow
    jnz  L640op20
    jmp  near L640setExit

__ANDBlock:

    not  ch
    mov  bx, [bp][len]
    dec  bx
L640op30:
    push di
    or   bx, bx
    jz   L640op32
    push bx
L640op31:
    lodsb
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    inc  di
    dec  bx
    jnz  L640op31
    pop  bx
L640op32:
    lodsb
    or   al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    pop  di
    call incRow
    jnz  L640op30
    jmp  near L640setExit

__ORBlock:
    mov  bx, [bp][len]
L640op40:
    push di
    push bx
L640op41:
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  L640op41
    pop  bx
    pop  di
    call incRow
    jnz  L640op40
    jmp  near L640setExit


__reverseBlock:

    cmp  cx, 0FF00H
    jnz  L640op55
    mov  cx, [bp][len]
L640op50:
    push cx
    push di
revLoop1:
    lodsb
    not  al
    stosb
    loop revLoop1
    pop  di
    pop  cx
    call incRow
    jnz  L640op50
    jmp  near L640setExit

L640op55:
    not  ch
    mov  dx, 0FF00H
    ror  dx, cl
    mov  bx, [bp][len]
    dec  bx
L640op56:
    push di
    or   bx, bx
    jz   L640op58
    push bx
L640op57:
    and  es:[di], dx
    lodsb
    sub  ah, ah
    not  al
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  L640op57
    pop  bx
L640op58:
    mov  al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    not  ax
    mov  [bp][lastMask], ax
    lodsb
    sub  ah, ah
    not  al
    ror  ax, cl
    and ax, [bp][lastMask]
    or   es:[di], ax
    pop  di
    call incRow
    jnz  L640op56
    jmp  near L640setExit


(*
void CGA640Put(short x1, y1, unsigned char *buffer, short action);
*)

public __CGA320Put :

    push bp
    mov  bp, sp
    sub  sp, locals
    mov  word [bp][pixAddress], __pixeladdr320x200
    mov  byte [bp][clShift], 6
    jmp  PCGAcommon

public __CGA640Put :

    push bp
    mov  bp, sp
    sub  sp, locals
    mov  word [bp][pixAddress], __pixeladdr640x200
    mov  byte [bp][clShift], 7
PCGAcommon:
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  ax, [bp][action]
    or  ax, ax
    jnz  L640op2
L640op1:
    mov  word [bp][bitOp], __ORBlock
    jmp  gotOp
L640op2:
    dec  ax
    jnz  L640op3
    mov  word [bp][bitOp], __ANDBlock
    jmp  gotOp
L640op3:
    dec  ax
    jnz  L640op4
    mov  word [bp][bitOp], __reverseBlock
    jmp  gotOp
L640op4:
    dec  ax
    jnz  L640op5
    mov  word [bp][bitOp], __setBlock
    jmp  gotOp
L640op5:
    mov  word [bp][bitOp], __XORBlock
gotOp:
    mov  ax, [bp][y1]
    mov  bx, [bp][x1]
    call [bp][pixAddress]
    xor  cl, [bp][clShift]
    mov  di, bx
    mov  bx, 2000H
    test di, 2000H
    jz   L640interleave1
    mov  bx, 80-2000H
L640interleave1:
    mov  [bp][incr], bx
    lds  si, [bp][buffer]
    lodsw
    mov  [bp][rows], ax
    lodsb
    sub  ah, ah
    mov  [bp][len], ax
    lodsb
    mov  ch, al
    jmp  [bp][bitOp]
L640setExit:
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __CGA320leftscan :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push di
    push si
    push ds
    std
    mov  si, ax               (* ptr *)
(*%T _XTD *)
    extrn __B800h
    mov  ax, __B800h
(*%E *)
(*%F _XTD *)
    mov  ax, 0B800H
(*%E *)
    mov  ds, ax
    mov  di, dx               (* left *)
    mov  ax, dx
    mov  dx, cx               (* limit *)
    mov  cl, 6
    shl  bl, cl
    mov  cx, ax
    and  cl, 3
    shl  cl, 1
    mov  bh, 0C0H
    shr  bx, cl
    lodsb
CGALscanLoop:
    dec  di
    rol  bl, 1
    rol  bl, 1
    rol  bh, 1
    rol  bh, 1
    jc   CGALoad
CGAloadDone:
    mov  ah, al
    and  ah, bh
    cmp  ah, bl
    je   CGALscanDone
    cmp  di, dx
    jge  CGALscanLoop
CGALscanDone:
    inc  di
    mov  ax, di
    cld
    pop  ds
    pop  si
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

CGALoad:
    lodsb
    jmp  CGAloadDone

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
