section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdrHerc

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

(*
void HercGet(unsigned char *buffer, short x1, y1, x2, y2);
*)

buffer = frame
x1     = 4+frame
y1     = 6+frame
x2     = 8+frame
y2     = 10+frame
len       = -2
leaf      = -4
locals    =  4

public __HercGet :
    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  ax, [bp][x2]      (* get block size *)
    sub  ax, [bp][x1]
    mov  cx, 0FF07H
    and  cl, al
    xor  cl, 7
    shl  ch, cl
    mov  cl, ch
    push cx
    mov  cl, 3
    shr  ax, cl
    inc  ax
    push ax
    mov  ax, [bp][y2]
    sub  ax, [bp][y1]
    inc  ax
    push ax

    mov  ax, [bp][y1]            (* compute video address *)
    mov  bx, [bp][x1]
    call __pixeladdrHerc
    xor  cl, 7
    push es
    pop  ds
    mov  si, bx
    cmp  si, 2000H
    jb   HGinterleave1
    cmp  si, 4000H
    jb   HGinterleave2
    cmp  si, 6000H
    jb   HGinterleave3
HGinterleave4:
    mov  bx, 3H
    jmp  HGgotInterleave
HGinterleave3:
    mov  bx, 2H
    jmp  HGgotInterleave
HGinterleave2:
    mov  bx, 1H
    jmp  HGgotInterleave
HGinterleave1:
    mov  bx, 0H
HGgotInterleave:
    mov  [bp][leaf], bx
    les  di, [bp][buffer]
    pop  ax                   (* pixel rows *)
    stosw
    mov  dx, ax
    pop  ax                   (* bytes per pixel row *)
    stosb
    mov  [bp][len], ax
    pop  ax
    stosb                     (* mask for last byte *)
    mov  ch, al

HGgetLoop1:
    mov  bx, [bp][len]
    push si
HGgetLoop2:
    lodsw
    dec  si
    rol  ax, cl
    stosb
    dec  bx
    jnz  HGgetLoop2

    pop  si
    and  es:[di][-1], ch
    mov  ax, [bp][leaf]
    cmp  ax, 3
    jnz  HGnotLast
    sub  ax, ax
    mov  [bp][leaf], ax
    sub  si, 6000H-90
    jmp  HGgotRow
HGnotLast:
    inc  ax
    mov  [bp][leaf], ax
    add  si, 2000H
HGgotRow:
    dec  dx
    jnz  HGgetLoop1

    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn  __pixeladdrHerc

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

x1     = frame
y1     = 2+frame
buffer = 4+frame
action = 8+frame
len        = -2
leaf       = -4
rows       = -6
bitOp      = -8
lastMask   = -10
locals     =  10

incRow:
    mov  ax, [bp][leaf]
    cmp  ax, 3
    jnz  notLast
    sub  ax, ax
    mov  [bp][leaf], ax
    sub  di, 6000H-90
    jmp  gotRow
notLast:
    inc  ax
    mov  [bp][leaf], ax
    add  di, 2000H
gotRow:
    dec  word [bp][rows]
    ret  0

__setBlock:

    cmp  cx, 0FF00H
    jnz  op15
    mov  cx, [bp][len]
op10:
    push cx
    push di
rep ; movsb
    pop  di
    pop  cx
    call incRow
    jnz  op10
    jmp  near setExit

op15:
    not  ch
    mov  dx, 0FF00H
    ror  dx, cl
    mov  bx, [bp][len]
    dec  bx
op16:
    push di
    or   bx, bx
    jz   op18
    push bx
op17:
    and  es:[di], dx
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  op17
    pop  bx
op18:
    mov  al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    pop  di
    call incRow
    jnz  op16
    jmp  near setExit

__XORBlock:
    mov  bx, [bp][len]
op20:
    push di
    push bx
op21:
    lodsb
    sub  ah, ah
    ror  ax, cl
    xor  es:[di], ax
    inc  di
    dec  bx
    jnz  op21
    pop  bx
    pop  di
    call incRow
    jnz  op20
    jmp  near setExit

__ANDBlock:

    not  ch
    mov  bx, [bp][len]
    dec  bx
op30:
    push di
    or   bx, bx
    jz   op32
    push bx
op31:
    lodsb
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    inc  di
    dec  bx
    jnz  op31
    pop  bx
op32:
    lodsb
    or   al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    pop  di
    call incRow
    jnz  op30
    jmp  near setExit

__ORBlock:
    mov  bx, [bp][len]
op40:
    push di
    push bx
op41:
    lodsb
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  op41
    pop  bx
    pop  di
    call incRow
    jnz  op40
    jmp  near setExit


__reverseBlock:

    cmp  cx, 0FF00H
    jnz  op55
    mov  cx, [bp][len]
op50:
    push cx
    push di
revLoop1:
    lodsb
    not  al
    stosb
    loop revLoop1
    pop  di
    pop  cx
    call incRow
    jnz  op50
    jmp  near setExit

op55:
    not  ch
    mov  dx, 0FF00H
    ror  dx, cl
    mov  bx, [bp][len]
    dec  bx
op56:
    push di
    or   bx, bx
    jz   op58
    push bx
op57:
    and  es:[di], dx
    lodsb
    not  al
    sub  ah, ah
    ror  ax, cl
    or   es:[di], ax
    inc  di
    dec  bx
    jnz  op57
    pop  bx
op58:
    mov  al, ch
    mov  ah, 0FFH
    ror  ax, cl
    and  es:[di], ax
    not  ax
    mov  [bp][lastMask], ax
    lodsb
    sub  ah, ah
    not  al
    ror  ax, cl
    and ax, [bp][lastMask]
    or   es:[di], ax
    pop  di
    call incRow
    jnz  op56
    jmp  near setExit


(*
void HercPut(short x1, y1, unsigned char *buffer, short action);
*)

public __HercPut :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  ax, [bp][action]
    or  ax, ax
    jnz  op2
op1:
    mov  word [bp][bitOp], __ORBlock
    jmp  gotOp
op2:
    dec  ax
    jnz  op3
    mov  word [bp][bitOp], __ANDBlock
    jmp  gotOp
op3:
    dec  ax
    jnz  op4
    mov  word [bp][bitOp], __reverseBlock
    jmp  gotOp
op4:
    dec  ax
    jnz  op5
    mov  word [bp][bitOp], __setBlock
    jmp  gotOp
op5:
    mov  word [bp][bitOp], __XORBlock
gotOp:
    mov  ax, [bp][y1]
    mov  bx, [bp][x1]
    call __pixeladdrHerc
    xor  cl, 7
    mov  di, bx
    cmp  di, 2000H
    jb   interleave1
    cmp  di, 4000H
    jb   interleave2
    cmp  di, 6000H
    jb   interleave3
interleave4:
    mov  bx, 3H
    jmp  gotInterleave
interleave3:
    mov  bx, 2H
    jmp  gotInterleave
interleave2:
    mov  bx, 1H
    jmp  gotInterleave
interleave1:
    mov  bx, 0H
gotInterleave:
    mov  [bp][leaf], bx
    lds  si, [bp][buffer]
    lodsw
    mov  [bp][rows], ax
    lodsb
    sub  ah, ah
    mov  [bp][len], ax
    lodsb
    mov  ch, al
    mov  bx, [bp][len]
    jmp  [bp][bitOp]
setExit:
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

select _DATA

extrn __active_page
extrn __page_size
extrn __bkcolor

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __clear_Herc :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push di
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  ax, [__active_page]
    mul  word [__page_size]
(*%T _XTD *)
    db   0C1H,0F8H,004H                (*I shl  ax, 4 *)
    mov  di, ax
    extrn __B000h
    mov  ax, __B000h
(*%E *)
(*%F _XTD *)
    add  ax, 0B000H
    sub  di, di
(*%E *)
    mov  es, ax
    mov  ax, [__bkcolor]
    jz   black
    mov  ax, 0FFFFH
black:
    mov  cx, 4000H
    rep; stosw
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

select _DATA

extrn __fgcolor
extrn __bkcolor
extrn __display_state
extrn __active_page
extrn __txcolor
extrn __current_video

extrn __HercPut
extrn __current_text
__GPSET     = 3
__GPRESET   = 2
__GPAND     = 1
__GPOR      = 0
__GPXOR     = 4
__RHUNDLIN  = 8

mode          = 14       (* current video mode *)
_HERCMONO     =  8       (* 720 x 348, BW for HGC *)

(*  Buffer for character shape in putimage format for hercules *)
__PixRows       : dw 12       (* pixel rows per char - 12 vertical **)
__BytsPerRow    : db 1        (* 8 bit wide chars **)
__FinalMask     : db 0FFH     (* All bits matter **)
                  dw 0        (* Two zero pixel rows **)
__Character     : dw 0,0,0,0  (* 8 pixel rows **)
__Underline     : db 0        (* This byte for underlining **)
                  db 0        (* 1 more zero pixel row **)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __txt_out :

chk      = frame

    push bp
    mov  bp, sp
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  ah, 9
    mov  bh, [__active_page]
    mov  al, [bp][chk]
    mov  cl, 4
    mov  bl, [__bkcolor]
    shl  bl, cl
    mov  dl, [__txcolor]
    mov  dh, dl
    and  dl, 0FH
    or   bl, dl
    test dh, 10H
    jz   outChar
    or   bl, 80H
outChar:
    cmp  word ds:[__current_video][mode], _HERCMONO
    jz   herc_text
    mov  cx, 1
    int  10H
done:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(* Obtain the character shape from the bios table at F000:FA6E**)
(* al = char to output **)
herc_text:
    push di
    push si
    (* Copy char shape from bios table into buffer **)
    mov bl, al                  (* char to output *)
    xor bh, bh
    push ds
    mov ax, ds
    mov es, ax
(*%F _XTD *)
    mov ax, 0F000H              (* bios segment *)
(*%E *)
(*%T _XTD *)
    extrn __F000h
    mov ax, __F000h
(*%E *)
    mov ds, ax
    mov ax, 0FA6EH              (* char table starting offset *)
    mov cl, 3
    shl bx, cl                  (* char code * 8 (8 bytes in table/char) *)
    add ax, bx                  (* offset of char in table *)
    mov si, ax                  (* ds:si is char loc in bios **)
    mov di, __Character         (* address of dest. down here **)
    lodsw
    stosw
    lodsw
    stosw
    lodsw
    stosw
    lodsw
    stosw
    xor al, al                  (* Assume no underline *)
    xor dh, dh                  (* dx is foreground 'colour' *)
    mov cx, dx
    and cl, 07H
    and dl, 08H                 (* dx is underline bit **)
    jz normal
    not al
normal:
    stosb
    pop ds

(* Now call HercPut to load the character shape onto the screen RAM **)

    push cx
    push ds                     (* buffer *)
    mov cx, __PixRows
    push cx
    mov al, [__current_text]    (* convert row to y pixels *)
    xor ah, ah
    shl ax, 1
    shl ax, 1
    mov bx, ax
    shl ax, 1
    add ax, bx                  (* row * 12 *)
    push ax
    mov al, [__current_text][2] (* convert col to x pixels *)
    xor ah, ah
    mov cl, 3
    shl ax, cl
    push ax
(*%F NearCall *)
    call far __HercPut
(*%E *)
(*%T NearCall *)
    call __HercPut
(*%E *)
    add sp, 0AH
    pop si
    pop di
    jmp done

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

select _DATA

extrn __fgcolor
extrn __bkcolor
extrn __display_state
extrn __active_page
extrn __txcolor

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


public __gcur :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push ax
    mov  ah, 2
    mov  bh, dl
    mov  dl, cl
    mov  dh, bl
    int  10H
    pop  bx
    or   bl, 80H
    mov  ah, 9
    mov  al, 219
outChar:
    mov  cx, 1
    int  10H
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

select _DATA

extrn __defaultmode

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


public __setbiosmode :

mode     = frame

    push  bp
    mov   bp, sp
    mov   ax, [bp][mode]
    mov   ah, 0H
    int   10H
    pop   bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
