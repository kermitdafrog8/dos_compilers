(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __hclip
extrn __pixeladdr320x200
select _DATA

select _DATA

PropPix: db 0, 55H, 0AAH, 0FFH

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


x1     = -2
y1     = -4
x2     = -6
color  = -8
locals =  8

public __CGA320HLine :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
(*%F SameDS *)
