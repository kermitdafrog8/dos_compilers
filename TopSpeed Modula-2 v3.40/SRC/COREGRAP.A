section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


public __change_screen_background :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push di
    push si
    push ds
    mov  es, bx
    mov  ds, bx
    mov  di, ax
    mov  si, ax
    shl  dl, 1
    shl  dl, 1
    shl  dl, 1
    shl  dl, 1
changeLoop:
    lodsw
    and  ah, 0FH
    or   ah, dl
    stosw
    loop changeLoop
    pop  ds
    pop  si
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(****************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __FindPS2
extrn __FindEGA
extrn __FindCGA
extrn __FindMono

select _DATA

public  __TestSequence: db      0            (* this list of flags and addresses *)
                        dw      __FindPS2    (* determines the order in which this *)
                                             (* program looks for the various *)    (* subsystems *)
public  __EGAflag :     db      0
                        dw      __FindEGA

public __CGAflag :      db      0
                        dw      __FindCGA

public __Monoflag :     db      0
                        dw      __FindMono

(****************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

select _DATA

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

(*             TYPE
                 VIDstruct = RECORD
                               VideoSubsystem0 : SHORTCARD
                               Display0        : SHORTCARD
                               VideoSubsystem1 : SHORTCARD
                               Display1        : SHORTCARD
                             END

               PROCEDURE VideoID(VAR vs: VIDstruct)

               Subsystem ID values:
                               0 = (none)
                               1 = MDA
                               2 = CGA
                               3 = EGA
                               4 = MCGA
                               5 = VGA
                             80h = HGC
                             81h = HGC+
                             82h = Hercules InColor


               Display types:  0 = (none)
                               1 = MDA-compatible monochrome
                               2 = CGA-compatible color
                               3 = EGA-compatible color
                               4 = PS/2-compatible monochrome
                               5 = PS/2-compatible color


       The values returned in VIDstruct[0].VideoSubsystem and
       VIDstruct[0].Display indicate the currently active subsystem.
*)

Video0Type   = 0               (* first subsytem type *)
Display0Type = 1               (* display attached to first subsystem *)
Video1Type   = 2               (* second subsystem type *)
Display1Type = 3               (* display attached to second subsystem *)

Device0      = 0
Device1      = 2

MDA      =  1
CGA      =  2
EGA      =  3
MCGA     =  4
VGA      =  5
HGC      = 80H
HGCPlus  = 81H
InColor  = 82H

MDADisplay      =   1
CGADisplay      =   2
EGAColorDisplay =   3
PS2MonoDisplay  =   4
PS2ColorDisplay =   5

TRUE            =   1
FALSE           =   0

select _DATA

extrn __Monoflag
extrn __EGAflag
extrn __CGAflag
extrn __TestSequence

EGADisplays :   db      CGADisplay      (* 0000b, 0001b  (EGA switch values) *)
                db      EGAColorDisplay (* 0010b, 0011b *)
                db      MDADisplay      (* 0100b, 0101b *)
                db      CGADisplay      (* 0110b, 0111b *)
                db      EGAColorDisplay (* 1000b, 1001b *)
                db      MDADisplay      (* 1010b, 1011b *)

DCCtable :      db      0,0             (* translate table for INT 10H func 1AH *)
                db      MDA,MDADisplay
                db      CGA,CGADisplay
                db      0,0
                db      EGA,EGAColorDisplay
                db      EGA,MDADisplay
                db      0,0
                db      VGA,PS2MonoDisplay
                db      VGA,PS2ColorDisplay
                db      0,0
                db      MCGA,EGAColorDisplay
                db      MCGA,PS2MonoDisplay
                db      MCGA,PS2ColorDisplay


NumberOfTests   = 4

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

(*
 __FindPS2

       This subroutine uses INT 10H function 1AH to determine the video BIOS
       Display Combination Code (DCC) for each video subsystem present.
*)

public __FindPS2 :

    mov  ax, 1A00H
    int  10H          (* call video BIOS for info *)
    cmp  al, 1AH      (* exit if function not supported (i.e., *)
    jne  L13          (* no MCGA or VGA in system) *)

(* convert BIOS DCCs into specific subsystems & displays *)

    mov  cx, bx
    xor  bh, bh       (* BX := DCC for active subsystem *)
    or   ch, ch
    jz   L11          (* jump if only one subsystem present *)

    mov  bl, ch       (* BX := inactive DCC *)
    add  bx, bx
    mov  ax, [bx][DCCtable]

    mov  es:[di][Device1], ax
    mov  bl, cl
    xor  bh, bh       (* BX := active DCC *)
L11:
    add  bx, bx
    mov  ax, [bx][DCCtable]
    mov  es:[di][Device0], ax

(* reset flags for subsystems that have been ruled out *)

    mov  byte [__CGAflag], FALSE
    mov  byte [__EGAflag], FALSE
    mov  byte [__Monoflag], FALSE

    lea  bx, [Video0Type][di]      (* if the BIOS reported an MDA ... *)
    cmp  byte es:[bx], MDA
    je   L12
    lea  bx, [Video1Type][di]      (* if the BIOS reported an MDA ... *)
    cmp  byte es:[bx], MDA
    jne  L13
L12:
    mov  word es:[bx], 0           (* ..... Hercules can't be ruled out *)
    mov  byte [__Monoflag], TRUE
L13:
    ret  0

(* Look for an EGA. This is done by making a call to an EGA BIOS function
   which doesn't exist in the default (MDA, CGA) BIOS.
*)

public __FindEGA :              (* Caller:       AH = flags           *)
                                (* Returns:      AH = flags           *)
                                (*               Video0Type and       *)
                                (*               Display0Type updated *)

    mov  bl, 10H                (* BL := 10H (return EGA info) *)
    mov  ah, 12H
    int  10H                    (* call EGA BIOS for info *)
                                (* if EGA BIOS is present *)
                                (* BL <> 10H              *)
                                (* CL = switch setting    *)
    cmp  bl,10H
    je   L22                    (* jump if EGA BIOS not present *)
    mov  al, cl
    shr  al, 1                  (* AL := switches/2 *)
    mov  bx, EGADisplays
    xlat                        (* determine display type from switches *)
    mov  ah, al                 (* AH := display type *)
    mov  al, EGA                (* AL := subsystem type *)
    call FoundDevice
    cmp  ah, MDADisplay
    je   L21                    (* jump if EGA has a monochrome display *)
    mov  byte [__CGAflag], FALSE(* no CGA if EGA has color display *)
    jmp  L22
L21:
    mov  byte [__Monoflag], FALSE (* EGA has a mono display, so MDA and *)
                                (* Hercules are ruled out *)
L22:
    ret  0


(*  This is done by looking for the CGA's 6845 CRTC at I/O port 3D4H *)

public  __FindCGA :            (* Returns:      VIDstruct updated *)

    mov  dx, 3D4H               (* DX := CRTC address port *)
    call __Find6845
    jc   L31                    (* jump if not present *)
    mov  al, CGA
    mov  ah, CGADisplay
    call FoundDevice
L31:
    ret  0

(*
   __FindMono  This is done by looking for the MDA's 6845 CRTC at I/O port 3B4H.
   If a 6845 is found, the subroutine distinguishes between an MDA
   and a Hercules adapter by monitoring bit 7 of the CRT Status byte.
   This bit changes on Hercules adapters but does not change on an MDA.
   The various Hercules adapters are identified by bits 4 through 6 of
   the CRT Status value:
        000BH = HGC
        001BH = HGC+
        101BH = InColor card
*)
public __FindMono :                    (* Returns:    VIDstruct updated *)

    xor  bx, bx                        (* Clear RetraceToggle *)
    mov  dx, 003BAH                    (* Set DX := Status Port Address *)
    in   al, dx                        (* Get Status Byte *)
    and  al, 080H                      (* Mask out bits 0..6 *)
    mov  ah, al                        (* Store RdPort in AH *)
    mov  cx, 08000H                    (* Set loop count to 32767 *)
$$RdPortLoop:
    dec  cx
    jcxz $$RdPortDone
$$RdPortLoop2:
    in   al, dx                        (* Get Status Byte *)
    and  al, 080H                      (* Mask out bits 0..6 *)
    cmp  al, ah                        (* Same as last time? *)
    jz   $$RdPortLoop                  (* If So, try again *)
    in   al, dx                        (* Otherwise, update RdPort *)
    and  al, 080H
    mov  ah, al
    inc  bx                            (* Increase RetraceToggle *)
    loop $$RdPortLoop2
$$RdPortDone:
    mov  ah, MDADisplay                (* Assume MDA *)
    cmp  bx, 2                         (* Did the Retrace Toggle > twice *)
    ja   $$IsHerc                      (* If so, it's a Herc *)
    mov  al, MDA                       (* If not, it's a plain MDA *)
    jmp  $$Exit
$$IsHerc:
    in   al, dx                        (* Get the Status Byte *)
    and  al, 70H                       (* Mask out bits 0..3 *)
    cmp  al, 10H                       (* Is it a HGC+ ? *)
    jnz  $$NotPlus                     (* If not, keep looking *)
    mov  al, HGCPlus                   (* If so, tell the world *)
    jmp  $$Exit
$$NotPlus:
    cmp  al, 50H                       (* Is it an InColor Card *)
    jnz  $$PlainHGC                    (* If not, keep looking *)
    mov  ah, EGAColorDisplay           (* InColor is EGA compatible *)
    mov  al, InColor                   (* Shout it loud *)
    jmp  $$Exit
$$PlainHGC:
    mov  al, HGC                       (* It must be a plain HGC *)
$$Exit:
    call FoundDevice                   (* update VideoConfig *)
    ret  0                             (* Go Home *)

(*
   __Find6845  This routine detects the presence of the CRTC on an MDA,CGA, or
   HGC. The technique is to write and read register 0FH of the chip (Cursor
   Location low). If the same value is read as written, assume the chip
  is present at the specified port address.
*)

__Find6845 :

                                (* Caller:       DX = port addr *)
                                (* Returns:      cf set if not present *)
    mov  al, 0FH
    out  byte dx, al            (* select 6845 reg 0FH (Cursor Low) *)
    inc  dx

    in   al, dx                 (* AL := current Cursor Low value *)
    mov  ah, al                 (* preserve in AH *)
    mov  al, 66H                (* AL := arbritrary value *)
    out  byte dx, al            (* try to write to 6845 *)
    mov  cx, 8000H
L51:
    loop L51                    (* wait for 6845 to respond *)
    in   al, dx
    xchg ah, al                 (* AH := returned value *)
                                (* AL := original value *)
    out  byte dx, al            (* restore original value *)
    cmp  ah, 66H                (* test whether 6845 responded *)
    je   L52                    (* jump if it did cf is reset *)
    stc                         (* set carry flag if no 6845 present *)
    ret  0
L52:
    clc
    ret  0

__FindHercMode:

    mov  ax, 0F00H
    int  10H
    cmp  al, 7
    jne  noMono
    clc
    ret  0
noMono:
    stc
    ret 0


(* __FindActive This subroutine stores the currently active device as Device0.
   The current video mode determines which subsystem is active.
*)

__FindActive :

    cmp  word es:[di][Device1], 0
    je   L63                             (* exit if only one subsystem *)
    cmp  byte es:[Video0Type][di], 4     (* exit if MCGA or VGA present *)
    jge  L63                             (* INT 10H function 1AH *)
    cmp  byte es:[Video1Type][di], 4     (* already did the work *)
    jge  L63
    mov  ah, 0FH
    int  10H                             (* AL := current BIOS video mode *)
    and  al, 7
    cmp  al, 7                           (* jump if monochrome *)
    je   L61                             (* (mode 7 or 0FH) *)
    cmp  byte es:[Display0Type][di], MDADisplay
L61:
    jne  L63                             (* exit if Display0 is monochrome *)
L62:
    mov  ax, es:[di][Device0]            (* make Device0 currently active *)
    xchg ax, es:[di][Device1]
    mov  es:[di][Device0], ax
L63:
    ret  0

(*
   FoundDevice This routine updates the list of subsystems
*)

FoundDevice :
                                             (* Caller:   AH = display #   *)
                                             (*           AL = subsystem # *)
                                             (* Destroys: BX *)

    lea  bx, es:[Video0Type][di]
    cmp  byte es:[bx], 0
    je   L71                                 (* jump if 1st subsystem *)
    lea  bx, es:[Video1Type][di]             (* must be 2nd subsystem *)
L71:
    mov  es:[bx], ax                         (* update list entry *)
    ret  0


(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __getsystem :

(*  void _getsystem(VIDstruct *vid) *)

ARGpVID  = frame
    push bp
    mov  bp,sp
    push si
    push di
(*%F SameDS *)
    push ds
    mov  cx, _DATA
    mov  ds, cx
(*%E *)
(* initialize the data structure that will contain the results *)

(*%F NearPtr *)
    les  di, [bp][ARGpVID]              (* ES:DI -> start of data structure *)
(*%E *)
(*%T NearPtr *)
    mov  di, ds
    mov  es, di
    mov  di, [bp][ARGpVID]              (* ES:DI -> start of data structure *)
(*%E *)
    mov  word es:[di][Device0], 0       (* zero these variables *)
    mov  word es:[di][Device1], 0

(* look for various subsystems using the subroutines whose addresses are *)
(* tabulated in TestSequence; each subroutine sets flags in TestSequence *)
(* to indicate whether subsequent subroutines need to be called *)

    mov  byte [__CGAflag], TRUE
    mov  byte [__EGAflag], TRUE
    mov  byte [__Monoflag], TRUE
    mov  byte [__TestSequence], TRUE
    mov  cx, NumberOfTests
    mov  si, __TestSequence
L01:
    lodsb                           (* AL = flag *)
    test al,al
    lodsw                           (* AX = subroutine address *)
    jz   L02                        (* skip subroutine if flag is false *)
    push si
    push cx
    call ax                         (* call subroutine to detect subsystem *)
    pop  cx
    pop  si
L02:
    loop L01

(* determine which subsystem is active *)

    call __FindActive
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  di          (* restore caller registers and return *)
    pop  si
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __getmemory :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    mov  ah, 12H
    mov  bl, 10H
    int  10H
    mov  al, 64
    inc  bl
    mov  dl, bl
    mul  dl
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __clear_blink :

    mov  ax, 1003H
    mov  bl, 0H
    int  10H
    ret  0

(******************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __gr_abs_value :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    test ah, 80H
    jz  absRet
    neg ax
absRet:
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret far 0
(*%E *)
(*%T NearCall *)
    ret 0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __gdummy :             (* default null procedure for function pointers *)

(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)
(*
void _setcur(short row, short col, short page);
*)

public __setcur :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    mov  dh, al
    mov  dl, bl
    mov  bh, cl
    mov  ah, 2
    int  10H
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*************************************************************************)

numxpixels     = 0       (* number of pixels on X axis *)
numypixels     = 2       (* number of pixels on Y axis *)
numtextcols    = 4       (* number of text columns available *)
numtextrows    = 6       (* number of text rows available *)
numcolors      = 8       (* number of actual colors *)
bitsperpixel   = 10      (* number of bits per pixel *)
numvideopages  = 12      (* number of available video pages *)
mode           = 14      (* current video mode *)
adapter        = 16      (* active display adapter *)
monitor        = 18      (* active display monitor *)
memory         = 20      (* adapter video memory in K bytes *)

_DEFAULTMODE  =  -1      (* restore screen to original mode *)
_TEXTBW40     =  0       (* 40 x 25 text, 16 grey *)
_TEXTC40      =  1       (* 40 x 25 text, 16/8 color *)
_TEXTBW80     =  2       (* 80 x 25 text, 16 grey *)
_TEXTC80      =  3       (* 80 x 25 text, 16/8 color *)
_MRES4COLOR   =  4       (* 320 x 200, 4 color *)
_MRESNOCOLOR  =  5       (* 320 x 200, 4 grey *)
_HRESBW       =  6       (* 640 x 200, BW *)
_TEXTMONO     =  7       (* 80 x 25 text, BW *)
_HERCMONO     =  8       (* 720 x 348, BW for HGC *)
_MRES16COLOR  =  13      (* 320 x 200, 16 color *)
_HRES16COLOR  =  14      (* 640 x 200, 16 color *)
_ERESNOCOLOR  =  15      (* 640 x 350, BW *)
_ERESCOLOR    =  16      (* 640 x 350, 4 or 16 color *)
_VRES2COLOR   =  17      (* 640 x 480, BW *)
_VRES16COLOR  =  18      (* 640 x 480, 16 color *)
_MRES256COLOR =  19      (* 320 x 200, 256 color *)

extrn __current_video
extrn __clear_blink

public __resetEGA :


    mov  ax, _DATA
    mov  es, ax
    cmp  word es:[__current_video][mode], _VRES2COLOR
    jnz  notVres
    mov  cx, 1
    jmp  ccDone
notVres:
    cmp  word es:[__current_video][mode], _ERESNOCOLOR
    jnz  notEres
    mov  cx, 5
    jmp  ccDone
notEres:
    mov  cx, 0FH;
ccDone:
    mov  al, 2
    mov  dx, 3CEH
    out  byte dx, al
    mov  al, 0FH
    inc  dx
    out  byte dx, al
    mov  al, 1
    dec  dx
    out  byte dx, al
    sub  al, al
    inc  dx
    out  byte dx, al
    mov  al, 2
    dec  dx
    out  byte dx, al
    sub  al, al
    inc  dx
    out  byte dx, al
    mov  al, 3
    dec  dx
    out  byte dx, al
    sub  al, al
    inc  dx
    out  byte dx, al
    mov  al, 8
    dec  dx
    out  byte dx, al
    mov  al, 0FFH
    inc  dx
    out  byte dx, al
    mov  al, 7
    dec  dx
    out  byte dx, al
    mov  al, cl
    inc  dx
    out  byte dx, al
    mov  al, 5
    dec  dx
    out  byte dx, al
    sub  al, al
    inc  dx
    out  byte dx, al
    mov  al, 2
    mov  dx, 3C4H
    out  byte dx, al
    mov  al, 0FH
    inc  dx
    out  byte dx, al
    call __clear_blink

(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

public __setbc :

    mov  ah, 0BH
    sub  bx, bx
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

public __setr10 :

    mov  ax, 1010H
    mov  bx, 10H
    sub  cx, cx
    sub  dx, dx
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(***************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)


(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


public __gmemcpy :

(*
void *_gmemcpy(void *dest, void *source, unsigned num)

Copies num bytes from source to dest (Does not handle any overlap).
Returns destination address.
*)

num  = bxframe

    mov  es, bx
    mov  bx, sp
    mov  bx, ss:[bx][num]
    push di
    push si
    push ds
    mov  ds, dx
    mov  si, cx
    mov  di, ax
    mov  cx, bx
    jcxz noMove
    test al, 1
    jz   evenAdd                       (* word align *)
    movsb
    dec  cx
evenAdd:
    shr  cx, 1
    rep; movsw                         (* move words *)
    adc  cx, cx
    rep; movsb                         (* move odd byte *)
noMove:
    mov  dx, es
    pop  ds
    pop  si
    pop  di
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

(****************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __gmemset :

(*
void *_gmemset(void *s, char c, unsigned num)

Sets num bytes to c.
Returns buffer address.
*)

    push di
    mov  es, bx
    mov  di, ax
    mov  al, cl
    mov  cx, dx
    mov  dx, di
    jcxz noMove
    mov  ah, al
    test di, 1
    jz   evenAdd
    stosb              (* word align *)
    dec  cx
evenAdd:
    shr  cx, 1
rep  ; stosw           (* move words *)
    adc  cx, cx
rep  ; stosb           (* move odd byte *)
noMove:
    mov  ax, dx
    mov  dx, es        (* return buffer address *)
    pop  di
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(***************************************************************************)
section
(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __gmemwset :

(*
void *memwset(void *s, char c, unsigned num)

Sets num words to c.
Returns buffer address.
*)

    push di
    mov  es, bx
    mov  di, ax
    mov  ax, cx
    mov  cx, dx
    mov  dx, di
rep ;  stosw
    mov  ax, dx
    mov  dx, es             (* return buffer address *)
    pop  di
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
segment _DATA(DATA, 28H)
segment _TEXT(CODE,28H)

extrn __setvideomode
extrn __setvideomode_vector
extrn __display_state
extrn __mode_changed

select _TEXT

public __restore_mode :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
(*%F SameDS *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    cmp  byte [__display_state], 0
    jz   dontReset
    cmp  byte [__mode_changed], 0
    jz   dontReset
    mov  ax, -1
(*%F RegParam *)
    push ax
(*%E *)
(*%F _DLL *)
    call far __setvideomode
(*%E *)
(*%T _DLL *)
    call far [__setvideomode_vector]
(*%E *)
(*%F RegParam *)
    pop  ax
(*%E *)
dontReset:
(*%F SameDS *)
    pop  ds
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)
section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)
segment _INIT(INIT_CODE,28H)


extrn __initgraph
extrn __initgraph_vector
extrn __exitgraph
extrn __restore_mode

(*%T _DLLOVL *)

select _DATA

RestAdr: dd __restore_mode

(*%E *)

select  _TEXT
do_initgraph : (* defined later on ! *)

select _INIT
(*%F NearCall *)
initgraph : dw MAGIC_NUM
            db PR4
            dd do_initgraph
(*%E *)
(*%T NearCall *)
initgraph : dw MAGIC_NUM
            db PR4
            dw do_initgraph
(*%E *)

select _DATA
public __defaultmode :  dw  initgraph, 0

select  _TEXT

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push ds
    mov  ax, _DATA
    mov  ds, ax
(*%F _DLL *)
    call far __initgraph
(*%E *)
(*%T _DLL *)
    cmp  word [__initgraph_vector], 0
    jz   noInit
    call far [__initgraph_vector]
(*%E *)
(*%F _DLLOVL *)
    mov  word [__exitgraph], __restore_mode
(*%F NearCall *)
    mov  word [__exitgraph][2], cs
(*%E *)
(*%E *)
(*%T _DLLOVL *)
    mov  ax, [RestAdr]
    mov  word [__exitgraph], ax
    mov  ax, [RestAdr][2]
    mov  word [__exitgraph][2], ax
(*%E *)
noInit:
    pop  ds
(*%F NearCall *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*%E *)

(****************************************************************************)
(*%T _DLL *)
section

segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

extrn __setvideomode_vector
extrn __initgraph_vector

public __set_initgraph_vector :

    push  bp
    mov   bp, sp
    push ds
    push di
    mov  di, _DATA
    mov  ds, di
    mov  [__setvideomode_vector][2], dx
    mov  [__setvideomode_vector], cx
    mov  [__initgraph_vector][2], bx
    mov  [__initgraph_vector], ax
    pop  di
    pop  ds
    pop  bp
    ret  far 0
(*%E *)



end