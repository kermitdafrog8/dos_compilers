public __CGA640leftscan :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push di
    push si
    push ds
    std
    mov  si, ax               (* ptr *)
(*%T _XTD *)
    extrn __B800h
    mov  ax, __B800h
(*%E *)
(*%F _XTD *)
    mov  ax, 0B800H
(*%E *)
    mov  ds, ax
    mov  di, dx               (* left *)
    mov  ax, dx
    mov  dx, cx               (* limit *)
    mov  cx, 7
    and  ax, cx
    sub  cx, ax
    lodsb
L640LscanLoop:
    dec  di
    inc  cl
    cmp  cl, 8
    jnz  L640LnoLoad
    sub  cl, cl
    lodsb
L640LnoLoad:
    mov  ah, 1
    shl  ah, cl
    and  ah, al
    shr  ah, cl
    cmp  ah, bl
    jz   L640LscanDone
    cmp  di, dx
