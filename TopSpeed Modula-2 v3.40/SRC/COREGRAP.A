(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


public __getvideomode :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    mov  ah, 0FH
    int  10H
    sub  ah, ah
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
