section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdr640x200
extrn __lclip

select _DATA

extrn __fgcolor

L640x1      : dw 0
L640y1      : dw 0
L640x2      : dw 0
L640y2      : dw 0
L640inc1    : dw 0
L640inc2    : dw 0
L640leafinc : dw 0
L640draw    : dw 0
L640lstyle  : dw 0
L640buffer  : dw 0

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

L640verticalLine:
    mov  ax, [L640y1]
    mov  bx, [L640y2]
    mov  cx, bx
    sub  cx, ax
    jge  L640dyPos
    neg  cx
    mov  ax, bx
L640dyPos:
    inc  cx
    mov  bx, [L640x1]
    push cx
    call __pixeladdr640x200
    mov  al, [__fgcolor]
    shl  ax, cl
    not  ah
    pop  cx
    test bx, si
    jz   L640int1
    xchg si, di
L640int1:
    or   al, al
    jz   L640pixVal0
L640vertLoop:
    test bp, [L640lstyle]
    jz   L640noStore1
    or   es:[bx], al
L640noStore1:
    rol  bp, 1
    add  bx, si
    xchg si, di
    loop L640vertLoop
    jmp  near L640lineExit
L640pixVal0:
    test bp, [L640lstyle]
    jz   L640noStore2
    and  es:[bx], ah
L640noStore2:
    rol  bp, 1
    add  bx, si
    xchg si, di
    loop L640pixVal0
    jmp  near L640lineExit

L640horizLine:
    mov  ax, [L640y1]
    mov  bx, [L640x1]
    call __pixeladdr640x200
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    mov  cx, [L640x2]
    sub  cx, [L640x1]
    inc  cx
    mov  di, [L640lstyle]
    mov  si, -1
L640horizSlope:
    mov  ah, es:[bx]
L640horizLoop:
    and  ah, dh
    test bp, di
    jz   L640noStore5
    or   ah, dl
L640noStore5:
    rol  bp, 1
    ror  dl, 1
    ror  dh, 1
    jnc  L640maskLeft5
    loop L640horizLoop
    mov  es:[bx], ah
    jmp  near L640lineExit
L640maskLeft5:
    mov  es:[bx], ah
    inc  bx
    dec  cx
    or   si, si
    js   notYet
    mov  [si][L640buffer], ah
notYet:
    cmp  si, 1
    jz  storeBytes
    inc  si
notEnough:
    jcxz near L640lineExit
    jmp L640horizSlope

storeBytes:
    mov  si, cx
    and  si, 7
    push si
    shr  cx, 1
    shr  cx, 1
    shr  cx, 1
    jcxz abort
    sub  si, si
sbLoop:
    mov  ah, [si][L640buffer]
    mov  es:[bx], ah
    inc  si
    inc  bx
    and  si, 2
    loop sbLoop
abort:
    pop  cx
    jmp  notEnough

L640lowSlope:
    mov  ah, es:[bx]
L640lowLoop:
    and  ah, dh
    test bp, [L640lstyle]
    jz   L640noStore3
    or   ah, dl
L640noStore3:
    rol  bp, 1
    ror  dl, 1
    ror  dh, 1
    jnc  L640maskLeft
    or   di, di
    jns  L640dPos
    add  di, [L640inc1]
    loop L640lowLoop
    mov  es:[bx], ah
    jmp  L640lineExit
L640dPos:
    add  di, [L640inc2]
    mov  es:[bx], ah
    add  bx, si
    xchg si, [L640leafinc]
    loop L640lowSlope
    jmp  L640lineExit
L640maskLeft:
    mov  es:[bx], ah
    inc  bx
    or   di, di
    jns  L640dPos2
    add  di, [L640inc1]
    loop L640lowSlope
    jmp  L640lineExit
L640dPos2:
    add  di, [L640inc2]
    add  bx, si
    xchg si, [L640leafinc]
    loop L640lowSlope
    jmp  L640lineExit

L640highSlope:
    and  es:[bx], dh
    test bp, [L640lstyle]
    jz   L640noStore4
    or   es:[bx], dl
L640noStore4:
    rol  bp, 1
    add  bx, si
    xchg si, [L640leafinc]
    or   di, di
    jns  L640dPos3
    add  di, [L640inc1]
    loop L640highSlope
    jmp  L640lineExit
L640dPos3:
    add  di, [L640inc2]
    ror  dl ,1
    ror  dh, 1
    cmc
    adc  bx, 0
    loop L640highSlope

L640lineExit:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __CGA640Line :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   L640lineExit
    mov  [L640x1], ax
    mov  [L640y1], bx
    mov  [L640x2], cx
    mov  [L640y2], dx
    mov  cx, [bp][frame]
    mov  [L640lstyle], cx
    mov  cx, ax
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  si, 2000H
    mov  di, 80-2000H
    mov  cx, [L640x2]
    sub  cx, ax
    jz   L640verticalLine
    mov  bx, [L640y2]
    sub  bx, [L640y1]
    je   L640horizLine
    jns  L640posInc
    neg  bx
    xchg si, di
    neg  si
    neg  di
L640posInc:
    mov  [L640leafinc], di
    mov  word [L640draw], L640lowSlope
    cmp  bx, cx
    jle  L640useLowSlope
    mov  word [L640draw], L640highSlope
    xchg bx, cx
L640useLowSlope:
    shl  bx, 1
    mov  [L640inc1], bx
    sub  bx, cx
    mov  di, bx
    sub  bx, cx
    mov  [L640inc2], bx
    push cx
    mov  bx, [L640x1]
    mov  ax, [L640y1]
    call __pixeladdr640x200
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    pop  cx
    inc  cx
    test bx, 2000H
    jz   L640iLeave0
    xchg si, [L640leafinc]
L640iLeave0:
    jmp  [L640draw]

(**************************************************************************)

section
extrn __pixeladdr320x200

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __lclip

select _DATA

extrn __fgcolor

L320x1      : dw 0
L320y1      : dw 0
L320x2      : dw 0
L320y2      : dw 0
L320inc1    : dw 0
L320inc2    : dw 0
L320leafinc : dw 0
L320draw    : dw 0
L320lstyle  : dw 0
L320buffer  : dw 0, 0

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

L320verticalLine:
    mov  ax, [L320y1]
    mov  bx, [L320y2]
    mov  cx, bx
    sub  cx, ax
    jge  L320dyPos
    neg  cx
    mov  ax, bx
L320dyPos:
    inc  cx
    mov  bx, [L320x1]
    push cx
    call __pixeladdr320x200
    mov  al, [__fgcolor]
    shl  ax, cl
    not  ah
    pop  cx
    test bx, si
    jz   L320vertLoop
    xchg si, di
L320vertLoop:
    and  es:[bx], ah
    test bp, [L320lstyle]
    jz   L320noStore1
    or   es:[bx], al
L320noStore1:
    rol  bp, 1
    add  bx, si
    xchg si, di
    loop L320vertLoop
    jmp  near L320lineExit

L320horizLine:
    mov  ax, [L320y1]
    mov  bx, [L320x1]
    call __pixeladdr320x200
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    mov  cx, [L320x2]
    sub  cx, [L320x1]
    inc  cx
    mov  di, [L320lstyle]
    mov  si, -1
L320horizSlope:
    mov  ah, es:[bx]
L320horizLoop:
    and  ah, dh
    test bp, di
    jz   L320noStore5
    or   ah, dl
L320noStore5:
    rol  bp, 1
    ror  dl, 1
    ror  dl, 1
    ror  dh, 1
    ror  dh, 1
    jnc  L320maskLeft5
    loop L320horizLoop
    mov  es:[bx], ah
    jmp  near L320lineExit
L320maskLeft5:
    mov  es:[bx], ah
    inc  bx
    dec  cx
    or   si, si
    js   notYet
    mov  [si][L320buffer], ah
notYet:
    cmp  si, 3
    jz  storeBytes
    inc  si
notEnough:
    jcxz near L320lineExit
    jmp L320horizSlope

storeBytes:
    mov  si, cx
    and  si, 3
    push si
    shr  cx, 1
    shr  cx, 1
    jcxz abort
    sub  si, si
sbLoop:
    mov  ah, [si][L320buffer]
    mov  es:[bx], ah
    inc  si
    inc  bx
    and  si, 3
    loop sbLoop
abort:
    pop  cx
    jmp  notEnough

L320lowSlope:
    mov  ah, es:[bx]
L320lowLoop:
    and  ah, dh
    test bp, [L320lstyle]
    jz   L320noStore3
    or   ah, dl
L320noStore3:
    rol  bp, 1
    ror  dl, 1
    ror  dl, 1
    ror  dh, 1
    ror  dh, 1
    jnc  L320maskLeft
    or   di, di
    jns  L320dPos
    add  di, [L320inc1]
    loop L320lowLoop
    mov  es:[bx], ah
    jmp  L320lineExit
L320dPos:
    add  di, [L320inc2]
    mov  es:[bx], ah
    add  bx, si
    xchg si, [L320leafinc]
    loop L320lowSlope
    jmp  L320lineExit
L320maskLeft:
    mov  es:[bx], ah
    inc  bx
    or   di, di
    jns  L320dPos2
    add  di, [L320inc1]
    loop L320lowSlope
    jmp  L320lineExit
L320dPos2:
    add  di, [L320inc2]
    add  bx, si
    xchg si, [L320leafinc]
    loop L320lowSlope
    jmp  L320lineExit

L320highSlope:
    and  es:[bx], dh
    test bp, [L320lstyle]
    jz   L320noStore4
    or   es:[bx], dl
L320noStore4:
    rol  bp, 1
    add  bx, si
    xchg si, [L320leafinc]
    or   di, di
    jns  L320dPos3
    add  di, [L320inc1]
    loop L320highSlope
    jmp  L320lineExit
L320dPos3:
    add  di, [L320inc2]
    ror  dl ,1
    ror  dl ,1
    ror  dh, 1
    ror  dh, 1
    cmc
    adc  bx, 0
    loop L320highSlope

L320lineExit:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __CGA320Line :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   L320lineExit
    mov  [L320x1], ax
    mov  [L320y1], bx
    mov  [L320x2], cx
    mov  [L320y2], dx
    mov  cx, [bp][frame]
    mov  [L320lstyle], cx
    mov  cx, ax
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  si, 2000H
    mov  di, 80-2000H
    mov  cx, [L320x2]
    sub  cx, ax
    jz   L320verticalLine
    mov  bx, [L320y2]
    sub  bx, [L320y1]
    je   L320horizLine
    jns  L320posInc
    neg  bx
    xchg si, di
    neg  si
    neg  di
L320posInc:
    mov  [L320leafinc], di
    mov  word [L320draw], L320lowSlope
    cmp  bx, cx
    jle  L320useLowSlope
    mov  word [L320draw], L320highSlope
    xchg bx, cx
L320useLowSlope:
    shl  bx, 1
    mov  [L320inc1], bx
    sub  bx, cx
    mov  di, bx
    sub  bx, cx
    mov  [L320inc2], bx
    push cx
    mov  bx, [L320x1]
    mov  ax, [L320y1]
    call __pixeladdr320x200
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    pop  cx
    inc  cx
    test bx, 2000H
    jz   L320iLeave0
    xchg si, [L320leafinc]
L320iLeave0:
    jmp  [L320draw]

(**************************************************************************)

section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __pixeladdrHerc
extrn __lclip

select _DATA

extrn __fgcolor

Hercx1      : dw 0
Hercy1      : dw 0
Hercx2      : dw 0
Hercy2      : dw 0
Hercinc1    : dw 0
Hercinc2    : dw 0
Hercleafinc : dw 0
Hercdraw    : dw 0
Herclstyle  : dw 0

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

HERCverticalLine:
    mov  ax, [Hercy1]
    mov  bx, [Hercy2]
    mov  cx, bx
    sub  cx, ax
    jge  HERCdyPos
    neg  cx
    mov  ax, bx
HERCdyPos:
    inc  cx
    mov  bx, [Hercx1]
    push cx
    call __pixeladdrHerc
    mov  al, [__fgcolor]
    shl  ax, cl
    not  ah
    pop  cx
    or   al, al
    jz   HERCpixVal0
HERCvertLoop:
    test bp, [Herclstyle]
    jz   HERCnoStore1
    or   es:[bx], al
HERCnoStore1:
    rol  bp, 1
    add  bx, si
    jns  iLeave2
    add  bx, di
iLeave2:
    loop HERCvertLoop
    jmp  near HERClineExit
HERCpixVal0:
    test bp, [Herclstyle]
    jz   HERCnoStore2
    and  es:[bx], ah
HERCnoStore2:
    rol  bp, 1
    add  bx, si
    jns  iLeave3
    add  bx, di
iLeave3:
    loop HERCpixVal0
    jmp  near HERClineExit

HERClowSlope:
    mov  ah, es:[bx]
HERClowLoop:
    and  ah, dh
    test bp, [Herclstyle]
    jz   HERCnoStore3
    or   ah, dl
HERCnoStore3:
    rol  bp, 1
    ror  dl, 1
    ror  dh, 1
    jnc  HERCmaskLeft
    or   di, di
    jns  HERCdPos
    add  di, [Hercinc1]
    loop HERClowLoop
    mov  es:[bx], ah
    jmp  HERClineExit
HERCdPos:
    add  di, [Hercinc2]
    mov  es:[bx], ah
    add  bx, si
    jns  HERCnotLastInt
    add  bx, [Hercleafinc]
HERCnotLastInt:
    loop HERClowSlope
    jmp  HERClineExit
HERCmaskLeft:
    mov  es:[bx], ah
    inc  bx
    or   di, di
    jns  HERCdPos2
    add  di, [Hercinc1]
    loop HERClowSlope
    jmp  HERClineExit
HERCdPos2:
    add  di, [Hercinc2]
    add  bx, si
    jns  HERCnotLastInt2
    add  bx, [Hercleafinc]
HERCnotLastInt2:
    loop HERClowSlope
    jmp  HERClineExit

HERChighSlope:
    and  es:[bx], dh
    test bp, [Herclstyle]
    jz   HERCnoStore4
    or   es:[bx], dl
HERCnoStore4:
    rol  bp, 1
    add  bx, si
    jns  HERCnotLastInt3
    add  bx, [Hercleafinc]
HERCnotLastInt3:
    or   di, di
    jns  HERCdPos3
    add  di, [Hercinc1]
    loop HERChighSlope
    jmp  HERClineExit
HERCdPos3:
    add  di, [Hercinc2]
    ror  dl ,1
    ror  dh, 1
    cmc
    adc  bx, 0
    loop HERChighSlope

HERClineExit:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __HercLine :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   HERClineExit
    mov  [Hercx1], ax
    mov  [Hercy1], bx
    mov  [Hercx2], cx
    mov  [Hercy2], dx
    mov  cx, [bp][frame]
    mov  [Herclstyle], cx
    mov  cx, ax
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  si, 2000H
    mov  di, 90-8000H
    mov  cx, [Hercx2]
    sub  cx, ax
    jz   HERCverticalLine
    mov  bx, [Hercy2]
    sub  bx, [Hercy1]
    jns  HERCposInc
    neg  bx
    neg  si
    neg  di
HERCposInc:
    mov  [Hercleafinc], di
    mov  word [Hercdraw], HERClowSlope
    cmp  bx, cx
    jle  HERCuseLowSlope
    mov  word [Hercdraw], HERChighSlope
    xchg bx, cx
HERCuseLowSlope:
    shl  bx, 1
    mov  [Hercinc1], bx
    sub  bx, cx
    mov  di, bx
    sub  bx, cx
    mov  [Hercinc2], bx
    push cx
    mov  bx, [Hercx1]
    mov  ax, [Hercy1]
    call __pixeladdrHerc
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    pop  cx
    inc  cx
    jmp  [Hercdraw]

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn  __pixeladdrEGA2
extrn __EGAxlat
extrn __lclip

select _DATA

extrn __fgcolor
extrn __width
extrn __EGAtranslate

EGAx1      : dw 0
EGAy1      : dw 0
EGAx2      : dw 0
EGAy2      : dw 0
EGAinc1    : dw 0
EGAinc2    : dw 0
EGAvertinc1 : dw 0
EGAdraw    : dw 0
EGAcolor   : dw 0
EGAlstyle  : dw 0
EGAmaskbit : dw 0

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

    out  byte dx, ax

EGAverticalLine:
    mov  cx, [EGAx1]
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  ax, [EGAy1]
    mov  bx, [EGAy2]
    mov  cx, bx
    sub  cx, ax
    jge  EGAdPos
    neg  cx
    mov  ax, bx
EGAdPos:
    inc  cx
    mov  bx, [EGAx1]
    push cx
    call __pixeladdrEGA2
    shl  ah, cl
    mov  al, 8
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    pop  cx
    mov  dx, [EGAlstyle]
EGAvertLoop:
    test bp, dx
    jz   EGAnoStore1
    or   byte es:[bx], 0FFH
EGAnoStore1:
    rol  bp, 1
    add  bx, si
    loop EGAvertLoop
    jmp  near EGAlineExit

EGAlowSlope:
    mov  bp, [EGAinc1]
EGAlowSlopeL:
    sub  ah, ah
EGAlowLoop:
    or   ah, bl
    ror  bl, 1
    jc   EGAmaskLeft
    or   si, si
    jns  EGAdPos1
    add  si, bp
    loop EGAlowLoop
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    jmp  near EGAlineExit
EGAdPos1:
    add  si, [EGAinc2]
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    add  di, [EGAvertinc1]
    loop EGAlowSlopeL
    jmp  near EGAlineExit
EGAmaskLeft:
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    inc  di
    or   si, si
    jns  EGAdPos2
    add  si, bp
    loop EGAlowSlopeL
    jmp  near EGAlineExit
EGAdPos2:
    add  si, [EGAinc2]
    add  di, [EGAvertinc1]
    loop EGAlowSlopeL
    jmp  near EGAlineExit

EGAlowSlopeM:
    sub  ah, ah
EGAlowLoopM:
    push ax
    mov  ax, [EGAmaskbit]
    test ax, [EGAlstyle]
    pop  ax
    jz   EGAnoStore3M
    or   ah, bl
EGAnoStore3M:
    rol  word [EGAmaskbit], 1
    ror  bl, 1
    jc   EGAmaskLeftM
    or   si, si
    jns  EGAdPos1M
    add  si, [EGAinc1]
    loop EGAlowLoopM
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    jmp  near EGAlineExit
EGAdPos1M:
    add  si, [EGAinc2]
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    add  di, [EGAvertinc1]
    loop EGAlowSlopeM
    jmp  EGAlineExit
EGAmaskLeftM:
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    inc  di
    or   si, si
    jns  EGAdPos2M
    add  si, [EGAinc1]
    loop EGAlowSlopeM
    jmp  EGAlineExit
EGAdPos2M:
    add  si, [EGAinc2]
    add  di, [EGAvertinc1]
    loop EGAlowSlopeM
    jmp  EGAlineExit


EGAhighSlope:
    mov  bp, [EGAinc1]
    mov  bx, [EGAvertinc1]
EGAhighLoop:
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
    add  di, bx
    or   si, si
    jns  EGAdPos3
    add  si, bp
    loop EGAhighLoop
    jmp  EGAlineExit
EGAdPos3:
    add  si, [EGAinc2]
    ror  ah, 1
    adc  di, 0
    loop EGAhighLoop
    jmp  EGAlineExit

EGAhighSlopeM:
    mov  bp, [EGAinc1]
    mov  bx, [EGAvertinc1]
EGAhighLoopM:
    push ax
    mov  ax, [EGAmaskbit]
    test ax, [EGAlstyle]
    pop  ax
    jz   EGAnoStore4M
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    or   byte es:[di], 0FFH
EGAnoStore4M:
    rol  word [EGAmaskbit], 1
    add  di, bx
    or   si, si
    jns  EGAdPos3M
    add  si, bp
    loop EGAhighLoopM
    jmp  EGAlineExit
EGAdPos3M:
    add  si, [EGAinc2]
    ror  ah, 1
    adc  di, 0
    loop EGAhighLoopM

EGAlineExit:
    mov  dx, 3CEH
    sub  ax, ax
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    inc  ax
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 3
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, 0FF08H
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
noDraw:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __EGALine :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   noDraw
    mov  [EGAx1], ax
    mov  [EGAy1], bx
    mov  [EGAx2], cx
    mov  [EGAy2], dx
    mov  ax, [bp][frame]
    mov  [EGAlstyle], ax
    mov  ax, [__fgcolor]
    cmp  byte [__EGAtranslate], 0
    jz   notNeeded
    call __EGAxlat
notNeeded:
    mov  [EGAcolor], ax
    mov  dx, 3CEH
    mov  ax, 5H
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ah, [EGAcolor]
    sub  al, al
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  ax, 0FF01H
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 3
    mov  ah, 0
(*%F FastIO *)
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)

    mov  si, [__width]
    mov  cx, [EGAx2]
    mov  ax, [EGAx1]
    sub  cx, ax
    jz   EGAverticalLine
    mov  bx, [EGAy2]
    sub  bx, [EGAy1]
    jns  EGAposInc
    neg  bx
    neg  si
EGAposInc:
    mov  [EGAvertinc1], si
    cmp  bx, cx
    jle  EGAuseLowSlope
    mov  bp, 1
    xchg bx, cx
    jmp  EGAgotSlope
EGAuseLowSlope:
    mov  bp, 2
EGAgotSlope:
    shl  bx, 1
    mov  [EGAinc1], bx
    sub  bx, cx
    mov  si, bx
    sub  bx, cx
    mov  [EGAinc2], bx
    push cx
    mov  bx, [EGAx1]
    mov  ax, [EGAy1]
    call __pixeladdrEGA2
    mov  di, bx
    shl  ah, cl
    mov  bl, ah
    mov  al, 8
    pop  cx
    inc  cx
    cmp  word [EGAlstyle], -1
    jne  EGAMaskSet
    cmp  bp, 1
    je   EGAhighSlope
    jmp  EGAlowSlope
EGAMaskSet:
    mov  [EGAdraw], bp
    push cx
    mov  cx, [EGAx1]
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  [EGAmaskbit], bp
    pop  cx
    cmp  byte [EGAdraw], 1
    je   EGAhighSlopeM
    jmp  EGAlowSlopeM

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn  __pixeladdrEGA2
extrn __lclip

select _DATA

extrn __fgcolor
extrn __width

EGA2x1      : dw 0
EGA2y1      : dw 0
EGA2x2      : dw 0
EGA2y2      : dw 0
EGA2inc1    : dw 0
EGA2inc2    : dw 0
EGA2draw    : dw 0
EGA2lstyle  : dw 0
propPix     : db 0, 0FFH

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

rotate:
    push cx
    push ax
    mov  cx, 1
    mov  si, 8000H
    sub  ax, ax
rotLoop:
    test bx, cx
    jz   zeroBit
    or   ax, si
zeroBit:
    shr  si, 1
    shl  cx, 1
    jc   rotDone
    jmp  rotLoop
rotDone:
    mov  bx, ax
    pop  ax
    pop  cx
    ret  0

EGA2verticalLine:
    mov  cx, [EGA2x1]
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    mov  ax, [EGA2y1]
    mov  bx, [EGA2y2]
    mov  cx, bx
    sub  cx, ax
    jge  EGA2dPos
    neg  cx
    mov  ax, bx
EGA2dPos:
    inc  cx
    mov  bx, [EGA2x1]
    push cx
    call __pixeladdrEGA2
    mov  al, [__fgcolor]
    shl  ax, cl
    not  ah
    pop  cx
    mov  dx, [EGA2lstyle]
    or   al, al
    jz   EGA2vertLoop2
EGA2vertLoop1:
    test bp, dx
    jz   EGA2noStore1
    or   es:[bx], al
EGA2noStore1:
    rol  bp, 1
    add  bx, si
    loop EGA2vertLoop1
    jmp  near EGA2lineExit
EGA2vertLoop2:
    test bp, dx
    jz   EGA2noStore2
    and  es:[bx], ah
EGA2noStore2:
    rol  bp, 1
    add  bx, si
    loop EGA2vertLoop2
    jmp  near EGA2lineExit

EGA2horiz:
    mov  ax, [EGA2y1]
    mov  bx, [EGA2x1]
    call __pixeladdrEGA2
    mov  di, bx
    mov  dh, ah
    not  dh
    mov  dl, 0FFH
    shl  dh, cl
    not  dh
    mov  cx, [EGA2x2]
    and  cl, 7
    xor  cl, 7
    shl  dl, cl
    mov  ax, [EGA2x2]
    mov  bx, [EGA2x1]
    mov  cl, 3
    shr  ax, cl
    shr  bx, cl
    mov  cx, ax
    sub  cx, bx
    mov  bx, propPix
    mov  al, [__fgcolor]
    xlat
    mov  bx, [EGA2lstyle]
    call rotate
    test di, 1
    jz   maskSetOK
    xchg bh, bl
maskSetOK:
    mov  bp, ax
    and  al, bh
    or   dh, dh
    js   fullByte
    or   cx, cx
    jnz  multiByte
    and  dl, dh
    jmp  lastByte
multiByte:
    mov  ah, al
    and  ah, dh
    not  dh
    and  es:[di], dh
    or   es:[di], ah
    inc  di
    dec  cx
fullByte:
    mov  ax, bp
    xchg bh, bl
    and  al, bh
    jcxz lastByte
    stosb
    loop fullByte
lastByte:
    and  al, dl
    not  dl
    and  es:[di], dl
    or   es:[di], al
    jmp  near EGA2lineExit


EGA2lowSlope:
    mov  bp, [EGA2inc1]
EGA2lowSlopeL:
    mov  ah, es:[bx]
EGA2lowLoop:
    and  ah, dh
    or   ah, dl
    ror  dl, 1
    ror  dh, 1
    jnc  EGA2maskLeft
    or   di, di
    jns  EGA2dPos1
    add  di, bp
    loop EGA2lowLoop
    mov  es:[bx], ah
    jmp  near EGA2lineExit
EGA2dPos1:
    add  di, [EGA2inc2]
    mov  es:[bx], ah
    add  bx, si
    loop EGA2lowSlopeL
    jmp  near EGA2lineExit
EGA2maskLeft:
    mov  es:[bx], ah
    inc  bx
    or   di, di
    jns  EGA2dPos2
    add  di, bp
    loop EGA2lowSlopeL
    jmp  near EGA2lineExit
EGA2dPos2:
    add  di, [EGA2inc2]
    add  bx, si
    loop EGA2lowSlopeL
    jmp  near EGA2lineExit

EGA2lowSlopeM:
    mov  ah, es:[bx]
EGA2lowLoopM:
    and  ah, dh
    test bp, [EGA2lstyle]
    jz   EGA2noStore3
    or   ah, dl
EGA2noStore3:
    rol  bp, 1
    ror  dl, 1
    ror  dh, 1
    jnc  EGA2maskLeftM
    or   di, di
    jns  EGA2dPos1M
    add  di, [EGA2inc1]
    loop EGA2lowLoopM
    mov  es:[bx], ah
    jmp  EGA2lineExit
EGA2dPos1M:
    add  di, [EGA2inc2]
    mov  es:[bx], ah
    add  bx, si
    loop EGA2lowSlopeM
    jmp  EGA2lineExit
EGA2maskLeftM:
    mov  es:[bx], ah
    inc  bx
    or   di, di
    jns  EGA2dPos2M
    add  di, [EGA2inc1]
    loop EGA2lowSlopeM
    jmp  EGA2lineExit
EGA2dPos2M:
    add  di, [EGA2inc2]
    add  bx, si
    loop EGA2lowSlopeM
    jmp  EGA2lineExit


EGA2highSlope:
    mov  bp, [EGA2inc1]
EGA2highSlopeL:
    and  es:[bx], dh
    or   es:[bx], dl
    add  bx, si
    or   di, di
    jns  EGA2dPos3
    add  di, bp
    loop EGA2highSlopeL
    jmp  EGA2lineExit
EGA2dPos3:
    add  di, [EGA2inc2]
    ror  dl, 1
    ror  dh, 1
    cmc
    adc  bx, 0
    loop EGA2highSlopeL
    jmp  EGA2lineExit

EGA2highSlopeM:
    and  es:[bx], dh
    test bp, [EGA2lstyle]
    jz   EGA2noStore4
    or   es:[bx], dl
EGA2noStore4:
    rol  bp, 1
    add  bx, si
    or   di, di
    jns  EGA2dPos3M
    add  di, [EGA2inc1]
    loop EGA2highSlopeM
    jmp  EGA2lineExit
EGA2dPos3M:
    add  di, [EGA2inc2]
    ror  dl, 1
    ror  dh, 1
    cmc
    adc  bx, 0
    loop EGA2highSlopeM

EGA2lineExit:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 2
(*%E *)
(*%T NearCall *)
    ret  2
(*%E *)

public __EGA2Line :

    push bp
    mov  bp, sp
    push di
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    call __lclip
    jc   EGA2lineExit
    mov  [EGA2x1], ax
    mov  [EGA2y1], bx
    mov  [EGA2x2], cx
    mov  [EGA2y2], dx
    mov  ax, [bp][frame]
    mov  [EGA2lstyle], ax
    mov  si, 80
    mov  cx, [EGA2x2]
    mov  ax, [EGA2x1]
    sub  cx, ax
    jz   EGA2verticalLine
    mov  bx, [EGA2y2]
    sub  bx, [EGA2y1]
    je   EGA2horiz
    jns  EGA2posInc
    neg  bx
    neg  si
EGA2posInc:
    cmp  bx, cx
    jle  EGA2useLowSlope
    mov  bp, 1
    xchg bx, cx
    jmp  EGA2gotSlope
EGA2useLowSlope:
    mov  bp, 2
EGA2gotSlope:
    shl  bx, 1
    mov  [EGA2inc1], bx
    sub  bx, cx
    mov  di, bx
    sub  bx, cx
    mov  [EGA2inc2], bx
    push cx
    mov  bx, [EGA2x1]
    mov  ax, [EGA2y1]
    call __pixeladdrEGA2
    mov  al, [__fgcolor]
    shl  ax, cl
    mov  dx, ax
    not  dh
    pop  cx
    inc  cx
    cmp  word [EGA2lstyle], -1
    jne  EGA2MaskSet
    cmp  bp, 1
    je   EGA2highSlope
    jmp  EGA2lowSlope
EGA2MaskSet:
    mov  [EGA2draw], bp
    push cx
    mov  cx, [EGA2x1]
    and  cl, 15
    mov  bp, 1
    shl  bp, cl
    pop  cx
    cmp  byte [EGA2draw], 1
    je   EGA2highSlopeM
    jmp  EGA2lowSlopeM

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __VGAPoint :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    mov  cx, ax
    mov  ax, 320
    mul  bx
    add  ax, cx
    mov  bx, ax
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  es, ax
    mov  al, es:[bx]
    sub  ah, ah
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)


(*
void VGAGet(unsigned char *buffer, short x1, y1, x2, y2);
*)

buffer = frame
x1     = 4+frame
y1     = 6+frame
x2     = 8+frame
y2     = 10+frame
len       = -2
incr      = -4
pixAddress= -6
byteShift = -7
locals    =  7

public __VGAGet :
    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
    les  di, [bp][buffer]
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  ds, ax
    mov  ax, [bp][y1]
    mov  dx, 320
    mul  dx
    add  ax, [bp][x1]
    mov  si, ax

    mov  ax, [bp][x2]        (* cols *)
    sub  ax, [bp][x1]
    inc  ax
    push ax
    mov  cl, 3
    shl  ax, cl
    stosw
    mov  ax, [bp][y2]        (* rows *)
    sub  ax, [bp][y1]
    inc  ax
    mov  cx, ax
    stosw
    mov  bx, 320
    pop  ax
getRowLoop:
    push cx
    mov  dx, si
    mov  cx, ax
    shr  cx, 1
rep ; movsw
    adc  cx, cx
rep ; movsb
    mov  si, dx
    add  si, bx
    pop  cx
    loop getRowLoop

    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

x1     = frame
y1     = 2+frame
buffer = 4+frame
action = 8+frame
len        = -2
incr       = -4
rows       = -6
bitOp      = -8
pixAddress = -10
locals     =  10

public __VGAPut :

    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
    lds  si, [bp][buffer]
    lodsw
    mov  [bp][len], ax
    mov  cl, 3
    shr  ax, cl
    mov  [bp][len], ax
    lodsw
    mov  [bp][rows], ax
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  es, ax
    mov  ax, [bp][y1]
    mov  dx, 320
    mul  dx
    add  ax, [bp][x1]
    mov  di, ax
    mov  ax, [bp][action]
    mov  cx, [bp][rows]
    mov  bx, 320
    or   ax, ax
    jz   __OR
    dec  ax
    or   ax, ax
    jz   __AND
    dec  ax
    or   ax, ax
    jz   __RESET
    dec  ax
    or   ax, ax
    jz   __SET
    dec  ax
    or   ax, ax
    jz   __XOR

setExit:
    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

__OR:

orRowLoop:
    push cx
    mov  dx, di
    mov  cx, [bp][len]
orColLoop:
    lodsb
    or   ax, es:[di]
    stosb
    loop orColLoop
    mov  di, dx
    add  di, bx
    pop  cx
    loop orRowLoop
    jmp  setExit

__AND:

andRowLoop:
    push cx
    mov  dx, di
    mov  cx, [bp][len]
andColLoop:
    lodsb
    and  es:[di], al
    inc  di
    loop andColLoop
    mov  di, dx
    add  di, bx
    pop  cx
    loop andRowLoop
    jmp  setExit

__RESET:

resetRowLoop:
    push cx
    mov  dx, di
    mov  cx, [bp][len]
resetColLoop:
    lodsb
    not  al
    stosb
    loop resetColLoop
    mov  di, dx
    add  di, bx
    pop  cx
    loop resetRowLoop
    jmp  setExit

__SET:

setRowLoop:
    push cx
    mov  dx, di
    mov  cx, [bp][len]
rep; movsb
    mov  di, dx
    add  di, bx
    pop  cx
    loop setRowLoop
    jmp  setExit

__XOR:

xorRowLoop:
    push cx
    mov  dx, di
    mov  cx, [bp][len]
xorColLoop:
    lodsb
    xor  es:[di], al
    inc  di
    loop xorColLoop
    mov  di, dx
    add  di, bx
    pop  cx
    loop xorRowLoop
    jmp  setExit

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn  __pixeladdrEGA

select _DATA

extrn __width
extrn __EGAPlaneShift
extrn __EGAStartPlane

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

(****Move from selector for a huge selector to the next****)
(* Input : Selector on stack *)
(* Output : Selector on stack, all regs preserved *)
(* Internal routine, always near called *)
extrn __hugeshift
public @next_seg:
   push bp
   mov bp,sp
   push ax
(*%F SameDS *)
   push ds
   mov  ax, seg __hugeshift
   mov  ds, ax
(*%E *)
   mov  ax,[__hugeshift]
   add  [bp][4],ax
(*%F SameDS *)
   pop  ds
(*%E *)
   pop ax
   pop bp
   ret 0


(*
void EGAGet(unsigned char *buffer, short x1, y1, x2, y2);
*)

buffer = frame
x1     = 4+frame
y1     = 6+frame
x2     = 8+frame
y2     = 10+frame
BytesPerRow   = -2
len           = -4
rows          = -6
EGAPlaneShift = -8
EGAStartPlane = -10
locals        =  10

ByteShift   = 3

public __EGAGet :
    push bp
    mov  bp, sp
    sub  sp, locals
    push di
    push si
    push ds
(*%F SameDS *)
    mov  ax, _DATA
    mov  ds, ax
(*%E *)
    mov  ax, [__EGAPlaneShift]
    mov  [bp][EGAPlaneShift], ax
    mov  ax, [__EGAStartPlane]
    mov  [bp][EGAStartPlane], ax
    mov  ax, [__width]
    mov  [bp][BytesPerRow], ax
    mov  ax, [bp][x2]
    sub  ax, [bp][x1]
    mov  cx, 0FF07H
    and  cl, al
    xor  cl, 7
    shl  ch, cl
    mov  cl, ch
    push cx
    mov  cl, ByteShift
    shr  ax, cl
    inc  ax
    push ax

    mov  ax, [bp][y2]
    sub  ax, [bp][y1]
    inc  ax
    push ax
                              (* setup addressing *)
    mov  ax, [bp][y1]
    mov  bx, [bp][x1]
    call __pixeladdrEGA
    xor  cl, 7
    mov  si, es
    mov  ds, si
    mov  si, bx
    les  di, [bp][buffer]
                              (* build header *)
    pop  ax
    mov  [bp][rows], ax
    stosw
    pop  ax
    mov  [bp][len], ax
    stosb
    pop  ax
    mov  ch, al
    stosb
                              (* setup controller *)
    mov  dx, 3CEH
    mov  al, 5
    out  byte dx, al
    sub  al, al
    inc  dx
    out  byte dx, al
    dec  dx
    mov  al, 4H
    out  byte dx, al
    mov  al, [bp][EGAStartPlane]
    mov  ah, [bp][EGAPlaneShift]
    inc  dx
getPlaneLoop:
    out  byte dx, al
    push ax
    push [bp][rows]
    push si
op2:
    mov  bx, [bp][len]
    push si
op3:
    lodsw
    dec  si
    rol  ax, cl
    stosb
    or   di, di
    jnz  inSeg
    push es
    call @next_seg
    pop  es
inSeg:
    dec  bx
    jnz  op3
    and  es:[di][-1], ch
    pop  si
    add  si, [bp][BytesPerRow]
    dec  word [bp][rows]
    jnz  op2
    pop  si
    pop  [bp][rows]
    pop  ax
    sub  al, ah
    jns  getPlaneLoop

    pop  ds
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)
section

(*%F NearCall *)
segment Graphics_TEXT(CODE,28H)
(*%E *)
(*%T NearCall *)
segment _TEXT(CODE,28H)
(*%E *)
segment _DATA(DATA, 28H)

extrn __EGArexlat

select _DATA

extrn __width
extrn __page_size
extrn __active_page
extrn __EGAPlaneShift
extrn __EGAStartPlane
extrn __EGA64K
extrn __EGAtranslate

(*%F NearCall *)
select Graphics_TEXT
(*%E *)
(*%T NearCall *)
select _TEXT
(*%E *)

public __EGAPoint :

(*%T _DLLOVL *)
    push  bp
    mov   bp, sp
(*%E *)
    push si
(*%F SameDS *)
    push ds
    mov  si, _DATA
    mov  ds, si
(*%E *)
    mov  cx, ax
    and  cx, 7
    mov  ch, 80H
    shr  ch, cl
    mov  cl, ch                        (* cl = mask *)
(*%T _XTD *)
    db   0C1H,0F8H,003H                (*I shr  ax, 3 *)
(*%E *)
(*%F _XTD *)
    shr  ax, 1
    shr  ax, 1
    shr  ax, 1
(*%E *)
    mov  si, ax
    mov  ax, [__width]
    mul  bx
    add  si, ax                        (* offset *)
    mov  ax, [__active_page]
    mul  word [__page_size]
(*%T _XTD *)
    db   0C1H,0E0H,004H                (*I shl  ax, 4 *)
    add  si, ax
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    add  ax, 0A000H
(*%E *)
    mov  es, ax                        (* segment *)

    mov  dx, 03CEH
    mov  ax, 5
(*%F FastIO *)
    extrn $OutWord
    call $OutWord
(*%E *)
(*%T FastIO *)
    out  word dx, ax
(*%E *)
    mov  al, 4
    out  byte dx, al
    inc  dx
    cmp  byte [__EGA64K], 0
    je   fullEGA
    mov  ax, 1
    and  ax, si
    add  ax, [__EGAStartPlane]
    jmp  gotPlane
fullEGA:
    mov  ax, [__EGAStartPlane]
gotPlane:
    mov  bl, [__EGAPlaneShift]
readLoop:
    out  byte dx, al
    mov  ch, es:[si]
    and  ch, cl
    neg  ch
    rcl  ah, 1
    sub  al, bl
    jns  readLoop
    mov  al, ah
    sub  ah, ah
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

