L640LscanDone:
    inc  di
    mov  ax, di
    cld
    pop  ds
    pop  si
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
