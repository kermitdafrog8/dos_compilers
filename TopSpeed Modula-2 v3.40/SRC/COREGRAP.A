    mov  dl, 0FFH
    shl  dh, cl
    not  dh
    mov  cx, [bp][x2]
    and  cl, 7
    xor  cl, 7
    shl  dl, cl
    mov  ax, [bp][x2]
    mov  bx, [bp][x1]
    mov  cl, 3
    shr  ax, cl
    shr  bx, cl
    mov  cx, ax
    sub  cx, bx
    mov  bx, PropPix
    mov  al, [bp][color]
    xlat
    or   dh, dh
    js   byteAligned
    or   cx, cx
    jnz  multiByte
    and  dl, dh
    jmp  singleByte
multiByte:
