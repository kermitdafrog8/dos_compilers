(*%E *)

public __VGArightscan :


(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push di
    mov  di, ax
(*%T _XTD *)
    extrn __A000h
    mov  ax, __A000h
(*%E *)
(*%F _XTD *)
    mov  ax, 0A000H
(*%E *)
    mov  es, ax
    mov  al, bl
scanLoop:
    inc  di
    inc  dx
    cmp  al, es:[di]
    je   scanDone
    cmp  dx, cx
    jle  scanLoop
scanDone:
    mov  ax, dx
    dec  ax
    pop  di
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
