    mov  [bp][color], dx
    xchg ax, bx
    call __pixeladdr320x200
    mov  di, bx
    mov  dh, ah
    not  dh
    mov  dl, 0FFH
    shl  dh, cl
    not  dh
    mov  cx, [bp][x2]
    and  cl, 3
    xor  cl, 3
    shl  cl, 1
    shl  dl, cl
    mov  ax, [bp][x2]
    mov  bx, [bp][x1]
    mov  cl, 2
    shr  ax, cl
    shr  bx, cl
    mov  cx, ax
    sub  cx, bx
    mov  bx, PropPix
    mov  al, [bp][color]
    xlat
    or   dh, dh
    js   byteAligned
    or   cx, cx
    jnz  multiByte
    and  dl, dh
    jmp  singleByte
multiByte:
    mov  ah, al
    and  ah, dh
    not  dh
    and  es:[di], dh
    or   es:[di], ah
    inc  di
    dec  cx
byteAligned:
rep ; stosb
singleByte:
    and  al, dl
    not  dl
    and  es:[di], dl
    or   es:[di], al
noDraw:
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(**************************************************************************)

