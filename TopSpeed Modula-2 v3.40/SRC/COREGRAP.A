(*%E *)

public __CGA640rightscan :

    push bp
    mov  bp, sp
    push di
    push si
    push ds
    mov  si, ax               (* ptr *)
(*%T _XTD *)
    extrn __B800h
    mov  ax, __B800h
(*%E *)
(*%F _XTD *)
    mov  ax, 0B800H
(*%E *)
    mov  ds, ax
    mov  es, ax
    mov  di, dx               (* right *)
    mov  ax, dx
    mov  dx, cx               (* limit *)
    mov  cl, 7
    shl  bl, cl
    mov  cx, ax
    and  cl, 7
    mov  bh, 080H
    shr  bx, cl
    mov  cx, dx
    sub  cx, di
    mov  di, -1
    lodsb
CGARscanLoop:
    ror  bl, 1
    ror  bh, 1
    jc  CGARLoad
CGARnoInc:
    mov  ah, al
    and  ah, bh
    cmp  ah, bl
    loopne CGARscanLoop
CGARscanDone:
    jne  noInc
    inc  cx
noInc:
    mov  ax, dx
    sub  ax, cx
    pop  ds
    pop  si
    pop  di
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

CGARLoad:
    inc  di
    jne  CGARfastTest
    lodsb
    jmp  CGARnoInc
CGARfastTest:
    mov  bp, cx
    and  bp, 7
    shr  cx, 1
    shr  cx, 1
    shr  cx, 1
    jcxz CGARnoInc
    mov  di, si
repe ; scasb
    jne  foundNewByte
    mov  cx, bp
    jcxz noInc
    jmp  setupNext
foundNewByte:
