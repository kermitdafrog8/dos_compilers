section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment COREWIND_TEXT(CODE,28H)
(*%E *)

extrn  __IsDirect
extrn  __ScreenSel
extrn  __Config
extrn  __BufInf
extrn  __Status

extrn VIOREADCELLSTR
extrn VIOWRTCELLSTR

extrn VIOSCRUNLOCK
extrn VIOSCRLOCK
extrn VIOGETCONFIG
extrn VIOGETPHYSBUF


(*%F RegParam *)
RetSize = 0
(*%E *)
(*%T RegParam *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%F NearPtr *)
RetSize = 6
(*%E *)
(*%E *)


(*%F RegParam *)
ToL   = frame
(*%F NearPtr *)
FromL = 4+frame
Len   = 8+frame
PalL  = 10+frame
(*%E *)
(*%T NearPtr *)
FromL = 2+frame
Len   = 4+frame
PalL  = 6+frame
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
ToL   = -4
FromL = -8
Len   = 4+frame
PalL  = frame
(*%E *)
(*%T NearPtr *)
ToL   = -2
FromL = -4
Len   = -6
PalL  = -8
(*%E *)
locals = 8
(*%E *)

public __palxlat :

  push bp
  mov bp,sp
(*%T RegParam *)
   sub  sp, locals
(*%F NearPtr *)
   mov  [bp][ToL], ax
   mov  [bp][ToL][2], bx
   mov  [bp][FromL], cx
   mov  [bp][FromL][2], dx
(*%E *)
(*%T NearPtr *)
   mov  [bp][ToL], ax
   mov  [bp][FromL], bx
   mov  [bp][Len], cx
   mov  [bp][PalL], dx
(*%E *)
(*%E *)
  push ds
  push si
  push di
  mov cx,[bp][Len]
  jcxz PXExit
  sub sp,10
  mov di,sp
(* copy pallette onto stack *)
(*%F NearPtr *)
  lds si,[bp][PalL]
  push ss
  pop es
(*%E *)
(*%T NearPtr *)
  mov si,[bp][PalL]
  mov ax, _DATA
  mov es, ax
(*%E *)
  mov cx,5
  rep
  movsw
  mov bx,sp
(*%F NearPtr *)
  lds si, [bp][FromL]
  les di, [bp][ToL]
(*%E *)
(*%T NearPtr *)
  mov si, [bp][FromL]
  mov di, [bp][ToL]
(*%E *)
  mov cx,[bp][Len]
PXloop:
  lodsw
  xchg al,ah
  db 36H        (* ss override for xlat *)
  xlat
  xchg al,ah
  stosw
  loop PXloop
  add sp,10

PXExit:
  pop di
  pop si
  pop ds
(*%T RegParam *)
  mov sp, bp
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

