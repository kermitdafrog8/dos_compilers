section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment COREWIND_TEXT(CODE,28H)
(*%E *)

extrn  __IsDirect
extrn  __ScreenSel
extrn  __Config
extrn  __BufInf
extrn  __Status

extrn VIOREADCELLSTR
extrn VIOWRTCELLSTR

extrn VIOSCRUNLOCK
extrn VIOSCRLOCK
extrn VIOGETCONFIG
extrn VIOGETPHYSBUF

(*%F RegParam *)
RetSize = 0
(*%E *)
(*%T RegParam *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%F NearPtr *)
RetSize = 4
(*%E *)
(*%E *)


(*%F RegParam *)
BuffL = frame
(*%F NearPtr *)
StrL  = 4+frame
Len   = 8+frame
Attr  = 10+frame
(*%E *)
(*%T NearPtr *)
StrL  = 2+frame
Len   = 4+frame
Attr  = 6+frame
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
Len   = 2+frame
Attr  = frame
(*%E *)
(*%E *)

public __bufferwrite :

  push bp
  mov  bp, sp
  push ds
  push si
  push di
(*%T RegParam *)
(*%F NearPtr *)
  mov ds, dx
  mov si, cx
  mov es, bx
  mov di, ax
(*%E *)
(*%T NearPtr *)
  mov si, bx
  mov di, ax
  mov ax, _DATA
  mov es, ax
(*%E *)
(*%E *)

(*%F RegParam *)
  mov cx, [bp][Len]
(*%F NearPtr *)
  lds si, [bp][StrL]
  les di, [bp][BuffL]
(*%E *)
(*%T NearPtr *)
  mov si, [bp][StrL]
  mov di, [bp][BuffL]
  mov ax, _DATA
  mov es, ax
(*%E *)
  mov ah, [bp][Attr]
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
  mov cx, [bp][Len]
  mov ah, [bp][Attr]
(*%E *)
(*%T NearPtr *)
  mov ah, dl
(*%E *)
(*%E *)

  jcxz $Exit
LDoWrite:
LWriteLoop:
  lodsb
  stosw
  loop LWriteLoop
$Exit:
  pop di
  pop si
  pop ds
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

(*****************************************************************************)
section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment COREWIND_TEXT(CODE,28H)
(*%E *)

extrn VIOGETMODE

buf    = -34
locals =  34
rows   =   6

public __getscreendepth :

    push bp
    mov  bp, sp
    sub  sp, locals
    lea  bx, [bp][buf]
    mov  word ss:[bx][0], locals
    push ss
    push bx
    sub  ax, ax
    push ax
    call far VIOGETMODE
    mov  al, [bp][buf][rows]
    mov  sp, bp
    pop  bp
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

