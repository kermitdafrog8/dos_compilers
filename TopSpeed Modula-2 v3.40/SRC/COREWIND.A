extrn  __IsDirect
extrn  __ScreenSel
extrn  __Config
extrn  __BufInf
extrn  __Status

extrn VIOREADCELLSTR
extrn VIOWRTCELLSTR

extrn VIOSCRUNLOCK
extrn VIOSCRLOCK
extrn VIOGETCONFIG
extrn VIOGETPHYSBUF

(*%F RegParam *)
RetSize = 0
(*%E *)
(*%T RegParam *)
(*%F NearPtr *)
RetSize = 2
(*%E *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%E *)


(*%F RegParam *)
X       = frame
Y       = 2+frame
SourceL = 4+frame
(*%F NearPtr *)
Len     = 8+frame
(*%E *)
(*%T NearPtr *)
Len     = 6+frame
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
Len     = frame
X  =     -2
Y  =     -4
SourceL =-8
locals  = 8
(*%E *)
(*%T NearPtr *)
X  =     -2
Y  =     -4
SourceL =-8
Len     = -10
locals  =  10
(*%E *)
(*%E *)

public __buffertoscreen :

  push bp
  mov  bp, sp

(*%T RegParam *)
  sub  sp, locals
  mov  [bp][X], ax
  mov  [bp][Y], bx
  mov  [bp][SourceL], cx
(*%F NearPtr *)
  mov  [bp][SourceL][2], dx
(*%E *)
(*%T NearPtr *)
  mov  [bp][Len], dx
(*%E *)
(*%E *)

(*%F SameDS *)
  push ds
  mov  ax, _DATA
  mov  ds, ax
(*%E *)
  cmp  byte [__IsDirect],0
  jne  FBufferToScreen
NBTS:
(*%F NearPtr *)
  push [bp][SourceL][2]
(*%E *)
(*%T NearPtr *)
  push ds
(*%E *)
  push [bp][SourceL]
  mov ax, [bp][Len]
  shl ax,1
  push ax
  push [bp][Y]
  push [bp][X]
  xor  ax, ax
  push ax
  call far VIOWRTCELLSTR
RetBufferToScreen:
(*%F SameDS *)
  pop ds
(*%E *)
(*%T RegParam *)
  mov sp, bp
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)

FBufferToScreen:
  xor ax,ax
  push ax
  push ds
  mov ax, __Status
  push ax
  xor ax,ax;
  push ax
  call far VIOSCRLOCK;
  cmp byte [__Status], 0
  jne NBTS
erTest:
  or  ax, ax
  jne NBTS

  push si
  push di
  push ds
  mov es, [__ScreenSel]
(*%F NearPtr *)
  lds si,[bp][SourceL]
(*%E *)
(*%T NearPtr *)
  mov si,[bp][SourceL]
(*%E *)
  mov ax, [bp][Y]
  mov di, [bp][X]

  mov cl, 4
  shl ax, cl  (* 16Y *)
  add di, ax
  shl ax, 1
  shl ax, 1
  add di, ax  (* +64Y=80Y *)
  shl di, 1
  mov cx, [bp][Len]
  rep
  movsw
  pop ds
  pop di
  pop si
  xor ax,ax
  push ax
  call far VIOSCRUNLOCK
  jmp RetBufferToScreen

(****************************************************************************)
section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment COREWIND_TEXT(CODE,28H)
(*%E *)

extrn  __IsDirect
extrn  __ScreenSel
extrn  __Config
extrn  __BufInf
extrn  __Status

extrn VIOREADCELLSTR
extrn VIOWRTCELLSTR

extrn VIOSCRUNLOCK
extrn VIOSCRLOCK
extrn VIOGETCONFIG
extrn VIOGETPHYSBUF


(*%F RegParam *)
RetSize = 0
(*%E *)
(*%T RegParam *)
(*%F NearPtr *)
RetSize = 2
(*%E *)
(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%E *)


(*%F RegParam *)
X       = frame
Y       = 2+frame
DestL = 4+frame
(*%F NearPtr *)
Len     = 8+frame
(*%E *)
(*%T NearPtr *)
Len     = 6+frame
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
Len     = frame
(*%E *)
(*%T NearPtr *)
Len     = -2
locals  =  2
(*%E *)
(*%E *)

public __screentobuffer :

(*%F RegParam *)
  push bp
  mov bp,sp
(*%F NearPtr *)
  push [bp][DestL][2]
(*%E *)
(*%T NearPtr *)
  push ds
(*%E *)
  push [bp][DestL]
  push ss
  shl word [bp][Len],1
  lea ax, [bp][Len]
  push ax
  push [bp][Y]
  push [bp][X]
  xor ax,ax
  push ax
  call far VIOREADCELLSTR
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

(*%T RegParam *)
  push bp
  mov  bp,sp
(*%T NearPtr *)
  sub  sp, locals
  mov  [bp][Len], dx
(*%E *)
(*%F NearPtr *)
  push dx
  push cx
(*%E *)
(*%T NearPtr *)
  push ds
  push cx
(*%E *)
  push ss
  shl word [bp][Len],1
  lea dx, [bp][Len]
  push dx
  push bx
  push ax
  xor ax,ax
  push ax
  call far VIOREADCELLSTR
(*%T NearPtr *)
  mov sp, bp
(*%E *)
  pop bp
(*%F NearCall *)
  ret far RetSize
(*%E *)
(*%T NearCall *)
  ret RetSize
(*%E *)
(*%E *)

section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment COREWIND_TEXT(CODE,28H)
(*%E *)

extrn  __IsDirect
extrn  __ScreenSel
extrn  __Config
extrn  __BufInf
extrn  __Status

extrn VIOREADCELLSTR
extrn VIOWRTCELLSTR

extrn VIOSCRUNLOCK
extrn VIOSCRLOCK
extrn VIOGETCONFIG
extrn VIOGETPHYSBUF

IsSnow = frame


(* initialize screen type *)
public __initscreentype :

  push bp
  mov bp, sp
(*%F SameDS *)
  push ds
  mov  ax, _DATA
  mov  ds, ax
(*%E *)
  mov byte [__IsDirect],0
  cmp byte [bp][IsSnow],0
  jne SkipInit
  mov byte [__IsDirect],1
  xor ax,ax
  push ax
  push ds
  mov bx, __Config
  push bx
  push ax
  call far VIOGETCONFIG
  mov word [__BufInf],0
  mov word [__BufInf][2], 0BH
  cmp word [__Config][2], 0
  je  itsmono
  mov word [__BufInf],8000H
  mov word [__BufInf][2],0BH
itsmono:
  push ds
  mov ax, __BufInf
  push ax
  xor ax,ax
  push ax
  call far VIOGETPHYSBUF
  or  ax, ax
  jz  initOK
  mov  byte [__IsDirect], 0
  jmp  SkipInit
initOK:
  mov  ax,[__BufInf][8]
  mov [__ScreenSel],ax
SkipInit:
(*%F SameDS *)
  pop ds
(*%E *)
  pop bp
(*%F NearCall *)
  ret far 0
(*%E *)
(*%T NearCall *)
  ret 0
(*%E *)

(*%E *)

(****************************************************************************)
(*%T _DLL *)
section

segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

extrn __initwin_vector

public __set_initwin_vector :

    push ds
    mov  cx, _DATA
    mov  ds, cx
    mov  [__initwin_vector][2], bx
    mov  [__initwin_vector], ax
    pop  ds
    ret  far 0
(*%E *)

end