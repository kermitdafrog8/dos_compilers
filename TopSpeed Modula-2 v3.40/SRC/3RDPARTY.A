    jne  local3
    mov  cx, [bp][dvW1]
    mov  ax, [bp][dsW2]
    sub  dx, dx
    div  cx
    mov  bx, ax
    mov  ax, [bp][dsW1]
    div  cx
    mov  dx, bx
    jmp  local7
local3:
    mov  bx, ax
    mov  cx, [bp][dvW1]
    mov  dx, [bp][dsW2]
    mov  ax, [bp][dsW1]
local4:
    shr  bx, 1
    rcr  cx, 1
    shr  dx, 1
    rcr  ax, 1
    or   bx, bx
    jne  local4
    div  cx
    mov  si, ax
    mul  word [bp][dvW2]
    xchg ax, cx
    mov  ax, [bp][dvW1]
    mul  si
    add  dx, cx
    jb   local5
    cmp  dx, [bp][dsW2]
    ja   local5
    jb   local6
    cmp  ax, [bp][dsW1]
    jbe  local6
local5:
    dec  si
local6:
    sub  dx, dx
    xchg ax, si
local7:
    dec  di
    jne  local8
    neg  dx
    neg  ax
    sbb  dx, 0
local8:
    pop  si
    pop  di
    pop  bx
    pop  bp
    ret  8

