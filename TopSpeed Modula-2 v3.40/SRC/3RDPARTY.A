  add  cl, 10H
  shr  bx, cl
  or   dx, bx
  ret  far 0
bigWord:
  sub  cl, 10H
  xchg ax, dx
  xor  ax, ax
  shl  dx, cl
  ret  far 0

section
segment (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)(CODE, 28H)

public N_LXRSH@ :
  pop   bx
  push  cs
  push  bx

public F_LXRSH@ :
public LXRSH@ :

  cmp  cl, 10H
  jae  bigWord
  mov  bx, dx
  shr  ax, cl
  sar  dx, cl
  neg  cl
  add  cl, 10H
  shl  bx, cl
  or   ax, bx
  ret  far 0
bigWord:
  sub  cl, 10H
  xchg ax, dx
  cwd
  sar  ax, cl
  ret  far 0

