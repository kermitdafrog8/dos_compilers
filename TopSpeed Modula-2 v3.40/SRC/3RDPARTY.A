section
segment (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)(CODE, 28H)

public FTOL@ :
public F_FTOL@ :

CW     =  -2
lnum   =  -6
locals =   6

  push  bp
  mov   bp, sp
  sub   sp, locals
  fstcw [bp][CW]
  fwait
  mov   ax, [bp][CW]
  or    word [bp][CW], 0C00H
  fwait
  fldcw [bp][CW]
  fistp dword [bp][lnum], st(0)
  mov   [bp][CW], ax
  fldcw [bp][CW]
  mov   ax, [bp][lnum]
  mov   dx, [bp][lnum][2]
  mov   sp, bp
  pop   bp
  ret   far 0

