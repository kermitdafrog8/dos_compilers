section
segment (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)(CODE,28H)

select (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)

public F_LXMUL@ :
public LXMUL@ :
    push si
    xchg ax, si
    xchg ax, dx
    test ax, ax
    je   L1
    mul  bx
L1:
    jcxz L2
    xchg ax, cx
    mul  si
    add  ax, cx
L2:
    xchg ax, si
    mul  bx
    add  dx, si
    pop  si
    ret  far 0

(****************************************************************************)
section
segment (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)(CODE,28H)

select (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)

public N_LDIV@ :
    pop  cx
    push cs
    push cx
public F_LDIV@ :
public LDIV@ :
    sub  cx, cx
    jmp  L1
public N_LUDIV@ :
    pop  cx
    push cs
    push cx
public F_LUDIV@ :
public LUDIV@ :
    mov  cx, 1
    jmp  L1
public N_LMOD@ :
    pop  cx
    push cs
    push cx
public F_LMOD@ :
public LMOD@ :
    mov  cx, 2
    jmp  L1
public N_LUMOD@ :
    pop  cx
    push cs
    push cx
public F_LUMOD@ :
public LUMOD@ :
    mov  cx, 3
L1:
    push bp
    push si
    push di
    mov  bp, sp
    mov  di, cx
    mov  ax, [bp][0AH]
    mov  dx, [bp][0CH]
    mov  bx, [bp][0EH]
    mov  cx, [bp][10H]
    or   cx, cx
    jne  L2
    or   dx, dx
    je   L10
    or   bx, bx
    je   L10
L2:
    test di, 1
    jne  L4
    or   dx, dx
    jns  L3
    neg  dx
    neg  ax
    sbb  dx, 0
    or   di, 0CH
L3:
    or   cx, cx
    jns  L4
    neg  cx
    neg  bx
    sbb  cx, 0
    xor  di, 4
L4:
    mov  bp, cx
    mov  cx, 20H
    push di
    xor  di, di
    xor  si, si
L5:
    shl  ax, 1
    rcl  dx, 1
    rcl  si, 1
    rcl  di, 1
    cmp  di, bp
    jb   L7
    ja   L6
    cmp  si, bx
    jb   L7
L6:
    sub  si, bx
    sbb  di, bp
    inc  ax
L7:
    loop L5
    pop  bx
    test bx, 2
    je   L8
    mov  ax, si
    mov  dx, di
    shr  bx, 1
L8:
    test bx, 4
    je   L9
    neg  dx
    neg  ax
    sbb  dx, 0
L9:
    pop  di
    pop  si
    pop  bp
    ret  far 8
L10:
    div  bx
    test di, 2
    je   L11
    xchg ax, dx
L11:
    xor  dx, dx
    jmp  L9

