  fxch    st(0),st(1)
  fcompp  st(0),st(1)
  fstsw   [bp][-2]
  fwait
  mov   ah,[bp][-1]
  and   ax,4100H
  shr   ax,1
  shl   ah,1
  or    ah,al
  sahf
  mov   sp,bp
  pop   bp
