(*%E *)

public __aNldiv :

    push bp
    mov  bp, sp
    push bx
    push di
    push si
    sub  di, di
    mov  ax, [bp][dsW2]
    or   ax, ax
    jge  local1
    inc  di
    mov  dx, [bp][dsW1]
    neg  ax
    neg  dx
    sbb  ax, 0
    mov  [bp][dsW2], ax
    mov  [bp][dsW1], dx
local1:
    mov  ax, [bp][dvW2]
    or   ax, ax
    jge  local2
    inc  di
    mov  dx, [bp][dvW1]
    neg  ax
    neg  dx
    sbb  ax, 0
    mov  [bp][dvW2], ax
    mov  [bp][dvW1], dx
local2:
