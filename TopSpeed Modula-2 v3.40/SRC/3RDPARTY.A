include "corelib.inc"

module ThirdParty

segment (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)(CODE,28H)
segment _DATA(DATA, 28H)

select (*%F SameDS*)PARTY3_TEXT (*%E*)(*%T SameDS*) _TEXT (*%E*)

extrn __FatalError
extrn __stk_base

CSVar = 2
IPVar = 0

public __chkstk:

(*%F NearCall *)
    pop  cx
(*%E *)
    pop  dx
    mov  bx,sp
    sub  bx,ax
    jb   stackError
    cmp  bx, [__stk_base]
    jb   stackError
    mov  sp,bx
    push dx
(*%F NearCall *)
    push cx
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

stackError:
    mov  bx, sp
    mov  ax, 1
    push ax
    push ss:[bx][IPVar]
(*%T NearCall*) push cs (*%E*)
(*%F NearCall*) push ss:[bx][CSVar] (*%E*)
    call far __FatalError

(**************************************************************************)
