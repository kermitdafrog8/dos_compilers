  (* compute 2^st(0) , result is represented as st(0) * 2^st(4) *)

extrn @coremath_int_four

public $pow2 :
  fld1  st(0)
  fxch  st(0), st(1)
  fst   st(5), st(0)
  frndint st(0)
  fsub  st(0), st(1)
  fxch  st(0), st(5)
  fsub  st(0), st(5)        (* we now know that st(0) is in range [0..2) *)
  fidiv word st(0), cs:[@coremath_int_four] (* now in range [0..0.5] *)
  f2xm1 st(0)
  faddp st(1), st(0)
  fmul  st(0), st(0)
  fmul  st(0), st(0)
  ret   0

