  dw asinl_exit, err_asinl_neg, err_asinl_pos; db f_st5+f_long, "asinl", 0

err_asinl_pos:
  call  $check_abs_one
  fld1  st(0)
  fstp  st(1), st(0)
  fchs  st(0)
  fldpi st(0)
  fscale st(0),st(1)
  sub   ax, ax
  ret   0

err_asinl_neg:
