  push  bp
  mov   bp, sp
  mov   word ss:[InMathLib], exptable
  mov   word ss:[InMathLib][2], bp
  sub   sp, 10
expCommon:
  fst   st(5), st(0)            (* save parameter for error processing *)
  fldl2e st(0)
  fmulp st(1), st(0)
  fist  word [bp][-2], st(0)    (* to check that it is not too large *)
  fwait
  call  $pow2
  fld   st(0), st(4)            (* retrieve integral part *)
  fxch  st(1), st(0)
  fscale st(0), st(1)
  fst   qword [bp][-10],st(0)   (* to provoke error if too big for double *)
  fstp  st(1),st(0)
exp_exit:
  mov   sp, bp
  pop   bp
  mov   word ss:[InMathLib], 0
  db    Ret0@

exptable:
