  push  bp
  mov   bp, sp
  mov   word ss:[InMathLib], tanhltable
  mov   word ss:[InMathLib][2], bp
  sub   sp, 12
  fld   tbyte st(0), [bp][frame]
(*%F SameDS *)                   (* for error processing *)
  mov   ax, seg __fac
  mov   es, ax
  fst   qword es:[__fac], st(0)
(*%E *)
(*%T SameDS *)
  fst   qword [__fac], st(0)
(*%E *)
  fwait
  fldl2e st(0)
  fmulp st(1), st(0)
  fist  word [bp][-2], st(0) (* to check that it is not too large *)
  fwait
  call  $pow2
  fld   qword st(0), [bp][-12] (* retrieve integral part *)
(*%T _WINDOWS *)
