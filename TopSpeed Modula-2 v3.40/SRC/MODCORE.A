(*%F RegParam *)
section
segment _DATA(DATA, 28H)
(*%T SameDS *)
segment _TEXT(CODE,28H)
(*%E *)
(*%F SameDS *)
segment STR_TEXT(CODE,28H)
(*%E *)


public _strlen :

(*
size_t	strlen(const char *s)

Returns length of s excluding terminating zero.
*)


s1  = frame

    push bp
    mov  bp, sp
    push cx
    push di
(*%F NearPtr *)
    les  di, [bp][s1]
(*%E *)
(*%T NearPtr *)
    mov  di, [bp][s1]
    push ds
    pop  es
(*%E *)
    mov  cx, 0FFFFH
    sub  al, al
repne ;  scasb             (* get length of string *)
    not  cx
    mov  ax, cx
    dec  ax                (* return value is length of string *)
    pop  di
    pop  cx
    pop  bp
(*%F NearCall *)
    ret  far   0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

public _strrchr :

(*
char *strrchr(const char *s, int c)

searches string for last occurrence c.
returns address of target byte if Found.
*)


addr   = frame
(*%T NearPtr *)
chk    = 2+frame
(*%E *)
(*%F NearPtr *)
chk    = 4+frame
(*%E *)


    push bp
    mov  bp, sp
    push cx
    push di
(*%F NearPtr *)
    les  di, [bp][addr]
(*%E *)
(*%T NearPtr *)
    mov  di, [bp][addr]
    push ds
    pop  es
(*%E *)
    mov  cx, 0FFFFH
    mov  al, 0
repne ;  scasb                (* find end of string *)
    sub  di, 2
    cmp  di, [bp][addr]    (* if it was a null string exit *)
    jb   rchrnotFound
    std
    mov  al, [bp][chk]
    not  cx
    dec  cx
repne  ;  scasb               (* search *)
    je   rchrFound
rchrnotFound:
    sub  ax, ax               (* return NULL *)
    cwd
    jmp  rchrDone
rchrFound:
    inc  di                   (* return address of Matching character *)
    mov  ax, di
(*%F NearPtr *)
    mov  dx, es
(*%E *)
rchrDone:
    cld
    pop  di
    pop  cx
    pop  bp
(*%F NearCall *)
    ret  far   0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

public _strnicmp :

(*
int strnicmp(const char  *s1, const char  *s2, int num)


Compares up to num characters.
Returns < 0 if s1<s2, 0 if s1=s2 and > 0 if s1 > s2.
*)

s1   = frame
(*%T NearPtr *)
s2     = 2+frame
num    = 4+frame
(*%E *)
(*%F NearPtr *)
s2     = 4+frame
num    = 8+frame
(*%E *)

    push bp
    mov  bp, sp
    push bx
    push cx
    push dx
    push di
    push si
(*%F NearPtr *)
    push ds
    lds  si, [bp][s1]
    les  di, [bp][s2]
(*%E *)
(*%T NearPtr *)
    mov  si, [bp][s1]
    mov  di, [bp][s2]
    push ds
    pop  es
(*%E *)
    mov  cx, [bp][num]
    sub  ax, ax
    jcxz nicmpDone
    mov  dx, 7A61H
nicmpLoop:
    lodsb
    or   al, al
    je   nicmpSame
    cmp  al, dh        (* convert to upper if lower *)
    ja   notlowa
    cmp  al, dl
    jb   notlowa
    sub  al, 20H
notlowa:
    mov  bl, es:[di]
    inc  di             (* convert to upper if lower *)
    cmp  bl, dh
    ja   notlowb
    cmp  bl, dl
    jb   notlowb
    sub  bl, 20H
notlowb:
    cmp  al, bl
    jl   nicmpLessThan
    jg   nicmpGreaterThan
    loop nicmpLoop
nicmpSame:
    sub  ax, ax         (* return 0 *)
    jmp  nicmpDone
nicmpLessThan:
    mov  ax, -1         (* return -1 *)
    jmp  nicmpDone
nicmpGreaterThan:
    mov  ax, 1          (* return 1 *)
nicmpDone:
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  dx
    pop  cx
    pop  bx
    pop  bp
(*%F NearCall *)
    ret  far   0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*%E *)

