section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)


select _TEXT

extrn __ioerr
extrn DOSOPEN

select _TEXT

public __os2_open :

(*%F RegParam *)
path   = frame
(*%F NearPtr *)
access = 4+frame
mode   = 6+frame
flag   = 8+frame
(*%E *)
(*%T NearPtr *)
access = 2+frame
mode   = 4+frame
flag   = 6+frame
(*%E *)
handle = -2
action = -4
locals =  4

    push bp
    mov  bp, sp
    sub  sp, locals
(*%F NearPtr *)
    push [bp][path][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][path]
    lea  ax, [bp][handle]
    push ss
    push ax
    lea  ax, [bp][action]
    push ss
    push ax
    sub  ax, ax
    push ax
    push ax
    push [bp][mode]
    push [bp][flag]
    mov  bx, [bp][access]
    test bx, 0F0H
    jnz  gotShare
    or   bx, 40H
gotShare:
    push bx
    push ax
    push ax
    call far DOSOPEN
    or   ax, ax
    jnz  openError
    mov  ax, [bp][handle]
openDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
flag = frame
RetSize = 2
(*%E *)
(*%T NearPtr *)
RetSize = 0
(*%E *)

handle = -2
action = -4
locals =  4

    push bp
    mov  bp, sp
    sub  sp, locals
(*%F NearPtr *)
    push bx
    push ax
(*%E *)
(*%T NearPtr *)
    push ds
    push ax
(*%E *)
    lea  ax, [bp][handle]
    push ss
    push ax
    lea  ax, [bp][action]
    push ss
    push ax
    sub  ax, ax
    push ax
    push ax
(*%F NearPtr *)
    push dx
    push [bp][flag]
    mov  bx, cx
(*%E *)
(*%T NearPtr *)
    push cx
    push dx
(*%E *)
    test bx, 0F0H
    jnz  gotShare
    or   bx, 40H
gotShare:
    push bx
    push ax
    push ax
    call far DOSOPEN
    or   ax, ax
    jnz  openError
    mov  ax, [bp][handle]
openDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far RetSize
(*%E *)
(*%T NearCall *)
    ret  RetSize
(*%E *)
(*%E *)

openError:
(*%F NearCall *)
    call far __ioerr
(*%E *)
(*%T NearCall *)
    call __ioerr
(*%E *)
    mov  ax, -1
    jmp  openDone

(****************************************************************************)

