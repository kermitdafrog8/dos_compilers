section
(*%F _OS2 *)
(****************************************************************************)
segment _DATA(DATA,28H)
segment _TEXT(CODE,28H)

extrn __seterrno
extrn __psp
extrn __FloatExecSave
extrn __FloatExecRestore

public __exec :

(* int cdecl _exec(char *pathname, struct paramblock *pblock)
     executes child process for system(). *)

FCB5 = 6
FCB6 = 10

(*%F RegParam *)
pathname = frame
(*%F NearPtr *)
pblock   = 4+frame
(*%E *)
(*%T NearPtr *)
pblock   = 2+frame
(*%E *)
(*%E *)

(*%F RegParam *)
    push bp
    mov  bp, sp
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%E *)
    call far __FloatExecSave
    push di
    push ds
(*%F SameDS *)
    mov  di, seg __psp
    mov  ds, di
(*%E *)
    mov  di, [__psp]
(*%F RegParam *)
(*%F NearPtr *)
    lds  dx, [bp][pathname]
    les  bx, [bp][pblock]
(*%E *)
(*%T NearPtr *)
    mov  dx, [bp][pathname]
    mov  bx, [bp][pblock]
    push ds
    pop  es
(*%E *)
(*%E *)
(*%T RegParam *)
(*%F NearPtr *)
    mov  ds, bx
    mov  es, dx
    mov  dx, ax
    mov  bx, cx
(*%E *)
(*%T NearPtr *)
    mov  dx, ax
    push ds
    pop  es
(*%E *)
(*%E *)
    mov  es:[bx][FCB6][2], di
    mov  word es:[bx][FCB6], 6CH
    mov  es:[bx][FCB5][2], ax
    mov  word es:[bx][FCB5], 5CH
    mov  ax, 4B00H
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    jnc  execOK
(*%F NearCall *)
    call far __seterrno
(*%E *)
(*%T NearCall *)
    call __seterrno
(*%E *)
    mov  ax, -1
    jmp  execDone
execOK:
    sub  ax, ax                     (* success - return 0 *)
execDone:
    pop  ds
    pop  di
    call far __FloatExecRestore
(*%F RegParam *)
    pop  bp
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _TEXT

public __get_retcode :

(*
int __get_retcode(void)

get return code of child process.
*)

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    mov  ah, 4DH
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)


(*****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _DATA

extrn __psp
PrevTop : dw 0

select _TEXT

public _AdjustMem :
(*%F RegParam *)
Seg = frame

    push bp
    mov  bp, sp
    mov  ax, [bp][Seg]
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
(*%E *)
    push bx
(*%F SameDS *)
    push ds
    mov  bx, seg __psp
    mov  ds, bx
(*%E *)
    or   ax, ax
    jnz  notRestore
    mov  ax, [PrevTop]
notRestore:
    mov  es, [__psp]
    mov  bx, es:[2]
    mov  es:[2], ax
    mov  [PrevTop], bx
    mov  bx, ax
    mov  ax, es
    sub  bx, ax
    mov  ah, 4AH
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)

(*%F SameDS *)
    pop  ds
(*%E *)
    pop  bx
(*%F RegParam *)
    pop  bp
(*%E *)
(*%T RegParam *)
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%E *)

(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

(*****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

select _DATA

extrn __psp
extrn __fmemsetup

select _TEXT

public __getheapmem :

(*%T _DLLOVL *)
    push bp
    mov  bp, sp
(*%E *)
    push bx
    push cx
(*%F SameDS *)
    push ds
    mov  bx, seg __psp
    mov  ds, bx
(*%E *)
    mov  byte [__fmemsetup], 1
    mov  es, [__psp]
    mov  ah, 4AH
    mov  bx, 0C000H
    extrn @DosInterrupt
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    mov  ah, 4AH
(*%F NearCall *)
    call far @DosInterrupt
(*%E *)
(*%T NearCall *)
    call @DosInterrupt
(*%E *)
    mov  ax, es:[2]     (* old top of mem *)
    mov  cx, es
    add  cx, bx
    mov  es:[2], cx
(*%F SameDS *)
    pop  ds
(*%E *)
    pop  cx
    pop  bx
(*%T _DLLOVL *)
    pop  bp
(*%E *)
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

(*%E *)  (* T OS2 *)
(****************************************************************************)
(*%T _OS2 *)
segment _TEXT(CODE,28H)
(* fixups for low level I/O *)

public _time        :
public __flsbuf     :
public __filbuf     :
public __flusher    :
   ret  far 0


(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn __ioerr
extrn DOSWRITE

select _TEXT

public __write :

(*%F RegParam *)
handle = frame
buffer = 2+frame
(*%F NearPtr *)
count  = 6+frame
(*%E *)
(*%T NearPtr *)
count  = 4+frame
(*%E *)
numwrit= -2
locals =  2

    push bp
    mov  bp, sp
    sub  sp, locals
    push [bp][handle]
(*%F NearPtr *)
    push [bp][buffer][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][buffer]
    push [bp][count]
    lea  ax, [bp][numwrit]
    push ss
    push ax
    call far DOSWRITE
    or   ax, ax
    jnz  writeError
    mov  ax, [bp][numwrit]
writeDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

(*%T RegParam *)
numwrit= -2
locals =  2

    push bp
    mov  bp, sp
    sub  sp, locals
    push ax
(*%F NearPtr *)
    push cx
    push bx
    push dx
(*%E *)
(*%T NearPtr *)
    push ds
    push bx
    push cx
(*%E *)
    lea  ax, [bp][numwrit]
    push ss
    push ax
    call far DOSWRITE
    or   ax, ax
    jnz  writeError
    mov  ax, [bp][numwrit]
writeDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

writeError:
(*%F NearCall *)
    call far __ioerr
(*%E *)
(*%T NearCall *)
    call __ioerr
(*%E *)
    mov  ax, -1
    jmp  writeDone
(****************************************************************************)

section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)


select _TEXT

extrn __ioerr
extrn DOSREAD

select _TEXT

public __read :

(*%F RegParam *)
handle = frame
buffer = 2+frame
(*%F NearPtr *)
count = 6+frame
(*%E *)
