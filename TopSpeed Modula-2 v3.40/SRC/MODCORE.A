(*%F RegParam *)
public _strcpy :

(* strcpy *)

dest   = frame
(*%T NearPtr *)
source = 2+frame
(*%E *)
(*%F NearPtr *)
source = 4+frame
(*%E *)

    push bp
    mov  bp, sp
    push cx
    push di
    push si
(*%F NearPtr *)
    push ds
    les  di, [bp][source]
(*%E *)
(*%T NearPtr *)
    mov  di, [bp][source]
    push ds
    pop  es
(*%E *)
    mov  cx, -1
    sub  al, al
repne ; scasb
    not  cx
(*%F NearPtr *)
    lds  si, [bp][source]
    les  di, [bp][dest]
(*%E *)
(*%T NearPtr *)
    mov  si, [bp][source]
    mov  di, [bp][dest]
(*%E *)
    shr  cx, 1
rep; movsw
    adc  cx, cx
rep; movsb
    mov  ax, [bp][dest]    (* return destination address *)
(*%F NearPtr *)
    mov  dx, es
    pop  ds
(*%E *)
    pop  si
    pop  di
    pop  cx
    pop  bp
(*%F NearCall *)
    ret  far   0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
