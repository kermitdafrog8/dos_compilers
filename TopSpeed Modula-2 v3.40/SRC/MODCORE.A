module ModCore

segment _TEXT(CODE,28H)

public __rreal_out :
public __rreal_in :

    ret 0

section
segment _DATA(DATA,28H)
(*%T _DLL *)
public __dummy_ptr : dd __init_dummy
(*%E *)

segment _TEXT(CODE,28H)
public __init_dummy :
public __initwin:
public __setvideomode :
public __exit1 :
public __initmt :
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
