public _strnicmp :

(*
int strnicmp(const char  *s1, const char  *s2, int num)


Compares up to num characters.
Returns < 0 if s1<s2, 0 if s1=s2 and > 0 if s1 > s2.
*)

(*%T NearPtr *)
RetSize = 0
(*%E *)
(*%F NearPtr *)
RetSize = 2
(*%E *)


(*%F NearPtr *)
num    = bxframe
(*%E *)

(*%F NearPtr *)
    xchg bx, dx
    mov  es, bx
    mov  bx, sp
    mov  bx, ss:[bx][num]
(*%E *)
(*%T NearPtr *)
    push dx
(*%E *)
    push di
    push si
(*%F NearPtr *)
    push ds
    mov  ds, dx
    mov  si, ax
    mov  di, cx
    mov  cx, bx
(*%E *)
(*%T NearPtr *)
    mov  si, ax
    mov  di, bx
    push ds
    pop  es
(*%E *)
    sub  ax, ax
    jcxz nicmpDone
nicmpLoop:
    lodsb
    or   al, al
    je   nicmpSame
    cmp  al, 'z'        (* convert to upper if lower *)
    ja   notlowa
    cmp  al, 'a'
    jb   notlowa
    sub  al, 20H
notlowa:
    mov  bl, es:[di]
    inc  di             (* convert to upper if lower *)
    cmp  bl, 'z'
    ja   notlowb
    cmp  bl, 'a'
    jb   notlowb
    sub  bl, 20H
notlowb:
    cmp  al, bl
    jl   nicmpLessThan
    jg   nicmpGreaterThan
    loop nicmpLoop
nicmpSame:
    sub  ax, ax         (* return 0 *)
    jmp  nicmpDone
nicmpLessThan:
    mov  ax, -1         (* return -1 *)
    jmp  nicmpDone
nicmpGreaterThan:
    mov  ax, 1          (* return 1 *)
nicmpDone:
(*%F NearPtr *)
    pop  ds
(*%E *)
    pop  si
    pop  di
(*%T NearPtr *)
    pop  dx
(*%E *)
(*%F NearCall *)
    ret  far   RetSize
(*%E *)
(*%T NearCall *)
    ret  RetSize
(*%E *)


