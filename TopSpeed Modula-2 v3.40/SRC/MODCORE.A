(*%E *)
    push di
(*%F NearPtr *)
    mov  es, bx
    mov  di, ax
    mov  dx, ax
    mov  bx, cx
(*%E *)
(*%T NearPtr *)
    mov  di, ax
    mov  dx, ax
    push ds
    pop  es
(*%E *)
    mov  cx, 0FFFFH
    sub  al, al
repne ;  scasb                (* find end of string *)
    sub  di, 2
    cmp  di, dx               (* if it was a null string exit *)
    jb   rchrnotFound
    std
    mov  al, bl
    not  cx
    dec  cx
repne  ;  scasb               (* search *)
    je   rchrFound
rchrnotFound:
    sub  ax, ax               (* return NULL *)
    cwd
    jmp  rchrDone
rchrFound:
    inc  di                   (* return address of Matching character *)
    mov  ax, di
(*%F NearPtr *)
    mov  dx, es
(*%E *)
rchrDone:
    cld
    pop  di
(*%T NearPtr *)
