(******************************************************************************)
section


segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)

extrn DOSQFILEMODE

select _DATA


select _TEXT
public  __getfmode :

(*
int  __getfmode(char *path)

*)


path   = frame
mode   = -2
locals = 2

    push bp
    mov  bp, sp
    sub  sp, locals
(*%F RegParam *)
(*%F NearPtr *)
    push [bp][path][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][path]
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
    push bx
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push ax
(*%E *)

    push ss
    lea  ax, [bp][mode]
    push ax
    sub  ax, ax
    push ax
    push ax
    call far DOSQFILEMODE
    or   ax, ax
    jz   gfmOK
    mov  ax, -1
    jmp  gfmDone
gfmOK:
    mov  ax, [bp][mode]
gfmDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far  0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)

