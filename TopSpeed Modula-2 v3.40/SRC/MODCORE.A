segment _DATA(DATA, 28H)


select _TEXT

extrn __ioerr
extrn DOSQCURDIR

select _TEXT

public _getcurdir :

(*%F RegParam *)
drive  = frame
path   = 2+frame
length = -2
locals = 2

    push bp
    mov  bp, sp
    sub  sp, locals
    mov  word [bp][length], 64
    push [bp][drive]
(*%F NearPtr *)
    push [bp][path][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][path]
    push ss
    lea  ax, [bp][length]
    push ax
    call far DOSQCURDIR
    or   ax, ax
    jnz  dirError
dirDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

(*%T RegParam *)
drive  = frame
path   = 2+frame
length = -2
locals = 2

    push bp
    mov  bp, sp
    sub  sp, locals
    mov  word [bp][length], 64
    push ax
(*%F NearPtr *)
    push cx
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push bx
    push ss
    lea  ax, [bp][length]
    push ax
    call far DOSQCURDIR
    or   ax, ax
    jnz  dirError
dirDone:
    mov  sp, bp
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

dirError:
(*%F NearCall *)
