section
segment _TEXT(CODE,28H)
segment _DATA(DATA, 28H)


select _TEXT

extrn __ioerr
extrn DOSMOVE

select _TEXT

public _rename :

(*%F RegParam *)
(*%F NearPtr *)
newpath = 4+frame
(*%E *)
(*%T NearPtr *)
newpath = 2+frame
(*%E *)
oldpath = frame

    push bp
    mov  bp, sp
(*%F NearPtr *)
    push [bp][oldpath][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][oldpath]
(*%F NearPtr *)
    push [bp][newpath][2]
(*%E *)
(*%T NearPtr *)
    push ds
(*%E *)
    push [bp][newpath]
    sub  ax, ax
    push ax
    push ax
    call far DOSMOVE
    or   ax, ax
    jnz  renameError
renameDone:
    pop  bp
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

(*%T RegParam *)
(*%F NearPtr *)
    push bx
    push ax
    push dx
    push cx
(*%E *)
(*%T NearPtr *)
    push ds
    push ax
    push ds
    push bx
(*%E *)
    sub  ax, ax
    push ax
    push ax
    call far DOSMOVE
    or   ax, ax
    jnz  renameError
renameDone:
(*%F NearCall *)
    ret  far 0
(*%E *)
(*%T NearCall *)
    ret  0
(*%E *)
(*%E *)

renameError:
(*%F NearCall *)
    call far __ioerr
(*%E *)
(*%T NearCall *)
    call __ioerr
(*%E *)
    mov  ax, -1
    jmp  renameDone

