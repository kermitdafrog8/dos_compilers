(*%E *)
(*%E *)

(*%T RegParam *)
numread = -2
locals  =  2

    push bp
    mov  bp, sp
    sub  sp, locals
    push ax
(*%F NearPtr *)
    push cx
    push bx
    push dx
(*%E *)
(*%T NearPtr *)
   push  ds
   push  bx
   push  cx
(*%E *)
    lea  ax, [bp][numread]
    push ss
    push ax
    call far DOSREAD
    or   ax, ax
    jnz  readError
    mov  ax, [bp][numread]
readDone:
