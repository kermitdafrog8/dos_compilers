section
segment _TEXT(CODE,28H);

public N$SetAnd : Data = sframe+2; Count = sframe
  push bp
  mov bp, sp
  push ax; push bx; push cx; push si
  mov cx, [bp][Count]
  lea bp, [bp][Data]
  mov si, cx
$loop:
