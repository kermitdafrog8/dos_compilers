  (*       none                                                          *)
  (*     Trashes:                                                        *)
  (*       none                                                          *)
  (*     Return:                                                         *)
  (*       ax    - Status Code                                           *)
  (*     Aliases:                                                        *)
  (*       __heapchk                                                     *)
  (*                                                                     *)
  (***********************************************************************)
segment _TEXT(CODE,48H)

extrn Loader$HeapCheck

public __heapchk :
public __fheapchk :
    push bx
    xor  bx, bx
    call far Loader$HeapCheck
    pop  bx
    ret  far 0

